{
    "name": "megaforbb/forum",
    "description": "MegaforBB Forum - Premium MVC",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "symfony/http-foundation": "^6.4|^7.0",
        "symfony/dotenv": "^6.4|^7.0",
        "symfony/security-csrf": "^6.4|^7.0",
        "illuminate/database": "^10.0|^11.0",
        "meilisearch/meilisearch-php": "^1.16",
        "symfony/event-dispatcher": "^7.4",
        "symfony/routing": "^7.4",
        "symfony/dependency-injection": "^7.4",
        "phpoption/phpoption": "^1.9",
        "twig/twig": "^3.23",
        "league/flysystem": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.0",
        "intervention/image": "^3.11",
        "filp/whoops": "^2.18",
        "monolog/monolog": "^3.10"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^4.0",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "App/",
            "App\\Database\\Seeders\\": "App/Database/seeders/",
            "Forecor\\Core\\": "Forecor/Core/",
            "Forecor\\": "Forecor/",
            "Plugins\\": "Inc/Plugin/"
        },
        "files": [
            "Forecor/Core/config.php",
            "Forecor/Core/helpers.php"
        ]
    },
    "config": {
        "vendor-dir": "Library/vendor",
        "optimize-autoloader": true,
        "platform": { "php": "8.3.26" },
        "allow-plugins": { "php-http/discovery": true }
    },
    "minimum-stability": "stable"
}
