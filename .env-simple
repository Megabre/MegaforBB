# MegaforBB Environment
APP_NAME=MegaforBB
APP_ENV=Production
APP_DEBUG=false
APP_URL=
APP_KEY=
APP_LOCALE=tr
APP_TIMEZONE=Europe/Istanbul

# Database
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4

CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=0
# Reverse proxy : (örn: 127.0.0.1,10.0.0.0/8)
TRUSTED_PROXIES=127.0.0.1,::1
REDIS_HOST=127.0.0.1

REDIS_PORT=6379
REDIS_PASSWORD=null

# Meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=null


# Rate limiting (requests per minute)
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
RATE_LIMIT_POST=10

# Admin
ADMIN_PATH=admin


LM_API_BASE=https://my.megaforbb.com.tr/api/v1/license-manager
LM_PRODUCT_ID=PROD-XXXXXXXX
LM_LICENSE_KEY=XXXX-XXXX-XXXX-XXXX
LM_SITE_DOMAIN=https://example.com
# LM_ENFORCE=true  → true yapılırsa lisans geçersizse forum tamamen kapanır
LM_ENFORCE=false
