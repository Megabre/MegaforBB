{% extends 'base.html.twig' %}
{% set adminPath = adminPath ?? env('ADMIN_PATH', 'admin') %}
{% set permissions = permissions ?? [] %}
{% block content %}
<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title">{{ core_e(pageTitle ?? admin__('permissions.title')) }}</h2>
            </div>
            <div class="col-auto ms-auto d-print-none">
                <a href="{{ core_url(adminPath ~ '/permissions/create') }}" class="btn btn-primary d-none d-sm-inline-block">
                    <i class="ti ti-plus"></i> {{ core_e(admin__('permissions.new')) }}
                </a>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        <div class="card">
            <div class="table-responsive">
                <table class="table table-vcenter card-table table-striped">
                    <thead>
                        <tr>
                            <th>{{ core_e(admin__('permissions.group')) }}</th>
                            <th>{{ core_e(admin__('permissions.key')) }}</th>
                            <th>{{ core_e(admin__('permissions.description')) }}</th>
                            <th>{{ core_e(admin__('permissions.default_value')) }}</th>
                            <th class="w-1">{{ core_e(admin__('common.actions')) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if permissions is empty %}
                        <tr><td colspan="5" class="text-center text-muted">{{ core_e(admin__('permissions.no_definitions')) }}</td></tr>
                        {% else %}
                        {% for p in permissions %}
                        <tr>
                            <td class="text-muted">{{ core_e(p.group) }}</td>
                            <td class="font-weight-bold">{{ core_e(p.key) }}</td>
                            <td class="text-muted">{{ core_e(p.description) }}</td>
                            <td>
                                {% if p.default_value %}<span class="badge bg-success">{{ core_e(admin__('common.yes')) }}</span>
                                {% else %}<span class="badge bg-secondary">{{ core_e(admin__('common.no')) }}</span>{% endif %}
                            </td>
                            <td>
                                <div class="btn-list flex-nowrap">
                                    <a href="{{ core_url(adminPath ~ '/permissions/edit/' ~ p.id) }}" class="btn btn-sm btn-white">{{ core_e(admin__('common.edit')) }}</a>
                                    <form action="{{ core_url(adminPath ~ '/permissions/delete/' ~ p.id) }}" method="post" onsubmit="return confirm('{{ core_e(admin__('common.are_you_sure')) }}');" style="display:inline;">
                                        {{ core_csrf_field()|raw }}
                                        <button type="submit" class="btn btn-sm btn-danger">{{ core_e(admin__('common.delete')) }}</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
