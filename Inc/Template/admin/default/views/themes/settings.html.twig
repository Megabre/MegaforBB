{% extends 'base.html.twig' %}
{% set s = settings ?? {} %}
{% set flashOk = flashOk ?? null %}
{% set flashError = flashError ?? null %}
{% block content %}
<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <div class="page-pretitle">{{ lang('admin.themes.pretitle_manager') }}</div>
                <h2 class="page-title">{{ lang('admin.themes.settings_title') }}</h2>
            </div>
            <div class="col-auto ms-auto d-print-none">
                <a href="{{ core_url(adminPath ~ '/themes') }}" class="btn btn-outline-secondary"><i class="ti ti-arrow-left me-2"></i> {{ lang('admin.themes.back_to_themes') }}</a>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        {% if flashOk %}
        <div class="alert alert-success alert-dismissible" role="alert">
            {{ flashOk|e }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {% endif %}
        {% if flashError %}
        <div class="alert alert-danger alert-dismissible" role="alert">
            {{ flashError|e }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {% endif %}

        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-palette me-2"></i>{{ lang('admin.themes.quick_customize') }}</h3>
            </div>
            <form action="{{ core_url(adminPath ~ '/themes/settings') }}" method="post">
                {{ core_csrf_field('admin_theme_settings')|raw }}
                <div class="card-body">
                    <p class="text-muted mb-4">{{ lang('admin.themes.quick_customize_desc') }}</p>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{{ lang('admin.themes.site_name_label') }}</label>
                            <input type="text" name="seo_site_name" class="form-control" value="{{ (s.seo_site_name ?? '')|e }}" placeholder="{{ lang('admin.themes.placeholder_site_name') }}">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{{ lang('admin.themes.slogan_label') }}</label>
                            <input type="text" name="seo_description" class="form-control" value="{{ (s.seo_description ?? '')|e }}" placeholder="{{ lang('admin.themes.placeholder_short_desc') }}">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Forum Logo URL</label>
                        <input type="text" name="forum_logo_url" class="form-control" value="{{ (s.forum_logo_url ?? '')|e }}" placeholder="https://site.com/logo.png">
                        {% if s.forum_logo_url %}
                        <div class="mt-2 text-center p-3 border rounded bg-light" style="max-width: 250px;">
                            <img src="{{ s.forum_logo_url|e }}" alt="{{ lang('admin.themes.alt_logo_preview') }}" style="max-height: 50px;">
                        </div>
                        {% endif %}
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tema Ana Rengi (Vurgu)</label>
                        <input type="color" name="theme_primary_color" class="form-control form-control-color" value="{{ (s.theme_primary_color ?? '#206bc4')|e }}" title="Tema rengi">
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">{{ lang('admin.themes.header_bg_color') }}</label>
                            <input type="color" name="theme_header_bg_color" class="form-control form-control-color" value="{{ (s.theme_header_bg_color ?? '#1f2937')|e }}">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">{{ lang('admin.themes.header_text_color') }}</label>
                            <input type="color" name="theme_header_text_color" class="form-control form-control-color" value="{{ (s.theme_header_text_color ?? '#ffffff')|e }}">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">{{ lang('admin.themes.menu_bg_color') }}</label>
                            <input type="color" name="theme_menu_bg_color" class="form-control form-control-color" value="{{ (s.theme_menu_bg_color ?? '#172029')|e }}">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">{{ lang('admin.themes.menu_text_color') }}</label>
                            <input type="color" name="theme_menu_text_color" class="form-control form-control-color" value="{{ (s.theme_menu_text_color ?? '#ffffff')|e }}">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">{{ lang('admin.themes.button_radius') }}</label>
                            <input type="number" min="0" max="32" name="theme_button_radius" class="form-control" value="{{ (s.theme_button_radius ?? '10')|e }}">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">{{ lang('admin.themes.footer_bg_color') }}</label>
                            <input type="color" name="theme_footer_bg_color" class="form-control form-control-color" value="{{ (s.theme_footer_bg_color ?? '#111827')|e }}">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">{{ lang('admin.themes.footer_text_color') }}</label>
                            <input type="color" name="theme_footer_text_color" class="form-control form-control-color" value="{{ (s.theme_footer_text_color ?? '#d1d5db')|e }}">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">{{ lang('admin.themes.card_bg_color') }}</label>
                            <input type="color" name="theme_card_bg_color" class="form-control form-control-color" value="{{ (s.theme_card_bg_color ?? '#ffffff')|e }}">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">{{ lang('admin.themes.card_border_color') }}</label>
                            <input type="color" name="theme_card_border_color" class="form-control form-control-color" value="{{ (s.theme_card_border_color ?? '#e5e7eb')|e }}">
                        </div>
                    </div>
                    <hr class="my-4">
                    <h4 class="mb-3">{{ lang('admin.themes.custom_codes') }}</h4>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.themes.custom_css') }}</label>
                        <textarea class="form-control font-monospace" name="custom_css" rows="6" placeholder="body { background: #f4f4f4; }">{{ (s.custom_css ?? '')|e }}</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.themes.custom_js') }}</label>
                        <textarea class="form-control font-monospace" name="custom_js" rows="6" placeholder="console.log('Merhaba');">{{ (s.custom_js ?? '')|e }}</textarea>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center">
                    <button type="submit" name="action" value="reset_defaults" class="btn btn-outline-danger" onclick="return confirm('{{ lang('admin.themes.reset_defaults_confirm')|e('js') }}');">
                        <i class="ti ti-restore me-2"></i>{{ lang('admin.themes.reset_defaults') }}
                    </button>
                    <button type="submit" class="btn btn-primary"><i class="ti ti-device-floppy me-2"></i>{{ lang('admin.themes.save_settings') }}</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
