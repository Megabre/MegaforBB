{% extends 'base.html.twig' %}
{% set s = settings ?? {} %}
{% set tabOrder = tabOrder ?? [] %}
{% set colOrder = colOrder ?? [] %}
{% set tabDefaults = tabDefaults ?? {} %}
{% set colDefaults = colDefaults ?? {} %}
{% set colCheckNames = colCheckNames ?? {} %}
{% set categories = categories ?? [] %}
{% set allForums = allForums ?? [] %}
{% set selectedForums = s.portal_forum_ids ?? [] %}
{% set soSettings = s.son_olaylar_settings ?? {} %}
{% set portalTabVisibility = s.portal_tab_visibility ?? {} %}
{% block content %}
<style>
.list-group-item { transition: all 0.2s ease; }
.list-group-item:hover { background-color: #f8f9fa; }
</style>
<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title"><i class="ti ti-layout-list me-2 text-primary"></i>{{ lang('admin.son_olaylar.title') }}</h2>
            </div>
        </div>
    </div>
</div>
<div class="page-body">
    <div class="container-xl">
        {% if flashOk %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ flashOk|e }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
        {% endif %}

        <form action="{{ core_url(adminPath ~ '/son-olaylar/update') }}" method="post">
            {{ core_csrf_field('admin_son_olaylar')|raw }}

            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-white">
                    <h3 class="card-title fw-bold m-0">{{ lang('admin.son_olaylar.card_settings') }}</h3>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <input type="hidden" name="son_olaylar_enabled" value="0">
                        <label class="form-check form-switch mb-0">
                            <input type="checkbox" name="son_olaylar_enabled" value="1" class="form-check-input" {{ (soSettings.enabled ?? true) ? 'checked' : '' }}>
                            <span class="form-check-label fw-bold">{{ lang('admin.son_olaylar.show_card') }}</span>
                        </label>
                        <small class="form-hint mt-1">{{ lang('admin.son_olaylar.card_hint') }}</small>
                    </div>
                </div>
            </div>

            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-white">
                    <h3 class="card-title fw-bold m-0">{{ lang('admin.son_olaylar.tabs_columns') }}</h3>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-lg-7">
                            <div class="mb-4">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="ti ti-layout-list me-2 text-primary"></i>
                                    <span class="fw-semibold">{{ lang('admin.son_olaylar.tabs_label') }}</span>
                                    <span class="text-muted small ms-2">— {{ lang('admin.son_olaylar.tabs_hint') }}</span>
                                </div>
                                <ul id="son-olaylar-tab-order" class="list-group">
                                    {% for tid in tabOrder %}
                                    <li class="list-group-item d-flex align-items-center gap-3 py-2 px-3" data-tab-id="{{ tid }}">
                                        <span class="drag-handle text-muted cursor-grab" style="cursor:grab"><i class="ti ti-grip-vertical"></i></span>
                                        <div class="form-check form-switch m-0 flex-shrink-0">
                                            <input type="checkbox" name="portal_tab_{{ tid }}" value="1" class="form-check-input" {{ portalTabVisibility[tid] ? 'checked' : '' }}>
                                        </div>
                                        <input type="text" name="son_olaylar_tab_label_{{ tid }}" class="form-control form-control-sm border-0 bg-light px-2 fw-semibold" value="{{ soSettings['tab_label_' ~ tid] ?? tabDefaults[tid] ?? tid }}" placeholder="{{ tabDefaults[tid] ?? '' }}">
                                    </li>
                                    {% endfor %}
                                </ul>
                                <input type="hidden" name="son_olaylar_tab_order" id="son-olaylar-tab-order-input" value="{{ tabOrder|json_encode|e('html_attr') }}">
                            </div>
                            <div class="mb-2">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="ti ti-columns me-2 text-primary"></i>
                                    <span class="fw-semibold">{{ lang('admin.son_olaylar.table_columns') }}</span>
                                    <span class="text-muted small ms-2">— {{ lang('admin.son_olaylar.columns_hint') }}</span>
                                </div>
                                <ul id="son-olaylar-column-order" class="list-group">
                                    {% for cid in colOrder %}
                                    <li class="list-group-item d-flex align-items-center gap-3 py-2 px-3" data-col-id="{{ cid }}">
                                        <span class="drag-handle text-muted cursor-grab" style="cursor:grab"><i class="ti ti-grip-vertical"></i></span>
                                        <div class="form-check form-switch m-0 flex-shrink-0">
                                            {% if colCheckNames[cid] is defined %}
                                            <input type="checkbox" name="{{ colCheckNames[cid] }}" value="1" class="form-check-input" {{ (cid == 'title' or soSettings['show_' ~ cid]) ? 'checked' : '' }}>
                                            {% else %}
                                            <input type="checkbox" class="form-check-input" checked disabled>
                                            {% endif %}
                                        </div>
                                        <span class="fw-semibold text-dark">{{ colDefaults[cid] ?? cid }}</span>
                                    </li>
                                    {% endfor %}
                                </ul>
                                <input type="hidden" name="son_olaylar_column_order" id="son-olaylar-column-order-input" value="{{ colOrder|json_encode|e('html_attr') }}">
                                <label class="form-check mt-3 ms-1">
                                    <input type="checkbox" name="son_olaylar_show_topic_icon" value="1" class="form-check-input" {{ soSettings.show_topic_icon ? 'checked' : '' }}>
                                    <span class="form-check-label">{{ lang('admin.son_olaylar.show_author_avatar_in_title') }}</span>
                                </label>
                            </div>
                        </div>
                        <div class="col-lg-5">
                            <div class="mb-4">
                                <div class="d-flex align-items-center mb-3">
                                    <i class="ti ti-list-numbers me-2 text-primary"></i>
                                    <span class="fw-semibold">{{ lang('admin.son_olaylar.content_limits') }}</span>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-muted">{{ lang('admin.son_olaylar.initial_records_label') }}</label>
                                    <input type="number" name="portal_tab_limit" class="form-control" value="{{ s.portal_tab_limit ?? 15 }}" min="5" max="50">
                                    <small class="form-hint">{{ lang('admin.son_olaylar.initial_records_hint') }}</small>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-muted">{{ lang('admin.son_olaylar.max_records_ajax') }}</label>
                                    <input type="number" name="portal_tab_max" class="form-control" value="{{ s.portal_tab_max ?? 50 }}" min="10" max="100">
                                </div>
                            </div>
                            <div>
                                <div class="d-flex align-items-center mb-3">
                                    <i class="ti ti-text-resize me-2 text-primary"></i>
                                    <span class="fw-semibold">{{ lang('admin.son_olaylar.char_limits') }}</span>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-muted">{{ lang('admin.son_olaylar.comment_preview_length') }}</label>
                                    <input type="number" name="son_olaylar_comment_snippet_limit" class="form-control" value="{{ soSettings.comment_snippet_limit ?? 80 }}" min="40" max="150">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-muted">{{ lang('admin.son_olaylar.topic_title_max_length') }}</label>
                                    <input type="number" name="son_olaylar_topic_title_limit" class="form-control" value="{{ soSettings.topic_title_limit ?? 80 }}" min="40" max="120">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h3 class="card-title fw-bold m-0">{{ lang('admin.son_olaylar.data_sources') }}</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">{{ lang('admin.son_olaylar.data_forums_label') }}</label>
                            <p class="text-muted small mb-3">{{ lang('admin.son_olaylar.data_forums_hint') }}</p>
                            <select name="portal_forum_ids[]" class="form-select select2" multiple data-placeholder="{{ lang('admin.son_olaylar.placeholder_all_forums') }}">
                                {% for cat in categories %}
                                    {% set catForums = allForums|filter(f => f.category_id == cat.id) %}
                                    {% if catForums is not empty %}
                                    <optgroup label="{{ cat.name|e('html_attr') }}">
                                        {% for f in catForums %}
                                        <option value="{{ f.id }}" {{ f.id in selectedForums ? 'selected' : '' }}>{{ f.name|e }}</option>
                                        {% endfor %}
                                    </optgroup>
                                    {% endif %}
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4 mb-5">
                <button type="submit" class="btn btn-primary px-5 py-2 fw-bold"><i class="ti ti-device-floppy me-2"></i> Ayarları Kaydet</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    if (typeof $ !== 'undefined' && typeof $.fn.select2 !== 'undefined') {
        $('.select2').select2({ theme: 'bootstrap-5', width: '100%' });
    }
    var tabEl = document.getElementById('son-olaylar-tab-order');
    if (tabEl) {
        new Sortable(tabEl, {
            animation: 150, handle: '.drag-handle',
            onEnd: function () {
                var order = [];
                tabEl.querySelectorAll('[data-tab-id]').forEach(function(li) { order.push(li.getAttribute('data-tab-id')); });
                document.getElementById('son-olaylar-tab-order-input').value = JSON.stringify(order);
            }
        });
    }
    var colEl = document.getElementById('son-olaylar-column-order');
    if (colEl) {
        new Sortable(colEl, {
            animation: 150, handle: '.drag-handle',
            onEnd: function () {
                var order = [];
                colEl.querySelectorAll('[data-col-id]').forEach(function(li) { order.push(li.getAttribute('data-col-id')); });
                document.getElementById('son-olaylar-column-order-input').value = JSON.stringify(order);
            }
        });
    }
});
</script>
{% endblock %}
