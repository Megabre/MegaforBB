{% extends 'base.html.twig' %}
{% block content %}
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-lite.min.css" rel="stylesheet">
<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title"><i class="ti ti-send me-2"></i> {{ lang('admin.communication.send_mail_title') }}</h2>
                <div class="text-muted mt-1">{{ lang('admin.communication.send_mail_desc') }}</div>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        {% if flashError is defined and flashError %}
        <div class="alert alert-danger alert-dismissible mb-3">
            {{ (flashError is iterable ? flashError[0] : flashError)|e }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {% endif %}
        {% if flashSuccess is defined and flashSuccess %}
        <div class="alert alert-success alert-dismissible mb-3">
            {{ (flashSuccess is iterable ? flashSuccess[0] : flashSuccess)|e }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {% endif %}

        <div class="card">
            <form action="{{ core_url(adminPath ~ '/communication/send') }}" method="post">
                {{ core_csrf_field('admin_communication')|raw }}
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.communication.recipient_type') }}</label>
                        <select name="recipient_type" id="recipient_type" class="form-select">
                            <option value="user">{{ lang('admin.communication.recipient_user') }}</option>
                            <option value="email">{{ lang('admin.communication.recipient_email') }}</option>
                        </select>
                    </div>
                    <div class="mb-3" id="wrap_user_identifier">
                        <label class="form-label">{{ lang('admin.communication.user_identifier_ph') }}</label>
                        <input type="text" name="user_identifier" class="form-control" placeholder="{{ lang('admin.communication.user_identifier_ph') }}">
                    </div>
                    <div class="mb-3 d-none" id="wrap_email">
                        <label class="form-label">{{ lang('admin.common.email') }}</label>
                        <input type="email" name="email" class="form-control" placeholder="{{ lang('admin.communication.email_ph') }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.communication.subject') }}</label>
                        <input type="text" name="subject" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.communication.body') }}</label>
                        <textarea id="body-editor" name="body_html" class="form-control" rows="10" required></textarea>
                        {% if placeholders is defined and placeholders is not empty %}
                        <div class="mt-2 p-3 bg-light rounded small">
                            <strong>{{ lang('admin.communication.available_tags') }}</strong>
                            <p class="text-muted mb-1 mt-1">{{ lang('admin.communication.available_tags_hint') }}</p>
                            <code class="d-inline-flex flex-wrap gap-1">{% for key, desc in placeholders %}<span title="{{ desc|e('html_attr') }}">{{ '{' ~ key ~ '}' }}</span>{% if not loop.last %} · {% endif %}{% endfor %}</code>
                        </div>
                        {% endif %}
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary"><i class="ti ti-send me-1"></i> {{ lang('admin.communication.send_mail_title') }}</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-lite.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    var rt = document.getElementById('recipient_type');
    var wrapUser = document.getElementById('wrap_user_identifier');
    var wrapEmail = document.getElementById('wrap_email');
    function toggle() {
        if (rt.value === 'email') {
            wrapUser.classList.add('d-none');
            wrapEmail.classList.remove('d-none');
            wrapUser.querySelector('input').removeAttribute('required');
            wrapEmail.querySelector('input').setAttribute('required', 'required');
        } else {
            wrapUser.classList.remove('d-none');
            wrapEmail.classList.add('d-none');
            wrapUser.querySelector('input').setAttribute('required', 'required');
            wrapEmail.querySelector('input').removeAttribute('required');
        }
    }
    rt.addEventListener('change', toggle);
    toggle();

    if (typeof jQuery !== 'undefined' && jQuery().summernote) {
        jQuery('#body-editor').summernote({ height: 280 });
    }
});
</script>
{% endblock %}
