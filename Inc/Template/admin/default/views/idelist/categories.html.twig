{% extends "base.html.twig" %}
{% block head_extra %}
  <link rel="stylesheet" href="{{ theme_asset_url('css/idelist.css') }}?v={{ core_config('app.version', '1.0.0') }}">
{% endblock %}

{% block content %}
<div class="container-xl py-3">
  {% include 'idelist/_nav.html.twig' with { tab: 'categories' } %}
  <div class="idelist-admin-grid">
    <section class="idelist-admin-panel">
      <div class="idelist-admin-panel__head">{{ core_e(core__('idelist.add_category')) }}</div>
      <div class="idelist-admin-panel__body">
        <form method="post" action="{{ core_url(adminPath ~ '/idelist/categories') }}" class="d-grid gap-2">
          {{ core_csrf_field('idelist_admin_category')|raw }}
          <input class="form-control" name="name" placeholder="{{ core_e(core__('idelist.category_label')) }}" required maxlength="100">
          <div class="d-flex align-items-center gap-2">
            <input class="form-control form-control-color" type="color" name="color_picker" value="#3B82F6" data-color-target="create">
            <input class="form-control" name="color" id="create-color-input" placeholder="#3B82F6" maxlength="7">
          </div>
          {% include 'idelist/_color_palette.html.twig' with { targetKey: 'create' } %}
          <input class="form-control" name="icon" placeholder="fa-solid fa-lightbulb" maxlength="50">
          <input class="form-control" type="number" name="sort_order" value="0">
          <button class="btn btn-primary">{{ core_e(core__('idelist.add_category')) }}</button>
        </form>
      </div>
    </section>

    <section class="idelist-admin-panel">
      <div class="idelist-admin-panel__head">{{ core_e(core__('idelist.admin_tab_categories')) }}</div>
      <div class="idelist-admin-panel__body">
        {% for c in categories %}
        <div class="idelist-category-row">
          <form method="post" action="{{ core_url(adminPath ~ '/idelist/categories/' ~ c.id) }}" class="contents">
            {{ core_csrf_field('idelist_admin_category')|raw }}
            <input class="form-control form-control-sm" name="name" value="{{ c.name|e('html_attr') }}">
            <div>
              <div class="d-flex align-items-center gap-2">
                <input class="form-control form-control-color form-control-sm" type="color" value="{{ (c.color ?: '#3B82F6')|e('html_attr') }}" data-color-target="row-{{ c.id }}">
                <input class="form-control form-control-sm" name="color" id="row-{{ c.id }}-color-input" value="{{ c.color|default('')|e('html_attr') }}">
              </div>
              {% include 'idelist/_color_palette.html.twig' with { targetKey: 'row-' ~ c.id } %}
            </div>
            <input class="form-control form-control-sm" name="icon" value="{{ c.icon|default('')|e('html_attr') }}">
            <input class="form-control form-control-sm" type="number" name="sort_order" value="{{ c.sort_order|default(0) }}">
            <button class="btn btn-sm btn-outline-primary" type="submit">{{ core_e(core__('idelist.save_action')) }}</button>
          </form>
          <form method="post" action="{{ core_url(adminPath ~ '/idelist/categories/' ~ c.id ~ '/delete') }}" onsubmit="return confirm({{ core__('idelist.confirm_delete_category')|json_encode|raw }})">
            {{ core_csrf_field('idelist_admin_category')|raw }}
            <button class="btn btn-sm btn-danger" type="submit">{{ core_e(core__('idelist.delete_action')) }}</button>
          </form>
        </div>
        {% else %}
          <div class="text-muted">{{ core_e(core__('idelist.no_categories')) }}</div>
        {% endfor %}
      </div>
    </section>
  </div>
</div>
{% endblock %}

{% block scripts %}
{% include 'idelist/_color_palette_script.html.twig' %}
<script>
bindPalette('create', 'create');
document.querySelectorAll('[data-color-target^="row-"]').forEach(function (el) {
  bindPalette(el.getAttribute('data-color-target'), 'create');
});
</script>
{% endblock %}
