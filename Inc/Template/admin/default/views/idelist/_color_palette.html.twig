<div class="idelist-color-palette" data-palette-target="{{ targetKey }}">
  {% for cp in ['#3B82F6','#8B5CF6','#F59E0B','#22C55E','#EF4444','#64748B'] %}
  <button type="button" class="idelist-color-dot" data-color="{{ cp }}" style="background: {{ cp }}" title="{{ cp }}"></button>
  {% endfor %}
</div>
