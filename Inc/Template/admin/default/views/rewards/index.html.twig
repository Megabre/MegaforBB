{% extends 'base.html.twig' %}
{% set list = list ?? [] %}
{% block content %}
<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title">{{ lang('admin.rewards.title') }}</h2>
            </div>
            <div class="col-auto ms-auto d-print-none">
                <a href="{{ core_url(adminPath ~ '/rewards/create') }}" class="btn btn-primary">{{ lang('admin.rewards.new_level') }}</a>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        <div class="card">
            <div class="card-body">
                <p class="text-muted mb-4">{{ lang('admin.rewards.description') }}</p>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter card-table table-striped">
                    <thead>
                        <tr>
                            <th>{{ lang('admin.common.sort_order') }}</th>
                            <th>{{ lang('admin.common.name') }}</th>
                            <th>{{ lang('admin.rewards.min_posts') }}</th>
                            <th>{{ lang('admin.rewards.min_reputation') }}</th>
                            <th>{{ lang('admin.rewards.min_likes') }}</th>
                            <th>{{ lang('admin.rewards.badge') }}</th>
                            <th class="w-1">{{ lang('admin.common.actions') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if list is empty %}
                        <tr><td colspan="7" class="text-center text-muted">{{ lang('admin.rewards.no_levels') }}</td></tr>
                        {% else %}
                        {% for r in list %}
                        <tr>
                            <td>{{ r.sort_order ?? 0 }}</td>
                            <td class="font-weight-bold">{{ (r.name ?? '')|e }}</td>
                            <td>{{ r.min_posts ?? 0 }}</td>
                            <td>{{ r.min_reputation ?? 0 }}</td>
                            <td>{{ r.min_likes ?? 0 }}</td>
                            <td>
                                {% if r.badge_label or r.badge_icon %}
                                <span class="badge {{ (r.badge_css ?? 'bg-secondary')|e }}">
                                    {% if r.badge_icon %}<i class="fa {{ r.badge_icon|e }} me-1"></i>{% endif %}
                                    {{ (r.badge_label ?? r.name ?? '')|e }}
                                </span>
                                {% else %}
                                <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="btn-list flex-nowrap">
                                    <a href="{{ core_url(adminPath ~ '/rewards/edit/' ~ r.id) }}" class="btn btn-sm btn-white">{{ lang('admin.common.edit') }}</a>
                                    <form action="{{ core_url(adminPath ~ '/rewards/delete/' ~ r.id) }}" method="post" onsubmit="return confirm('{{ lang('admin.rewards.delete_confirm') }}');" style="display:inline;">
                                        {{ core_csrf_field('admin_reward_delete')|raw }}
                                        <button type="submit" class="btn btn-sm btn-danger">{{ lang('admin.common.delete') }}</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
