                        <input type="url" name="schema_url" class="form-control" value="{{ (sf.schema_url ?? '')|e }}" placeholder="https://forumum.com">
                        <small class="form-hint d-block mt-1">{{ lang('admin.sys_settings.schema_url_hint') }}</small>
                    </div>
                    <div class="mb-3" id="schema-search-section">
                        <input type="hidden" name="schema_search_include" value="0">
                        <label class="form-check form-switch mb-2">
                            <input type="checkbox" name="schema_search_include" value="1" class="form-check-input" {{ sf.schema_search_include ?? true ? 'checked' : '' }}>
                            <span class="form-check-label">{{ lang('admin.sys_settings.schema_search_include') }}</span>
                        </label>
                        <input type="text" name="schema_search_url" class="form-control" value="{{ (sf.schema_search_url ?? '')|e }}" placeholder="https://forumum.com/search?q={search_term_string}">
                        <small class="form-hint d-block mt-1">{{ lang('admin.sys_settings.schema_search_url_hint') }}</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.schema_publisher') }}</label>
                        <input type="text" name="schema_publisher_name" class="form-control" value="{{ (sf.schema_publisher_name ?? '')|e }}" placeholder="{{ lang('admin.sys_settings.schema_publisher_hint') }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.schema_logo') }}</label>
                        <input type="url" name="schema_logo_url" class="form-control" value="{{ (sf.schema_logo_url ?? '')|e }}" placeholder="https://forumum.com/logo.png">
                        <small class="form-hint d-block mt-1">{{ lang('admin.sys_settings.schema_logo_hint') }}</small>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">{{ lang('admin.common.save') }}</button>
                </div>
            </form>
        </div>
        <script>
        (function() {
            var typeSelect = document.getElementById('schema-type-select');
            var searchSection = document.getElementById('schema-search-section');
            if (typeSelect && searchSection) {
                function toggle() { searchSection.style.display = typeSelect.value === 'Organization' ? 'none' : 'block'; }
                typeSelect.addEventListener('change', toggle);
                toggle();
            }
        })();
        </script>
        <div class="card mb-4">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-refresh me-2"></i>{{ lang('admin.sys_settings.rebuild_sef_title') }}</h3></div>
            <div class="card-body">
                <p class="text-muted mb-3">{{ lang('admin.sys_settings.rebuild_sef_desc') }}</p>
                <form action="{{ core_url((s.admin_path ?? 'admin') ~ '/system-settings/rebuild-sef-urls') }}" method="post" onsubmit="return confirm('{{ lang('admin.sys_settings.rebuild_sef_confirm')|e('js') }}');">
                    {{ core_csrf_field('admin_system_settings')|raw }}
                    <button type="submit" class="btn btn-outline-primary"><i class="ti ti-refresh me-1"></i>{{ lang('admin.sys_settings.rebuild_sef_btn') }}</button>
                </form>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-code me-2"></i>{{ lang('admin.sys_settings.custom_css_js') }}</h3></div>
            <form action="{{ core_url((s.admin_path ?? 'admin') ~ '/system-settings/update') }}" method="post">
                {{ core_csrf_field('admin_system_settings')|raw }}
                <input type="hidden" name="tab" value="seo">
                <div class="card-body">
                    <p class="text-muted small mb-3">{{ lang('admin.sys_settings.custom_css_js_desc') }}</p>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.custom_css') }}</label>
                        <textarea name="custom_css" class="form-control text-monospace" rows="5" placeholder=".header { background: red; }">{{ (s.custom_css ?? '')|e }}</textarea>
                        <small class="form-hint">{{ lang('admin.sys_settings.custom_css_hint') }}</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.custom_js') }}</label>
                        <textarea name="custom_js" class="form-control text-monospace" rows="5" placeholder="console.log('Hello');">{{ (s.custom_js ?? '')|e }}</textarea>
                        <small class="form-hint">{{ lang('admin.sys_settings.custom_js_hint') }}</small>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary"><i class="ti ti-device-floppy me-1"></i>{{ lang('admin.common.save') }}</button>
                </div>
            </form>
        </div>

        <div class="card mb-4">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-file-text me-2"></i>{{ lang('admin.sys_settings.robots_txt_editor') }}</h3></div>
            <form action="{{ core_url((s.admin_path ?? 'admin') ~ '/system-settings/update') }}" method="post">
                {{ core_csrf_field('admin_system_settings')|raw }}
                <input type="hidden" name="tab" value="seo">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.robots_txt_content') }}</label>
                        <textarea name="robots_txt_content" class="form-control text-monospace" rows="8" placeholder="User-agent: *&#10;Allow: /">{{ (s.robots_txt_content ?? '')|e }}</textarea>
                        <small class="form-hint">{{ lang('admin.sys_settings.robots_txt_hint') }}</small>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary"><i class="ti ti-device-floppy me-1"></i>{{ lang('admin.common.save') }}</button>
                </div>
            </form>
        </div>

        <div class="card mb-4">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-sitemap me-2"></i>{{ lang('admin.sys_settings.sitemap_xml') }}</h3></div>
            <div class="card-body">
                <p class="text-muted mb-3">{{ lang('admin.sys_settings.sitemap_xml_desc') }}</p>
                <form action="{{ core_url((s.admin_path ?? 'admin') ~ '/system-settings/rebuild-sitemap') }}" method="post" onsubmit="return confirm('{{ lang('admin.sys_settings.sitemap_rebuild_confirm')|e('js') }}');">
                    {{ core_csrf_field('admin_system_settings')|raw }}
                    <button type="submit" class="btn btn-success"><i class="ti ti-sitemap me-1"></i>{{ lang('admin.sys_settings.sitemap_rebuild_btn') }}</button>
                </form>
            </div>
        </div>
{% endif %}

{% if activeTab == 'storage' %}
        <div class="card mb-4">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-cloud-upload me-2"></i>{{ lang('admin.sys_settings.cloud_storage') }}</h3></div>
            <form action="{{ core_url((s.admin_path ?? 'admin') ~ '/system-settings/update') }}" method="post" id="storage-form">
                {{ core_csrf_field('admin_system_settings')|raw }}
                <input type="hidden" name="tab" value="storage">
                <div class="card-body">
                    <div class="mb-4">
                        <label class="form-label">{{ lang('admin.sys_settings.storage_type') }}</label>
                        <div class="form-selectgroup">
                            <label class="form-selectgroup-item">
                                <input type="radio" name="storage_driver" value="local" class="form-selectgroup-input" {{ (s.storage_driver ?? 'local') == 'local' ? 'checked' : '' }}>
                                <span class="form-selectgroup-label">{{ lang('admin.sys_settings.storage_local') }}</span>
                            </label>
                            <label class="form-selectgroup-item">
                                <input type="radio" name="storage_driver" value="aws_s3" class="form-selectgroup-input" {{ (s.storage_driver ?? '') == 'aws_s3' ? 'checked' : '' }}>
                                <span class="form-selectgroup-label">AWS S3</span>
                            </label>
                            <label class="form-selectgroup-item">
                                <input type="radio" name="storage_driver" value="r2" class="form-selectgroup-input" {{ (s.storage_driver ?? '') == 'r2' ? 'checked' : '' }}>
                                <span class="form-selectgroup-label">Cloudflare R2</span>
                            </label>
                        </div>
                    </div>
                    <div id="storage-local-section" class="storage-driver-section mb-4" style="{{ (s.storage_driver ?? 'local') == 'local' ? '' : 'display:none' }}">
                        <hr class="my-4"><h4 class="mb-3">Yerel yükleme dizini</h4>
                        <p class="text-muted small mb-2">Depolama türü <strong>Yerel disk</strong> iken avatar, kapak ve ek dosyalar bu dizine yazılır. URL her zaman <code>/uploads/...</code> kalır; sadece sunucudaki fiziksel konum değişir. <strong>AWS S3 veya R2</strong> seçiliyse yüklemeler buluta gider, bu ayar kullanılmaz.</p>
                        <div class="mb-3">
                            <label class="form-label">Yükleme kök dizini (proje içinde)</label>
                            <select name="storage_local_path" class="form-select">
                                <option value="uploads" {{ (s.storage_local_path ?? 'uploads') == 'uploads' ? 'selected' : '' }}>uploads (proje kökünde)</option>
                                <option value="Content/storage/uploads" {{ (s.storage_local_path ?? '') == 'Content/storage/uploads' ? 'selected' : '' }}>Content/storage/uploads</option>
                            </select>
                            <small class="form-hint">Varsayılan: <code>uploads</code>. İçeriği tek yerde toplamak için <code>Content/storage/uploads</code> seçebilirsiniz.</small>
                        </div>
                    </div>
                    <div id="storage-aws-s3-section" class="storage-driver-section mb-4" style="{{ (s.storage_driver ?? 'local') == 'aws_s3' ? '' : 'display:none' }}">
                        <hr class="my-4"><h4 class="mb-3">{{ lang('admin.sys_settings.aws_s3_settings') }}</h4>
                        <div class="row mb-3">
                            <div class="col-md-6"><label class="form-label">Access Key ID</label><input type="text" name="storage_aws_s3_key" class="form-control" value="{{ (s.storage_aws_s3_key ?? '')|e }}"></div>
                            <div class="col-md-6"><label class="form-label">Secret Access Key</label><input type="password" name="storage_aws_s3_secret" class="form-control" value="" placeholder="••••••••"></div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6"><label class="form-label">{{ lang('admin.sys_settings.bucket_name') }}</label><input type="text" name="storage_aws_s3_bucket" class="form-control" value="{{ (s.storage_aws_s3_bucket ?? '')|e }}"></div>
                            <div class="col-md-6"><label class="form-label">{{ lang('admin.sys_settings.region') }}</label><input type="text" name="storage_aws_s3_region" class="form-control" value="{{ (s.storage_aws_s3_region ?? 'us-east-1')|e }}"></div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6"><label class="form-label">{{ lang('admin.sys_settings.bucket_prefix') }}</label><input type="text" name="storage_aws_s3_prefix" class="form-control" value="{{ (s.storage_aws_s3_prefix ?? '')|e }}"></div>
                            <div class="col-md-6"><label class="form-label">CDN URL</label><input type="url" name="storage_aws_s3_cdn_url" class="form-control" value="{{ (s.storage_aws_s3_cdn_url ?? '')|e }}"></div>
                        </div>
                    </div>
                    <div id="storage-r2-section" class="storage-driver-section mb-4" style="{{ (s.storage_driver ?? 'local') == 'r2' ? '' : 'display:none' }}">
                        <hr class="my-4"><h4 class="mb-3">{{ lang('admin.sys_settings.r2_settings') }}</h4>
                        <div class="row mb-3">
                            <div class="col-md-6"><label class="form-label">Access Key ID</label><input type="text" name="storage_r2_key" class="form-control" value="{{ (s.storage_r2_key ?? '')|e }}"></div>
                            <div class="col-md-6"><label class="form-label">Secret Access Key</label><input type="password" name="storage_r2_secret" class="form-control" value="" placeholder="••••••••"></div>
                        </div>
                        <div class="mb-3"><label class="form-label">S3 API Endpoint</label><input type="url" name="storage_r2_endpoint" class="form-control" value="{{ (s.storage_r2_endpoint ?? '')|e }}"></div>
                        <div class="row mb-3">
                            <div class="col-md-6"><label class="form-label">{{ lang('admin.sys_settings.bucket_name') }}</label><input type="text" name="storage_r2_bucket" class="form-control" value="{{ (s.storage_r2_bucket ?? '')|e }}"></div>
                            <div class="col-md-6"><label class="form-label">{{ lang('admin.sys_settings.bucket_prefix') }}</label><input type="text" name="storage_r2_prefix" class="form-control" value="{{ (s.storage_r2_prefix ?? '')|e }}"></div>
                        </div>
                        <div class="mb-3"><label class="form-label">CDN / public URL</label><input type="url" name="storage_r2_cdn_url" class="form-control" value="{{ (s.storage_r2_cdn_url ?? '')|e }}"></div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary"><i class="ti ti-device-floppy me-1"></i>{{ lang('admin.common.save') }}</button>
                </div>
            </form>
            <div class="card-footer bg-light">
                <p class="text-muted small mb-2">Yükleme kök dizinini değiştirdikten sonra <strong>önce Kaydet</strong>e basın. Ardından eski dizindeki tüm dosyaları mevcut dizine taşımak ve veritabanı referanslarını güncellemek için:</p>
                <form action="{{ core_url((s.admin_path ?? 'admin') ~ '/system-settings/storage-sync') }}" method="post" class="d-inline" onsubmit="return confirm('Eski yükleme dizinindeki dosyalar mevcut dizine taşınacak ve veritabanı path\'leri güncellenecek. Emin misiniz?');">
                    {{ core_csrf_field('admin_system_settings')|raw }}
                    <button type="submit" class="btn btn-outline-primary"><i class="ti ti-folder-move me-1"></i>Yüklemeleri mevcut dizine senkronize et</button>
                </form>
            </div>
        </div>
        <script>
        (function(){
            var form = document.getElementById('storage-form');
            if (!form) return;
            var sections = { local: ['storage-local-section'], aws_s3: ['storage-aws-s3-section'], r2: ['storage-r2-section'] };
            form.querySelectorAll('input[name="storage_driver"]').forEach(function(radio) {
                radio.addEventListener('change', function() {
                    var v = this.value;
                    document.querySelectorAll('.storage-driver-section').forEach(function(el) { el.style.display = 'none'; });
                    (sections[v] || []).forEach(function(id) {
                        var el = document.getElementById(id);
                        if (el) el.style.display = '';
                    });
                });
            });
        })();
        </script>
{% endif %}

{% if activeTab == 'debug' %}
        <div class="card mb-4">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-bug me-2"></i>Debug modu (APP_DEBUG)</h3></div>
            <form action="{{ core_url((s.admin_path ?? 'admin') ~ '/system-settings/update') }}" method="post">
                {{ core_csrf_field('admin_system_settings')|raw }}
                <input type="hidden" name="tab" value="debug">
                <div class="card-body">
                    <p class="mb-3">Debug modunu aşağıdaki anahtarla panelden açıp kapatabilirsiniz. Değer veritabanında saklanır ve <code>.env</code> içindeki <code>APP_DEBUG</code> değerini geçersiz kılar.</p>
                    <div class="mb-4">
                        <input type="hidden" name="app_debug" value="0">
                        <label class="form-check form-switch form-switch-lg">
                            <input type="checkbox" name="app_debug" value="1" class="form-check-input" {{ appDebug ? 'checked' : '' }}>
                            <span class="form-check-label fw-bold">Debug modu açık</span>
                        </label>
                        <div class="mt-2">
                            <span class="badge bg-{{ appDebug ? 'success' : 'secondary' }} fs-6 px-2 py-1">{{ appDebug ? 'true' : 'false' }}</span>
                            <span class="ms-2 text-muted">Etkin değer: {{ appDebug ? 'true' : 'false' }}</span>
                        </div>
                    </div>
                    {% if not appDebug %}
                    <div class="alert alert-warning mb-0">
                        <i class="ti ti-alert-triangle me-2"></i>
                        <strong>Debug kapalı:</strong> Sunucu hataları (exception, PHP error) kullanıcıya ekranda gösterilmez; yalnızca log dosyasına yazılır. Tüm hatalar <code>Content/storage/logs/megaforbb-YYYY-MM-DD.log</code> dosyasında tutulur. Geliştirme sırasında sorun tespiti için yukarıdan debug modunu açabilirsiniz; canlı ortamda güvenlik için kapalı bırakın.
                    </div>
                    {% else %}
                    <div class="alert alert-info mb-0">
                        <i class="ti ti-info-circle me-2"></i>
                        <strong>Debug açık:</strong> Yakalanan hatalar hem log dosyasına yazılır hem de tarayıcıda (Whoops sayfası veya PHP uyarıları) gösterilir. Canlı sunucuda güvenlik için debug modunu kapatmanız önerilir.
                    </div>
                    {% endif %}
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary"><i class="ti ti-device-floppy me-1"></i>{{ lang('admin.common.save') }}</button>
                </div>
            </form>
        </div>
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title mb-0"><i class="ti ti-file-text me-2"></i>Son hata log satırları</h3>
                {% if logPath %}<span class="text-muted small font-monospace">{{ logPath|e }}</span>{% endif %}
            </div>
            <div class="card-body p-0">
                {% if recentLogLines is not empty %}
                <pre class="mb-0 p-3 bg-dark text-light small font-monospace" style="max-height: 420px; overflow: auto;">{% for line in recentLogLines %}{{ line|e }}{{ "\n" }}{% endfor %}</pre>
                {% else %}
                <p class="text-muted p-3 mb-0">Henüz log kaydı yok veya dosya okunamıyor.</p>
                {% endif %}
            </div>
        </div>
{% endif %}

        <div class="mb-4">
            <a href="{{ core_url(s.admin_path ?? 'admin') }}" class="btn">{{ lang('admin.sys_settings.back_to_panel') }}</a>
        </div>
    </div>
</div>
{% endblock %}
