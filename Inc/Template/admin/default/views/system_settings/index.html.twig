{% extends 'base.html.twig' %}
{% set s = settings ?? {} %}
{% set activeTab = activeTab ?? 'general' %}
{% set menuItems = s.top_menu_items ?? [] %}
{% set menuItemsTree = s.menu_items_tree ?? [] %}
{% set footerMenuItems = s.footer_menu_items ?? [] %}
{% set footerQuickLinks = s.footer_quick_links ?? [] %}
{% set pageTitles = {
    'general': { 'title': lang('admin.sys_settings.tab_general_title'), 'desc': lang('admin.sys_settings.tab_general_desc'), 'icon': 'ti-home-cog' },
    'menu':    { 'title': lang('admin.sys_settings.tab_menu_title'), 'desc': lang('admin.sys_settings.tab_menu_desc'), 'icon': 'ti-menu-2' },
    'mail':    { 'title': lang('admin.sys_settings.tab_mail_title'), 'desc': lang('admin.sys_settings.tab_mail_desc'), 'icon': 'ti-mail-cog' },
    'seo':     { 'title': lang('admin.sys_settings.tab_seo_title'), 'desc': lang('admin.sys_settings.tab_seo_desc'), 'icon': 'ti-search' },
    'storage': { 'title': lang('admin.sys_settings.tab_storage_title'), 'desc': lang('admin.sys_settings.tab_storage_desc'), 'icon': 'ti-cloud-upload' },
    'debug':   { 'title': 'Debug Modu', 'desc': 'APP_DEBUG durumu ve son hata log satirlari', 'icon': 'ti-bug' }
} %}
{% set page = pageTitles[activeTab] ?? pageTitles['general'] %}
{% set cronToken = s.cron_token ?? '' %}
{% set cronUrl = cronToken != '' ? (core_url('cron.php?token=' ~ cronToken)) : '' %}
{% set cronUrlFull = cronUrlFull ?? '' %}
{% set cronCliExample = cronCliExample ?? '' %}
{% set homePageType = s.home_page_type ?? 'forum' %}
{% set appDebug = appDebug ?? false %}
{% set logPath = logPath ?? '' %}
{% set recentLogLines = recentLogLines ?? [] %}
{% block content %}
<div class="page-header d-print-none">
    <div class="container-lg">
        <div class="row g-2 align-items-center">
            <div class="col-auto">
                <span class="page-pretitle-icon"><i class="ti {{ page.icon }} fs-2 text-primary"></i></span>
            </div>
            <div class="col">
                <h2 class="page-title">{{ page.title }}</h2>
                <div class="text-muted mt-1">{{ page.desc }}</div>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-lg">
        {% if flashSuccess %}
        <div class="alert alert-success alert-dismissible mb-4" role="alert">
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ lang('admin.sys_settings.alert_close') }}"></button>
            {{ flashSuccess|e }}
        </div>
        {% endif %}
        {% if flashError %}
        <div class="alert alert-danger alert-dismissible mb-4" role="alert">
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ lang('admin.sys_settings.alert_close') }}"></button>
            {{ flashError|e }}
        </div>
        {% endif %}

{% if activeTab == 'general' %}
        <div class="card mb-4">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-settings me-2"></i>{{ lang('admin.sys_settings.general_card') }}</h3></div>
            <form action="{{ core_url((s.admin_path ?? 'admin') ~ '/system-settings/update') }}" method="post">
                {{ core_csrf_field('admin_system_settings')|raw }}
                <input type="hidden" name="tab" value="general">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.forum_logo_url') }}</label>
                        <input type="text" name="forum_logo_url" class="form-control" value="{{ (s.forum_logo_url ?? '')|e }}" placeholder="https://example.com/logo.png">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.favicon_url') }}</label>
                        <input type="text" name="forum_favicon_url" class="form-control" value="{{ (s.forum_favicon_url ?? '')|e }}" placeholder="https://example.com/favicon.ico">
                        {% if s.forum_favicon_url %}
                        <div class="mt-2 d-flex align-items-center gap-2">
                            <img src="{{ s.forum_favicon_url|e }}" alt="Favicon" style="height:32px;width:32px;object-fit:contain;border:1px solid #dee2e6;border-radius:4px;">
                            <span class="text-muted small">{{ lang('admin.sys_settings.current_favicon') }}</span>
                        </div>
                        {% endif %}
                    </div>
                    <div class="mb-3">
                        <input type="hidden" name="show_site_title_next_to_logo" value="0">
                        <label class="form-check form-switch">
                            <input type="checkbox" name="show_site_title_next_to_logo" value="1" class="form-check-input" {{ s.show_site_title_next_to_logo ? 'checked' : '' }}>
                            <span class="form-check-label">{{ lang('admin.sys_settings.show_site_title') }}</span>
                        </label>
                    </div>
                    <div class="mb-3">
                        <input type="hidden" name="maintenance_mode" value="0">
                        <label class="form-check form-switch">
                            <input type="checkbox" name="maintenance_mode" value="1" class="form-check-input" {{ s.maintenance_mode ? 'checked' : '' }}>
                            <span class="form-check-label">{{ lang('admin.sys_settings.maintenance_mode') }}</span>
                        </label>
                    </div>
                    <div class="mb-3">
                        <input type="hidden" name="enable_timeline" value="0">
                        <label class="form-check form-switch">
                            <input type="checkbox" name="enable_timeline" value="1" class="form-check-input" {{ s.enable_timeline ? 'checked' : '' }}>
                            <span class="form-check-label">{{ lang('admin.sys_settings.enable_timeline') }}</span>
                        </label>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">{{ lang('admin.sys_settings.timeline_title') }}</label>
                            <input type="text" name="timeline_title" class="form-control" value="{{ (s.timeline_title ?? 'Zaman Tüneli')|e }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">{{ lang('admin.sys_settings.timeline_desc') }}</label>
                            <input type="text" name="timeline_description" class="form-control" value="{{ (s.timeline_description ?? '')|e }}">
                        </div>
                    </div>
                    <hr class="my-4">
                    <p class="text-muted small mb-2">{{ lang('admin.sys_settings.user_settings_link') }} <a href="{{ core_url((s.admin_path ?? 'admin') ~ '/user-settings') }}">{{ lang('admin.menu.user_settings') }}</a></p>
                    <hr class="my-4">
                    <h4 class="mb-3">{{ lang('admin.portal.documentation') }}</h4>
                    <div class="mb-3">
                        <input type="hidden" name="documentation_enabled" value="0">
                        <label class="form-check form-switch">
                            <input type="checkbox" name="documentation_enabled" value="1" class="form-check-input" {{ s.documentation_enabled ? 'checked' : '' }}>
                            <span class="form-check-label">{{ lang('admin.portal.documentation_enabled_label') }}</span>
                        </label>
                        <div class="form-text">{{ lang('admin.portal.documentation_hint') }}</div>
                        {% if s.documentation_enabled %}
                        <p class="mt-2 mb-0"><a href="{{ core_url((s.admin_path ?? 'admin') ~ '/documentation-settings') }}" class="btn btn-outline-primary btn-sm">{{ lang('admin.portal.documentation_manage') }}</a></p>
                        {% endif %}
                    </div>
                    <hr class="my-4">
                    <h4 class="mb-3">{{ lang('admin.sys_settings.home_page_type') }}</h4>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.home_page_type') }}</label>
                        <select name="home_page_type" class="form-select" id="home-page-type-select">
                            <option value="forum" {{ homePageType == 'forum' ? 'selected' : '' }}>{{ lang('admin.sys_settings.home_forum') }}</option>
                            <option value="articles" {{ homePageType == 'articles' ? 'selected' : '' }}>{{ lang('admin.sys_settings.home_articles') }}</option>
                            <option value="portal" {{ homePageType == 'portal' ? 'selected' : '' }}>{{ lang('admin.sys_settings.home_portal') }}</option>
                            <option value="custom_url" {{ homePageType == 'custom_url' ? 'selected' : '' }}>{{ lang('admin.sys_settings.home_custom_url') }}</option>
                        </select>
                    </div>
                    <div class="mb-3" id="home-custom-url-wrap" style="{{ homePageType == 'custom_url' ? '' : 'display:none' }}">
                        <label class="form-label">{{ lang('admin.sys_settings.custom_url_label') }}</label>
                        <input type="text" name="home_page_custom_url" class="form-control" value="{{ (s.home_page_custom_url ?? '')|e }}" placeholder="page/kurallar">
                    </div>
                    <hr class="my-4">
                    <h4 class="mb-3">{{ lang('admin.sys_settings.social_media') }}</h4>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Facebook</label>
                            <input type="url" name="social_facebook" class="form-control" value="{{ (s.social_facebook ?? '')|e }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">X (Twitter)</label>
                            <input type="url" name="social_twitter" class="form-control" value="{{ (s.social_twitter ?? '')|e }}">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Instagram</label>
                            <input type="url" name="social_instagram" class="form-control" value="{{ (s.social_instagram ?? '')|e }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">YouTube</label>
                            <input type="url" name="social_youtube" class="form-control" value="{{ (s.social_youtube ?? '')|e }}">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">LinkedIn</label>
                        <input type="url" name="social_linkedin" class="form-control" value="{{ (s.social_linkedin ?? '')|e }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.social_where') }}</label>
                        <div class="d-flex flex-wrap gap-4">
                            <label class="form-check">
                                <input type="hidden" name="social_show_header" value="0">
                                <input type="checkbox" name="social_show_header" value="1" class="form-check-input" {{ s.social_show_header ? 'checked' : '' }}>
                                <span class="form-check-label">Header</span>
                            </label>
                            <label class="form-check">
                                <input type="hidden" name="social_show_footer" value="0">
                                <input type="checkbox" name="social_show_footer" value="1" class="form-check-input" {{ s.social_show_footer ? 'checked' : '' }}>
                                <span class="form-check-label">Footer</span>
                            </label>
                            <label class="form-check">
                                <input type="hidden" name="social_show_sidebar" value="0">
                                <input type="checkbox" name="social_show_sidebar" value="1" class="form-check-input" {{ s.social_show_sidebar ? 'checked' : '' }}>
                                <span class="form-check-label">Sidebar</span>
                            </label>
                        </div>
                    </div>
                    <hr class="my-4">
                    <h4 class="mb-3">{{ lang('admin.sys_settings.error_404') }}</h4>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.error_404_result') }}</label>
                        <div class="form-selectgroup">
                            <label class="form-selectgroup-item">
                                <input type="radio" name="error_404_action" value="page" class="form-selectgroup-input" {{ (s.error_404_action ?? 'page') == 'page' ? 'checked' : '' }}>
                                <span class="form-selectgroup-label">{{ lang('admin.sys_settings.show_404_page') }}</span>
                            </label>
                            <label class="form-selectgroup-item">
                                <input type="radio" name="error_404_action" value="redirect" class="form-selectgroup-input" {{ (s.error_404_action ?? '') == 'redirect' ? 'checked' : '' }}>
                                <span class="form-selectgroup-label">{{ lang('admin.sys_settings.redirect_url') }}</span>
                            </label>
                        </div>
                        <small class="form-hint d-block mt-1">{{ lang('admin.sys_settings.redirect_hint') }}</small>
                    </div>
                    <div class="mb-3" id="error-404-url-wrap">
                        <label class="form-label">{{ lang('admin.sys_settings.redirect_address') }}</label>
                        <input type="text" name="error_404_redirect_url" class="form-control" value="{{ (s.error_404_redirect_url ?? '')|e }}">
                        <small class="form-hint">{{ lang('admin.sys_settings.redirect_hint2') }}</small>
                    </div>
                    <hr class="my-4">
                    <h4 class="mb-3">{{ lang('admin.sys_settings.cron_section') }}</h4>
                    <p class="text-muted small mb-3">
                        {{ lang('admin.sys_settings.cron_intro') }}<br>
                        {{ lang('admin.sys_settings.cron_intro2') }}
                    </p>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.cron_token') }}</label>
                        <div class="input-group">
                            <input type="text" id="cron-token-input" name="cron_token" class="form-control" value="{{ (s.cron_token ?? '')|e }}">
                            <button type="button" class="btn btn-outline-secondary" onclick="document.getElementById('cron-token-input').value = Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 15);">{{ lang('admin.sys_settings.generate_token') }}</button>
                        </div>
                        <small class="form-hint">{{ lang('admin.sys_settings.cron_token_hint') }}</small>
                    </div>
                    {% if cronUrl or cronUrlFull or cronCliExample %}
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.cron_cli_label') }}</label>
                        <p class="form-text text-muted small">{{ lang('admin.sys_settings.cron_cli_hint') }}</p>
                        <div class="input-group mb-2">
                            <span class="input-group-text">{{ lang('admin.sys_settings.cron_cli_php') }}</span>
                            <input type="text" class="form-control font-monospace small" value="{{ cronCliExample|e }}" readonly onclick="this.select();">
                        </div>
                        <p class="form-text text-muted small mb-2">{{ lang('admin.sys_settings.cron_cli_path_hint') }}</p>
                        <label class="form-label mt-2">{{ lang('admin.sys_settings.wget_curl_example') }}</label>
                        <p class="form-text text-muted small">{{ lang('admin.sys_settings.wget_curl_hint') }}</p>
                        {% if cronUrlFull %}
                        <div class="input-group mb-2">
                            <span class="input-group-text">{{ lang('admin.sys_settings.wget_quiet') }}</span>
                            <input type="text" class="form-control font-monospace small" value="wget -q -O - '{{ cronUrlFull|e }}' >/dev/null 2>&1" readonly onclick="this.select();">
                        </div>
                        <div class="input-group">
                            <span class="input-group-text">{{ lang('admin.sys_settings.curl_quiet') }}</span>
                            <input type="text" class="form-control font-monospace small" value="curl -s '{{ cronUrlFull|e }}' >/dev/null 2>&1" readonly onclick="this.select();">
                        </div>
                        {% endif %}
                    </div>
                    {% endif %}
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.admin_path_label') }}</label>
                        <input type="text" class="form-control" value="{{ (s.admin_path ?? 'admin')|e }}" readonly>
                        <small class="form-hint">{{ lang('admin.sys_settings.admin_path_hint') }}</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.composer_binary_path_label') }}</label>
                        <input type="text" name="composer_binary_path" class="form-control font-monospace" value="{{ (s.composer_binary_path ?? '')|e }}" placeholder="C:\laragon\bin\composer\composer.bat">
                        <small class="form-hint">{{ lang('admin.sys_settings.composer_binary_path_hint') }}</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ lang('admin.sys_settings.npx_binary_path_label') }}</label>
                        <input type="text" name="npx_binary_path" class="form-control font-monospace" value="{{ (s.npx_binary_path ?? '')|e }}" placeholder="/usr/bin/npx">
                        <small class="form-hint">{{ lang('admin.sys_settings.npx_binary_path_hint') }}</small>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">{{ lang('admin.common.save') }}</button>
                </div>
            </form>
        </div>
        <script>
        (function(){
            var sel = document.getElementById('home-page-type-select');
            var wrap = document.getElementById('home-custom-url-wrap');
            if (sel && wrap) {
                sel.addEventListener('change', function(){ wrap.style.display = this.value === 'custom_url' ? '' : 'none'; });
            }
            var page = document.querySelector('input[name="error_404_action"][value="page"]');
            var redirect = document.querySelector('input[name="error_404_action"][value="redirect"]');
            var wrap404 = document.getElementById('error-404-url-wrap');
            function toggle404(){ if (wrap404) wrap404.style.display = (redirect && redirect.checked) ? 'block' : 'none'; }
            if (page) page.addEventListener('change', toggle404);
            if (redirect) redirect.addEventListener('change', toggle404);
            toggle404();
        })();
        </script>
{% endif %}

{% if activeTab == 'menu' %}
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-menu-2 me-2"></i>{{ lang('admin.sys_settings.menu_items') }}</h3>
                <p class="text-muted mb-0 mt-1 small">{{ lang('admin.sys_settings.menu_drag_hint')|default('Öğeleri sürükleyip bırakarak sıralayın; bir öğeyi başka bir öğenin altına bırakarak alt menü yapın.') }}</p>
            </div>
            <form action="{{ core_url((s.admin_path ?? 'admin') ~ '/system-settings/update') }}" method="post" id="menu-form">
                {{ core_csrf_field('admin_system_settings')|raw }}
                <input type="hidden" name="tab" value="menu">
                <input type="hidden" name="menu_json" id="menu-json-input" value="">
                <div class="card-body">
                    <ul class="list-unstyled mb-0 menu-sortable-root" id="menu-sortable-root">
                        {% for item in menuItemsTree %}
                        <li class="menu-item-wrap border rounded mb-2 bg-light" data-id="{{ item.id }}">
                            <div class="menu-item-row d-flex flex-wrap align-items-center gap-2 p-2">
                                <span class="drag-handle text-muted cursor-grab" title="{{ lang('admin.sys_settings.menu_order') }}"><i class="ti ti-grip-vertical"></i></span>
                                <input type="text" class="form-control form-control-sm menu-label flex-grow-1" style="min-width: 120px;" value="{{ (item.label ?? '')|e }}" placeholder="{{ lang('admin.sys_settings.menu_title') }}">
                                <input type="text" class="form-control form-control-sm menu-url" style="min-width: 160px;" value="{{ (item.url ?? '')|e }}" placeholder="members veya https://...">
                                <label class="d-flex align-items-center mb-0">
                                    <input type="checkbox" class="form-check-input menu-visible" {{ (item.visible ?? '1') == '1' ? 'checked' : '' }}>
                                    <span class="ms-1 small text-muted">{{ lang('admin.sys_settings.menu_visible') }}</span>
                                </label>
                                <button type="button" class="btn btn-sm btn-outline-primary menu-add-child"><i class="ti ti-plus me-1"></i>{{ lang('admin.sys_settings.menu_add_child')|default('Alt menü') }}</button>
                                <button type="button" class="btn btn-sm btn-ghost-secondary text-danger menu-remove" title="{{ lang('admin.sys_settings.menu_remove') }}"><i class="ti ti-trash"></i></button>
                            </div>
                            <ul class="menu-children list-unstyled ms-4 mb-0 ps-2 border-start border-2 border-primary" style="min-height: 8px;">
                                {% for ch in item.children ?? [] %}
                                <li class="menu-item-wrap border rounded mb-2 mt-2 bg-white" data-id="{{ ch.id }}">
                                    <div class="menu-item-row d-flex flex-wrap align-items-center gap-2 p-2">
                                        <span class="drag-handle text-muted cursor-grab"><i class="ti ti-grip-vertical"></i></span>
                                        <input type="text" class="form-control form-control-sm menu-label flex-grow-1" style="min-width: 100px;" value="{{ (ch.label ?? '')|e }}" placeholder="{{ lang('admin.sys_settings.menu_title') }}">
                                        <input type="text" class="form-control form-control-sm menu-url" style="min-width: 140px;" value="{{ (ch.url ?? '')|e }}" placeholder="URL veya https://...">
                                        <label class="d-flex align-items-center mb-0">
                                            <input type="checkbox" class="form-check-input menu-visible" {{ (ch.visible ?? '1') == '1' ? 'checked' : '' }}>
                                            <span class="ms-1 small text-muted">{{ lang('admin.sys_settings.menu_visible') }}</span>
                                        </label>
                                        <button type="button" class="btn btn-sm btn-ghost-secondary text-danger menu-remove" title="{{ lang('admin.sys_settings.menu_remove') }}"><i class="ti ti-trash"></i></button>
                                    </div>
                                </li>
                                {% endfor %}
                            </ul>
                        </li>
                        {% endfor %}
                        {% if menuItemsTree is empty %}
                        <li class="menu-item-wrap border rounded mb-2 bg-light" data-id="0">
                            <div class="menu-item-row d-flex flex-wrap align-items-center gap-2 p-2">
                                <span class="drag-handle text-muted cursor-grab"><i class="ti ti-grip-vertical"></i></span>
                                <input type="text" class="form-control form-control-sm menu-label flex-grow-1" style="min-width: 120px;" placeholder="{{ lang('admin.sys_settings.menu_title') }}">
                                <input type="text" class="form-control form-control-sm menu-url" style="min-width: 160px;" placeholder="members veya https://...">
                                <label class="d-flex align-items-center mb-0">
                                    <input type="checkbox" class="form-check-input menu-visible" checked>
                                    <span class="ms-1 small text-muted">{{ lang('admin.sys_settings.menu_visible') }}</span>
                                </label>
                                <button type="button" class="btn btn-sm btn-outline-primary menu-add-child"><i class="ti ti-plus me-1"></i>{{ lang('admin.sys_settings.menu_add_child')|default('Alt menü') }}</button>
                                <button type="button" class="btn btn-sm btn-ghost-secondary text-danger menu-remove"><i class="ti ti-trash"></i></button>
                            </div>
                            <ul class="menu-children list-unstyled ms-4 mb-0 ps-2 border-start border-2 border-primary" style="min-height: 8px;"></ul>
                        </li>
                        {% endif %}
                    </ul>
                    <button type="button" class="btn btn-outline-primary btn-sm mt-2" id="menu-add-root"><i class="ti ti-plus me-1"></i> {{ lang('admin.sys_settings.menu_add_item') }}</button>
                    <hr class="my-4">
                    <h4 class="mb-3"><i class="ti ti-layout-bottombar me-2"></i>{{ lang('admin.sys_settings.footer_menu_items') }}</h4>
                    <div class="table-responsive">
                        <table class="table table-vcenter table-sm table-hover" id="footer-menu-table">
                            <thead>
                                <tr>
                                    <th style="width: 32px;" class="text-muted">{{ lang('admin.sys_settings.menu_order') }}</th>
                                    <th>{{ lang('admin.sys_settings.menu_title') }}</th>
                                    <th>{{ lang('admin.sys_settings.menu_url') }}</th>
                                    <th style="width: 70px;" class="text-center">{{ lang('admin.sys_settings.menu_visible') }}</th>
                                    <th style="width: 44px;"></th>
                                </tr>
                            </thead>
                            <tbody id="footer-menu-tbody">
                                {% for it in footerMenuItems %}
                                {% set fvis = (it.visible ?? '1') == '1' %}
                                <tr class="footer-menu-row">
                                    <td class="align-middle"><span class="drag-handle text-muted cursor-grab"><i class="ti ti-grip-vertical"></i></span></td>
                                    <td><input type="text" name="footer_label[]" class="form-control form-control-sm" value="{{ (it.label ?? '')|e }}" placeholder="{{ lang('admin.sys_settings.menu_text_ph') }}"></td>
                                    <td><input type="text" name="footer_url[]" class="form-control form-control-sm" value="{{ (it.url ?? '')|e }}" placeholder="page/kurallar"></td>
                                    <td class="text-center align-middle">
                                        <input type="hidden" name="footer_visible[]" value="{{ fvis ? '1' : '0' }}">
                                        <input type="checkbox" class="form-check-input footer-visible-cb" {{ fvis ? 'checked' : '' }}>
                                    </td>
