                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">{{ lang('admin.common.save') }}</button>
                </div>
            </form>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
        <script>
        (function() {
            var form = document.getElementById('menu-form');
            var rootEl = document.getElementById('menu-sortable-root');
            var jsonInput = document.getElementById('menu-json-input');
            if (!form || !rootEl || !jsonInput) return;

            function nextId() {
                var max = 0;
                rootEl.querySelectorAll('.menu-item-wrap[data-id]').forEach(function(li) {
                    var id = parseInt(li.getAttribute('data-id'), 10);
                    if (!isNaN(id) && id >= 0) max = Math.max(max, id);
                });
                return max + 1;
            }

            function serializeMenu() {
                var flat = [];
                var order = 0;
                function walk(ul, parentId) {
                    if (!ul) return;
                    var items = ul.querySelectorAll(':scope > .menu-item-wrap');
                    items.forEach(function(li) {
                        var label = (li.querySelector('.menu-label') && li.querySelector('.menu-label').value) || '';
                        if (label.trim() === '') return;
                        var url = (li.querySelector('.menu-url') && li.querySelector('.menu-url').value) || '';
                        var vis = (li.querySelector('.menu-visible') && li.querySelector('.menu-visible').checked);
                        var id = parseInt(li.getAttribute('data-id'), 10);
                        if (isNaN(id)) id = order;
                        flat.push({ id: id, label: label.trim(), url: url.trim(), visible: vis ? '1' : '0', parent_id: parentId || 0, order: order });
                        order++;
                        var childUl = li.querySelector(':scope > .menu-children');
                        if (childUl) walk(childUl, id);
                    });
                }
                walk(rootEl, 0);
                return flat;
            }

            form.addEventListener('submit', function() {
                jsonInput.value = JSON.stringify(serializeMenu());
            });

            rootEl.addEventListener('click', function(e) {
                var removeBtn = e.target.closest('.menu-remove');
                if (removeBtn) {
                    var wrap = removeBtn.closest('.menu-item-wrap');
                    if (wrap && rootEl.querySelectorAll('.menu-item-wrap').length > 1) wrap.remove();
                    return;
                }
                var addChildBtn = e.target.closest('.menu-add-child');
                if (addChildBtn) {
                    var wrap = addChildBtn.closest('.menu-item-wrap');
                    if (!wrap) return;
                    var childUl = wrap.querySelector(':scope > .menu-children');
                    if (!childUl) return;
                    var id = nextId();
                    var visibleLabel = {{ lang('admin.sys_settings.menu_visible')|json_encode|raw }};
                    var removeTitle = {{ lang('admin.sys_settings.menu_remove')|json_encode|raw }};
                    var titlePh = {{ lang('admin.sys_settings.menu_text_ph')|json_encode|raw }};
                    var li = document.createElement('li');
                    li.className = 'menu-item-wrap border rounded mb-2 mt-2 bg-white';
                    li.setAttribute('data-id', String(id));
                    li.innerHTML = '<div class="menu-item-row d-flex flex-wrap align-items-center gap-2 p-2">' +
                        '<span class="drag-handle text-muted cursor-grab"><i class="ti ti-grip-vertical"></i></span>' +
                        '<input type="text" class="form-control form-control-sm menu-label flex-grow-1" style="min-width: 100px;" placeholder="' + titlePh + '">' +
                        '<input type="text" class="form-control form-control-sm menu-url" style="min-width: 140px;" placeholder="URL veya https://...">' +
                        '<label class="d-flex align-items-center mb-0"><input type="checkbox" class="form-check-input menu-visible" checked><span class="ms-1 small text-muted">' + visibleLabel + '</span></label>' +
                        '<button type="button" class="btn btn-sm btn-ghost-secondary text-danger menu-remove" title="' + removeTitle + '"><i class="ti ti-trash"></i></button></div>';
                    childUl.appendChild(li);
                    if (typeof Sortable !== 'undefined' && childUl._sortable === undefined) {
                        childUl._sortable = new Sortable(childUl, { group: 'menu-items', handle: '.drag-handle', animation: 150, draggable: '.menu-item-wrap' });
                    }
                }
            });

            document.getElementById('menu-add-root')?.addEventListener('click', function() {
                var id = nextId();
                var visibleLabel = {{ lang('admin.sys_settings.menu_visible')|json_encode|raw }};
                var removeTitle = {{ lang('admin.sys_settings.menu_remove')|json_encode|raw }};
                var titlePh = {{ lang('admin.sys_settings.menu_text_ph')|json_encode|raw }};
                var li = document.createElement('li');
                li.className = 'menu-item-wrap border rounded mb-2 bg-light';
                li.setAttribute('data-id', String(id));
                li.innerHTML = '<div class="menu-item-row d-flex flex-wrap align-items-center gap-2 p-2">' +
                    '<span class="drag-handle text-muted cursor-grab"><i class="ti ti-grip-vertical"></i></span>' +
                    '<input type="text" class="form-control form-control-sm menu-label flex-grow-1" style="min-width: 120px;" placeholder="' + titlePh + '">' +
                    '<input type="text" class="form-control form-control-sm menu-url" style="min-width: 160px;" placeholder="members veya https://...">' +
                    '<label class="d-flex align-items-center mb-0"><input type="checkbox" class="form-check-input menu-visible" checked><span class="ms-1 small text-muted">' + visibleLabel + '</span></label>' +
                    '<button type="button" class="btn btn-sm btn-outline-primary menu-add-child"><i class="ti ti-plus me-1"></i>Alt menü</button>' +
                    '<button type="button" class="btn btn-sm btn-ghost-secondary text-danger menu-remove" title="' + removeTitle + '"><i class="ti ti-trash"></i></button></div>' +
                    '<ul class="menu-children list-unstyled ms-4 mb-0 ps-2 border-start border-2 border-primary" style="min-height: 8px;"></ul>';
                rootEl.appendChild(li);
            });

            if (typeof Sortable !== 'undefined') {
                new Sortable(rootEl, { group: 'menu-items', handle: '.drag-handle', animation: 150, draggable: '.menu-item-wrap' });
                rootEl.querySelectorAll('.menu-children').forEach(function(ul) {
                    ul._sortable = new Sortable(ul, { group: 'menu-items', handle: '.drag-handle', animation: 150, draggable: '.menu-item-wrap' });
                });
            }
            var footerTbody = document.getElementById('footer-menu-tbody');
            var menuPh = {{ lang('admin.sys_settings.menu_text_ph')|json_encode|raw }};
            if (footerTbody && form) {
                form.addEventListener('submit', function() {
                    footerTbody.querySelectorAll('.footer-visible-cb').forEach(function(cb, i) {
                        var h = footerTbody.querySelectorAll('input[name="footer_visible[]"]')[i];
                        if (h) h.value = cb.checked ? '1' : '0';
                    });
                });
                footerTbody.addEventListener('click', function(e) {
                    var btn = e.target.closest('.btn-footer-remove-row');
                    if (btn) {
                        var row = btn.closest('tr');
                        if (footerTbody.querySelectorAll('tr.footer-menu-row').length > 1) row.remove();
                    }
                });
                document.getElementById('footer-menu-add-row')?.addEventListener('click', function() {
                    var tr = document.createElement('tr');
                    tr.className = 'footer-menu-row';
                    tr.innerHTML = '<td class="align-middle"><span class="drag-handle text-muted cursor-grab"><i class="ti ti-grip-vertical"></i></span></td><td><input type="text" name="footer_label[]" class="form-control form-control-sm" placeholder="' + menuPh + '"></td><td><input type="text" name="footer_url[]" class="form-control form-control-sm" placeholder="page/kurallar"></td><td class="text-center align-middle"><input type="hidden" name="footer_visible[]" value="1"><input type="checkbox" class="form-check-input footer-visible-cb" checked></td><td><button type="button" class="btn btn-sm btn-ghost-secondary text-danger btn-footer-remove-row"><i class="ti ti-trash"></i></button></td>';
                    footerTbody.appendChild(tr);
                });
                new Sortable(footerTbody, { handle: '.drag-handle', animation: 150, draggable: 'tr.footer-menu-row' });
            }
            var quickTbody = document.getElementById('quick-links-tbody');
            if (quickTbody && form) {
                form.addEventListener('submit', function() {
                    quickTbody.querySelectorAll('.quick-visible-cb').forEach(function(cb, i) {
                        var h = quickTbody.querySelectorAll('input[name="quick_visible[]"]')[i];
                        if (h) h.value = cb.checked ? '1' : '0';
                    });
                });
                quickTbody.addEventListener('click', function(e) {
                    var btn = e.target.closest('.btn-quick-remove-row');
                    if (btn) {
                        var row = btn.closest('tr');
                        if (quickTbody.querySelectorAll('tr.quick-link-row').length > 1) row.remove();
                    }
                });
                document.getElementById('quick-links-add-row')?.addEventListener('click', function() {
                    var tr = document.createElement('tr');
                    tr.className = 'quick-link-row';
                    tr.innerHTML = '<td class="align-middle"><span class="drag-handle text-muted cursor-grab"><i class="ti ti-grip-vertical"></i></span></td><td><input type="text" name="quick_label[]" class="form-control form-control-sm" placeholder="' + menuPh + '"></td><td><input type="text" name="quick_url[]" class="form-control form-control-sm" placeholder="forum"></td><td><input type="text" name="quick_icon[]" class="form-control form-control-sm" placeholder="fa-solid fa-house"></td><td class="text-center align-middle"><input type="hidden" name="quick_visible[]" value="1"><input type="checkbox" class="form-check-input quick-visible-cb" checked></td><td><button type="button" class="btn btn-sm btn-ghost-secondary text-danger btn-quick-remove-row"><i class="ti ti-trash"></i></button></td>';
                    quickTbody.appendChild(tr);
                });
                new Sortable(quickTbody, { handle: '.drag-handle', animation: 150, draggable: 'tr.quick-link-row' });
            }
        })();
        </script>
{% endif %}

