{% extends 'base.html.twig' %}
{% set language = language ?? null %}
{% set translationRows = translationRows ?? [] %}
{% block content %}
<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <div class="page-pretitle"><a href="{{ core_url(adminPath ~ '/languages') }}">{{ lang('admin.languages.title')|e }}</a></div>
                <h2 class="page-title">{{ lang('admin.languages.edit_translations')|e }} — {{ (language.native_name ?? '')|e }} ({{ (language.code ?? '')|e }})</h2>
            </div>
            <div class="col-auto">
                <a href="{{ core_url(adminPath ~ '/languages/export/' ~ (language.code ?? '')|e('url')) }}" class="btn btn-outline-secondary"><i class="ti ti-download me-1"></i> {{ lang('admin.languages.export')|e }}</a>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        {% if flash('success') %}
        <div class="alert alert-success alert-dismissible" role="alert">
            <div class="d-flex"><i class="ti ti-check me-2"></i><div>{{ flash('success')|e }}</div></div>
            <a class="btn-close" data-bs-dismiss="alert" aria-label="Close"></a>
        </div>
        {% endif %}
        {% if flash('error') %}
        <div class="alert alert-danger alert-dismissible" role="alert">
            <div class="d-flex"><i class="ti ti-alert-circle me-2"></i><div>{{ flash('error')|e }}</div></div>
            <a class="btn-close" data-bs-dismiss="alert" aria-label="Close"></a>
        </div>
        {% endif %}

        <form action="{{ core_url(adminPath ~ '/languages/update/' ~ (language.code ?? '')|e('url')) }}" method="post" id="translationForm">
            {{ core_csrf_field()|raw }}

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">{{ lang('admin.languages.translations')|e }}</h3>
                    <div class="card-actions d-flex gap-2 align-items-center">
                        <div class="btn-group" id="groupFilter">
                            <button type="button" class="btn btn-sm btn-outline-primary active" data-filter="all">{{ lang('admin.languages.filter_all') }}</button>
                            <button type="button" class="btn btn-sm btn-outline-primary" data-filter="frontend">{{ lang('admin.languages.filter_frontend') }}</button>
                            <button type="button" class="btn btn-sm btn-outline-primary" data-filter="admin">{{ lang('admin.languages.filter_admin') }}</button>
                        </div>
                        <div class="input-icon">
                            <span class="input-icon-addon"><i class="ti ti-search"></i></span>
                            <input type="text" class="form-control" id="searchInput" placeholder="{{ lang('admin.languages.search_keys')|e }}" style="width:260px">
                        </div>
                    </div>
                </div>
                <div class="table-responsive" style="max-height: 70vh; overflow-y: auto;">
                    <table class="table table-vcenter card-table table-striped" id="translationTable">
                        <thead style="position: sticky; top: 0; background: white; z-index: 10;">
                            <tr>
                                <th style="width:320px">{{ lang('admin.languages.translation_key')|e }}</th>
                                <th style="width:40%">{{ lang('admin.languages.translation_value')|e }}</th>
                                <th style="width:35%">{{ lang('admin.languages.default_column') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in translationRows %}
                            {% set group = (row.key|slice(0, 6)) == 'admin.' ? 'admin' : 'frontend' %}
                            <tr data-key="{{ row.key|e('html_attr') }}" data-group="{{ group }}">
                                <td><code style="font-size: 11.5px; word-break: break-all;">{{ row.key|e }}</code></td>
                                <td>
                                    <input type="text" name="translations[{{ row.key|e('html_attr') }}]" value="{{ row.value|e('html_attr') }}" data-original="{{ row.value|e('html_attr') }}" class="form-control form-control-sm" placeholder="{{ row.default|e('html_attr') }}">
                                </td>
                                <td><span class="text-muted" style="font-size: 12px;">{{ row.default|e }}</span></td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <span class="text-muted" style="font-size: 12px;">
                        {{ lang('admin.languages.total_prefix') }} <strong id="totalCount">{{ translationRows|length }}</strong> {{ lang('admin.languages.total_suffix') }}
                        <span id="filteredCount" class="d-none"> · {{ lang('admin.languages.showing_prefix') }} <strong id="filteredNum">0</strong></span>
                    </span>
                    <button type="submit" class="btn btn-primary"><i class="ti ti-device-floppy me-1"></i> {{ lang('admin.languages.save_translations')|e }}</button>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}
{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var searchInput = document.getElementById('searchInput');
    var table = document.getElementById('translationTable');
    if (!table) return;
    var rows = table.querySelectorAll('tbody tr');
    var filteredCount = document.getElementById('filteredCount');
    var filteredNum = document.getElementById('filteredNum');
    var groupBtns = document.querySelectorAll('#groupFilter button');
    var activeGroup = 'all';

    function applyFilters() {
        var query = (searchInput && searchInput.value || '').toLowerCase().trim();
        var visible = 0;
        for (var i = 0; i < rows.length; i++) {
            var row = rows[i];
            var key = (row.getAttribute('data-key') || '').toLowerCase();
            var group = row.getAttribute('data-group') || '';
            var inp = row.querySelector('input');
            var value = (inp ? inp.value : '').toLowerCase();
            var defaultEl = row.querySelector('.text-muted');
            var defaultVal = (defaultEl ? defaultEl.textContent : '').toLowerCase();
            var matchGroup = (activeGroup === 'all' || group === activeGroup);
            var matchSearch = (query === '' || key.indexOf(query) !== -1 || value.indexOf(query) !== -1 || defaultVal.indexOf(query) !== -1);
            if (matchGroup && matchSearch) {
                row.style.display = '';
                visible++;
            } else {
                row.style.display = 'none';
            }
        }
        if (filteredCount && filteredNum) {
            if (query !== '' || activeGroup !== 'all') {
                filteredCount.classList.remove('d-none');
                filteredNum.textContent = visible;
            } else {
                filteredCount.classList.add('d-none');
            }
        }
    }

    if (searchInput) searchInput.addEventListener('input', applyFilters);
    if (groupBtns.length) {
        for (var j = 0; j < groupBtns.length; j++) {
            groupBtns[j].addEventListener('click', function() {
                for (var k = 0; k < groupBtns.length; k++) groupBtns[k].classList.remove('active');
                this.classList.add('active');
                activeGroup = this.getAttribute('data-filter');
                applyFilters();
            });
        }
    }

    var form = document.getElementById('translationForm');
    if (form) {
        form.addEventListener('submit', function () {
            var inputs = form.querySelectorAll('input[name^="translations["]');
            var changed = 0;
            for (var i = 0; i < inputs.length; i++) {
                var input = inputs[i];
                var original = input.getAttribute('data-original');
                if ((input.value || '') === (original || '')) {
                    input.disabled = true;
                } else {
                    input.disabled = false;
                    changed++;
                }
            }

            // If nothing changed, keep one harmless field enabled
            // so the backend receives translations as an array.
            if (changed === 0 && inputs.length > 0) {
                inputs[0].disabled = false;
            }
        });
    }
});
</script>
{% endblock %}
