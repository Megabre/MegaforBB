{% extends 'base.html.twig' %}
{% set settings = settings ?? [] %}
{% block content %}
<div class="page-header d-print-none">
    <div class="container-lg">
        <div class="row g-2 align-items-center">
            <div class="col">
                <div class="page-pretitle">{{ lang('admin.common.settings') }}</div>
                <h2 class="page-title">{{ lang('admin.topic_post.title') }}</h2>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-lg">
        <form action="{{ core_url(adminPath ~ '/topic-post-settings/update') }}" method="post">
            {{ core_csrf_field('admin_topic_post_settings')|raw }}
            <div class="row row-cards">
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-ruler-2 me-2 text-blue"></i>{{ lang('admin.topic_post.content_limits') }}</h3>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">{{ lang('admin.topic_post.max_post_length_label') }}</label>
                                <input type="number" name="max_post_length" class="form-control" value="{{ settings.max_post_length ?? 0 }}" min="0">
                                <span class="form-hint">{{ lang('admin.topic_post.max_post_length_hint') }}</span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">{{ lang('admin.topic_post.max_topic_title_label') }}</label>
                                <input type="number" name="max_topic_title_length" class="form-control" value="{{ settings.max_topic_title_length ?? 200 }}" min="1">
                                <span class="form-hint">{{ lang('admin.topic_post.max_topic_title_hint') }}</span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">{{ lang('admin.topic_post.max_profile_message_label') }}</label>
                                <input type="number" name="max_profile_message_length" class="form-control" value="{{ settings.max_profile_message_length ?? 0 }}" min="0">
                                <span class="form-hint">{{ lang('admin.topic_post.max_profile_message_hint') }}</span>
                            </div>
                            <div class="mb-0">
                                <label class="form-label">{{ lang('admin.topic_post.edit_timeout_label') }}</label>
                                <input type="number" name="edit_timeout_minutes" class="form-control" value="{{ settings.edit_timeout_minutes ?? 0 }}" min="0">
                                <span class="form-hint">{{ lang('admin.topic_post.edit_timeout_hint') }}</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-layout-rows me-2 text-green"></i>{{ lang('admin.topic_post.pagination_section') }}</h3>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label">{{ lang('admin.topic_post.posts_per_page_label') }}</label>
                                    <input type="number" name="posts_per_page" class="form-control" value="{{ settings.posts_per_page ?? 15 }}" min="1" max="100">
                                    <span class="form-hint">{{ lang('admin.topic_post.posts_per_page_hint') }}</span>
                                </div>
                                <div class="col-6">
                                    <label class="form-label">{{ lang('admin.topic_post.topics_per_page_label') }}</label>
                                    <input type="number" name="topics_per_page" class="form-control" value="{{ settings.topics_per_page ?? 20 }}" min="1" max="100">
                                    <span class="form-hint">{{ lang('admin.topic_post.topics_per_page_hint') }}</span>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label">{{ lang('admin.topic_post.min_time_posts_label') }}</label>
                                    <input type="number" name="min_time_between_posts" class="form-control" value="{{ settings.min_time_between_posts ?? 0 }}" min="0">
                                    <span class="form-hint">{{ lang('admin.topic_post.min_time_posts_hint') }}</span>
                                </div>
                                <div class="col-6">
                                    <label class="form-label">{{ lang('admin.topic_post.min_time_topics_label') }}</label>
                                    <input type="number" name="min_time_between_topics" class="form-control" value="{{ settings.min_time_between_topics ?? 0 }}" min="0">
                                    <span class="form-hint">{{ lang('admin.topic_post.min_time_topics_hint') }}</span>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-12">
                                    <label class="form-check form-switch">
                                        <input type="hidden" name="antibump_enabled" value="0">
                                        <input type="checkbox" name="antibump_enabled" value="1" class="form-check-input" {{ settings.antibump_enabled ?? true ? 'checked' : '' }}>
                                        <span class="form-check-label">{{ lang('admin.topic_post.antibump_enabled_label') }}</span>
                                    </label>
                                    <span class="form-hint d-block">{{ lang('admin.topic_post.antibump_enabled_hint') }}</span>
                                </div>
                                <div class="col-6 mt-2">
                                    <label class="form-label">{{ lang('admin.topic_post.antibump_seconds_label') }}</label>
                                    <input type="number" name="antibump_seconds" class="form-control" value="{{ settings.antibump_seconds ?? 60 }}" min="0" max="86400">
                                    <span class="form-hint">{{ lang('admin.topic_post.antibump_seconds_hint') }}</span>
                                </div>
                            </div>
                            <div class="mb-0">
                                <label class="form-label">{{ lang('admin.topic_post.max_poll_options_label') }}</label>
                                <input type="number" name="max_poll_options" class="form-control" value="{{ settings.max_poll_options ?? 10 }}" min="2" max="30">
                                <span class="form-hint">{{ lang('admin.topic_post.max_poll_options_hint') }}</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-eye me-2 text-purple"></i>{{ lang('admin.topic_post.view_features') }}</h3>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-check form-switch">
                                            <input type="hidden" name="lightbox_all_images_enabled" value="0">
                                            <input type="checkbox" name="lightbox_all_images_enabled" value="1" class="form-check-input" {{ settings.lightbox_all_images_enabled ? 'checked' : '' }}>
                                            <span class="form-check-label">{{ lang('admin.topic_post.lightbox_label') }}</span>
                                        </label>
                                        <span class="form-hint">{{ lang('admin.topic_post.lightbox_hint') }}</span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-check form-switch">
                                            <input type="hidden" name="show_signatures_to_guests" value="0">
                                            <input type="checkbox" name="show_signatures_to_guests" value="1" class="form-check-input" {{ settings.show_signatures_to_guests ? 'checked' : '' }}>
                                            <span class="form-check-label">{{ lang('admin.topic_post.show_signatures_guests_label') }}</span>
                                        </label>
                                        <span class="form-hint">{{ lang('admin.topic_post.show_signatures_guests_hint') }}</span>
                                    </div>
                                </div>
                                <div class="col-md-12 mt-3">
                                    <div class="mb-3 pb-3 border-bottom">
                                        <label class="form-check form-switch">
                                            <input type="hidden" name="topic_post_scrubber_enabled" value="0">
                                            <input type="checkbox" name="topic_post_scrubber_enabled" value="1" class="form-check-input"{{ (settings.topic_post_scrubber_enabled is defined ? settings.topic_post_scrubber_enabled : true) ? ' checked' : '' }}>
                                            <span class="form-check-label">{{ lang('admin.topic_post.scrubber_enabled_label') }}</span>
                                        </label>
                                        <span class="form-hint d-block">{{ lang('admin.topic_post.scrubber_enabled_hint') }}</span>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">{{ lang('admin.topic_post.post_editor_label') }}</label>
                                        <select name="post_editor" class="form-select">
                                            <option value="toast_ui" {{ (settings.post_editor ?? 'toast_ui') == 'toast_ui' ? 'selected' : '' }}>{{ lang('admin.topic_post.post_editor_toast_ui') }}</option>
                                            <option value="tinymce" {{ (settings.post_editor ?? '') == 'tinymce' ? 'selected' : '' }}>{{ lang('admin.topic_post.post_editor_tinymce') }}</option>
                                            <option value="ckeditor" {{ (settings.post_editor ?? '') == 'ckeditor' ? 'selected' : '' }}>{{ lang('admin.topic_post.post_editor_ckeditor') }}</option>
                                        </select>
                                        <span class="form-hint">{{ lang('admin.topic_post.post_editor_hint') }}</span>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-check form-switch">
                                            <input type="hidden" name="hide_content_from_guests" value="0">
                                            <input type="checkbox" name="hide_content_from_guests" value="1" class="form-check-input" {{ settings.hide_content_from_guests ? 'checked' : '' }}>
                                            <span class="form-check-label text-red">{{ lang('admin.topic_post.hide_secret_label') }}</span>
                                        </label>
                                        <span class="form-hint">{{ lang('admin.topic_post.hide_secret_hint') }}</span>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-check form-switch">
                                            <input type="hidden" name="enable_inline_quotes" value="0">
                                            <input type="checkbox" name="enable_inline_quotes" value="1" class="form-check-input" {{ settings.enable_inline_quotes ?? true ? 'checked' : '' }}>
                                            <span class="form-check-label">Satıriçi Alıntı Tasarımı (Nested Replies)</span>
                                        </label>
                                        <span class="form-hint">Yorumlara direkt cevap yazıldığında alıntı formatında iç içe mesaj görünümünü aktif eder.</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="card">
                        <div class="card-body d-flex align-items-center justify-content-between">
                            <div class="text-muted">
                                <i class="ti ti-info-circle me-1"></i>{{ lang('admin.topic_post.anti_bump_note', { link: '<a href="' ~ core_url(adminPath ~ '/security') ~ '">' ~ lang('admin.topic_post.security_link_text') ~ '</a>' })|raw }}
                            </div>
                            <div>
                                <a href="{{ core_url(adminPath) }}" class="btn me-2">{{ lang('admin.common.cancel') }}</a>
                                <button type="submit" class="btn btn-primary"><i class="ti ti-device-floppy me-1"></i>{{ lang('admin.common.save') }}</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}
