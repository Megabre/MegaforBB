{% if attachments is defined and attachments is not empty %}
{% set currentUser = user ?? null %}
{% set isStaff = isStaff ?? false %}
<div class="mt-3 pt-3 border-t border-gray-200">
  <div class="flex flex-wrap gap-2">
    {% for att in attachments %}
    <div class="inline-flex items-center gap-2 px-3 py-2 bg-slate-50 border border-gray-200 rounded-md text-sm">
      <i class="fa {{ attachment_icon(att.mime_type ?? '', att.original_name ?? '') }} text-slate-500"></i>
      <div class="min-w-0">
        <a href="{{ core_url('attachment/' ~ att.id ~ '/download') }}" class="font-medium text-[#105289] hover:text-blue-600 hover:underline truncate max-w-[180px] block" title="{{ core_e(att.original_name ?? '') }}">
          {{ core_e(att.original_name ?? '') }}
        </a>
        <span class="text-xs text-slate-500">
          {{ attachment_format_size(att.file_size ?? 0) }}
          {% if (att.download_count ?? 0) > 0 %} · <i class="fa-solid fa-download mr-0.5"></i>{{ att.download_count }}{% endif %}
        </span>
      </div>
      {% set canDelete = currentUser and ((att.user_id ?? 0) == currentUser.id or isStaff) %}
      {% if canDelete %}
      <form action="{{ core_url('attachment/' ~ att.id ~ '/delete') }}" method="post" class="inline attachment-delete-form" data-attachment-id="{{ att.id }}">
        {{ core_csrf_field('attachment_delete')|raw }}
        <button type="submit" class="p-1 text-slate-400 hover:text-red-600 rounded" title="Sil"><i class="fa-solid fa-trash-can text-xs"></i></button>
      </form>
      {% endif %}
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}
