  <script>window.MEGAFORBB_AJAX_ENABLED = {{ (ajax_enabled|default(true)) ? 'true' : 'false' }}; window.MEGAFORBB_EDITOR = {{ (editor_type|default('toast_ui')) == 'tinymce' ? '"tinymce"' : ((editor_type|default('toast_ui')) == 'ckeditor' ? '"ckeditor"' : '"toast_ui"') }};</script>
  {% if editor_type|default('toast_ui') == 'tinymce' %}
  <script src="{{ core_url('ui-vendor/tinymce/tinymce.min.js') }}"></script>
  <script>
    (function() {
      document.querySelectorAll('textarea[data-editor][data-initial-base64]').forEach(function(ta) {
        var raw = ta.getAttribute('data-initial-base64');
        if (!raw) return;
        try {
          var bstr = atob(raw);
          if (bstr) {
            var decoded = decodeURIComponent(bstr.split('').map(function(c) { return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2); }).join(''));
            if (typeof decoded === 'string') ta.value = decoded;
          }
        } catch (e) {
          try { ta.value = atob(raw) || ''; } catch (e2) {}
        }
      });
      var base = {{ core_url('ui-vendor/tinymce')|json_encode|raw }};
      var uploadUrl = window.MEGAFORBB_UPLOAD_URL || {{ base_url('upload/image')|json_encode|raw }};
      var baseUrl = (window.MEGAFORBB_BASE_URL || '').replace(/\/$/, '');
      function getMediaEmbedHtml(url) {
        if (!url || typeof url !== 'string') return '';
        url = url.trim();
        var yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
        if (yt) return '<div class="mfbb-media-embed ratio ratio-16x9"><iframe src="https://www.youtube.com/embed/' + yt[1] + '" allowfullscreen loading="lazy"></iframe></div>';
        var dm = url.match(/dailymotion\.com\/(?:video\/|embed\/video\/)([a-zA-Z0-9]+)/);
        if (dm) return '<div class="mfbb-media-embed ratio ratio-16x9"><iframe src="https://www.dailymotion.com/embed/video/' + dm[1] + '" allowfullscreen loading="lazy"></iframe></div>';
        return '';
      }
      if (typeof tinymce !== 'undefined') {
        tinymce.init({
          license_key: 'gpl',
          promotion: false,
          sandbox_iframes: false,
          base_url: base,
          selector: 'textarea[data-editor]',
          height: 320,
          min_height: 200,
          valid_elements: '*[*]',
          relative_urls: false,
          entity_encoding: 'raw',
          remove_script_host: false,
          menubar: 'file insert format table help',
          plugins: 'advlist autolink lists link image charmap preview searchreplace visualblocks code codesample fullscreen insertdatetime media table',
          toolbar: 'fullscreen code preview | undo redo | bold italic underline strikethrough | alignleft aligncenter alignright alignjustify | numlist bullist | forecolor backcolor removeformat | image media link | mfbb_spoiler mfbb_secret mfbb_emoji mfbb_media',
          content_css: [ base + '/editor_content.css' ],
          language: {{ (locale|default('tr')) == 'en' ? '"en"' : '"tr"' }},
          mobile: { menubar: 'file insert format table help' },
          images_upload_handler: function(blobInfo, progress) {
            return new Promise(function(resolve, reject) {
              var fd = new FormData();
              fd.append('file', blobInfo.blob(), blobInfo.filename());
              var url = uploadUrl.indexOf('http') === 0 ? uploadUrl : (window.location.origin + (uploadUrl.charAt(0) === '/' ? uploadUrl : '/' + uploadUrl));
              var xhr = new XMLHttpRequest();
              xhr.open('POST', url);
              xhr.withCredentials = true;
              xhr.onload = function() {
                try {
                  var d = JSON.parse(xhr.responseText);
                  if (d && d.url) resolve(d.url); else reject(new Error(d && d.error && d.error.message ? d.error.message : 'Upload failed'));
                } catch (e) { reject(e); }
              };
              xhr.onerror = function() { reject(new Error('Upload failed')); };
              xhr.send(fd);
            });
          },
          setup: function(editor) {
            var lang = window.MEGAFORBB_EDITOR_LANG || {};
            var spoilerPh = lang.spoiler_placeholder || 'Spoiler içeriği';
            var secretPh = lang.spoiler_placeholder || 'Gizli İçerik';
            editor.ui.registry.addButton('mfbb_spoiler', { text: '👁', tooltip: lang.spoiler_tooltip || 'Spoiler', onAction: function() {
              var sel = editor.selection.getContent({ format: 'text' }) || spoilerPh;
              editor.insertContent('<details class="mfbb-spoiler"><summary>Spoiler</summary>' + (sel || spoilerPh) + '</details>');
            }});
            editor.ui.registry.addButton('mfbb_secret', { text: '🔒', tooltip: 'Misafire gizli içerik', onAction: function() {
              var sel = editor.selection.getContent({ format: 'text' }) || secretPh;
              editor.insertContent('[secret]' + (sel || secretPh) + '[/secret]');
            }});
            editor.ui.registry.addButton('mfbb_media', { text: '▶', tooltip: lang.media_embed || 'Video ekle', onAction: function() {
              var url = window.prompt(lang.media_url_placeholder || 'YouTube veya Dailymotion URL', 'https://');
              var html = getMediaEmbedHtml(url);
              if (html) editor.insertContent(html);
            }});
            editor.ui.registry.addButton('mfbb_emoji', { text: '🙂', tooltip: 'Emoji / Smiley', onAction: function() {
              var win = editor.windowManager.open({ title: 'Emoji', width: 340, height: 300, body: { type: 'panel', items: [{ type: 'htmlpanel', html: '<div id="mfbb-tinymce-smileys" style="padding:8px;min-height:200px;"></div>' }] }, buttons: [{ type: 'cancel', text: 'Kapat' }] });
              var container = document.getElementById('mfbb-tinymce-smileys');
              if (container) {
                var apiUrl = baseUrl + '/api/smileys';
                function insertSmileyCode(code) {
                  if (!code) return;
                  var esc = document.createElement('div');
                  esc.textContent = code;
                  editor.insertContent(esc.innerHTML);
                }
                fetch(apiUrl).then(function(r) { return r.json(); }).then(function(data) {
                  container.innerHTML = '';
                  if (data.unicode && data.unicode.length) {
                    var g = document.createElement('div'); g.style.cssText = 'display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px;';
                    data.unicode.slice(0, 80).forEach(function(item) {
                      var btn = document.createElement('button'); btn.type = 'button'; btn.textContent = item.char || item.unicode_char || ''; btn.style.cssText = 'font-size:18px;padding:4px;border:1px solid #ddd;border-radius:4px;cursor:pointer;background:#fff;';
                      btn.onclick = function() { editor.insertContent(btn.textContent); };
                      g.appendChild(btn);
                    });
                    container.appendChild(g);
                  }
                  if (data.gifs && data.gifs.length) {
                    var g2 = document.createElement('div'); g2.style.cssText = 'display:flex;flex-wrap:wrap;gap:4px;';
                    data.gifs.slice(0, 24).forEach(function(item) {
                      var url = item.image_url || item.url || '';
                      var btn = document.createElement('button'); btn.type = 'button'; btn.style.cssText = 'padding:2px;border:1px solid #ddd;border-radius:4px;cursor:pointer;background:#fff;';
                      if (url) { var img = document.createElement('img'); img.src = url; img.style.cssText = 'width:24px;height:24px;'; btn.appendChild(img); }
                      btn.onclick = function() { insertSmileyCode((item.code || '').trim()); };
                      g2.appendChild(btn);
                    });
                    container.appendChild(g2);
                  }
                }).catch(function() { container.innerHTML = '<p>Yüklenemedi.</p>'; });
              }
            }});
          },
          init_instance_callback: function(ed) {
            var el = ed.getElement();
            if (el && el.nodeName === 'TEXTAREA') { el.removeAttribute('required'); }
          }
        });
      }
    })();
  </script>
