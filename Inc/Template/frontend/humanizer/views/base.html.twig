  <script>window.MEGAFORBB_EDITOR_LANG = { underline: {{ core__('editor.underline')|json_encode|raw }}, highlight: {{ core__('editor.highlight')|json_encode|raw }}, superscript: {{ core__('editor.superscript')|json_encode|raw }}, subscript: {{ core__('editor.subscript')|json_encode|raw }}, spoiler_tooltip: {{ core__('editor.spoiler_tooltip')|json_encode|raw }}, spoiler_placeholder: {{ core__('editor.spoiler_placeholder')|json_encode|raw }}, text_color: {{ core__('editor.text_color')|json_encode|raw }}, background_color: {{ core__('editor.background_color')|json_encode|raw }}, align_left: {{ core__('editor.align_left')|json_encode|raw }}, align_center: {{ core__('editor.align_center')|json_encode|raw }}, align_right: {{ core__('editor.align_right')|json_encode|raw }}, align_justify: {{ core__('editor.align_justify')|json_encode|raw }}, format_menu: {{ core__('editor.format_menu')|json_encode|raw }}, mention_choose_user: {{ core__('editor.mention_choose_user')|json_encode|raw }}, mention_no_users: {{ core__('editor.mention_no_users')|json_encode|raw }}, media_embed: {{ core__('editor.media_embed')|json_encode|raw }}, media_url_placeholder: {{ core__('editor.media_url_placeholder')|json_encode|raw }} };</script>
  {% if lightbox_all_images_enabled|default(true) %}
  <div id="mfbb-lightbox" class="fixed inset-0 z-[9998] hidden bg-black/80 backdrop-blur-sm items-center justify-center cursor-zoom-out" onclick="this.classList.add('hidden');this.classList.remove('flex')">
    <img id="mfbb-lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[90vh] rounded-lg shadow-2xl object-contain">
    <button onclick="event.stopPropagation();this.parentElement.classList.add('hidden');this.parentElement.classList.remove('flex')" class="absolute top-4 right-4 w-10 h-10 bg-white/20 hover:bg-white/40 rounded-full text-white text-xl flex items-center justify-center">&times;</button>
  </div>
  {% endif %}
  {% include 'partials/frontend_js_lang.html.twig' %}
  <script src="{{ core_url('js/main.js') }}?v={{ core_config('app.version', '1.0.0') }}"></script>
  <script src="{{ theme_asset_url('js/theme.js') }}?v={{ 'now'|date('U') }}"></script>
  {% if custom_js is not empty %}
  <script>
    {{ custom_js|raw }}
  </script>
  {% endif %}
  {% if footer_extra is defined and footer_extra is not empty %}{{ footer_extra|raw }}{% endif %}
