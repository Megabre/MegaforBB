{% set currentUser = user ?? null %}
{% set navItems = top_menu_items ?? [] %}
{% if navItems is empty %}
  {% set portalEnabled = portal_enabled ?? false %}
  {% set membersEnabled = members_list_enabled ?? true %}
  {% set documentationEnabled = documentation_enabled ?? false %}
  {% if portalEnabled %}
    {% set navItems = [
      { label: core__('common.home'), href: core_url(''), children: [] },
      { label: core__('common.forum'), href: core_url('forum'), children: [] },
      { label: core__('article.articles'), href: core_url('articles'), children: [] },
      { label: core__('documentation.title'), href: core_url('documentation'), children: [] },
      { label: core__('common.members'), href: core_url('members'), children: [] },
      { label: core__('common.rules'), href: core_url('page/kurallar'), children: [] },
      { label: core__('common.new_posts'), href: core_url('') ~ '#latest', children: [] }
    ] %}
  {% else %}
    {% set navItems = [
      { label: core__('common.forum'), href: core_url(''), children: [] },
      { label: core__('article.articles'), href: core_url('articles'), children: [] },
      { label: core__('documentation.title'), href: core_url('documentation'), children: [] },
      { label: core__('common.members'), href: core_url('members'), children: [] },
      { label: core__('common.rules'), href: core_url('page/kurallar'), children: [] },
      { label: core__('common.new_posts'), href: core_url('') ~ '#latest', children: [] }
    ] %}
  {% endif %}
  {% if not documentationEnabled %}
    {% set navItems = navItems|filter(n => (n.href ?? '') != core_url('documentation')) %}
  {% endif %}
  {% if not membersEnabled %}
    {% set navItems = navItems|filter(n => (n.href ?? '') != core_url('members')) %}
  {% endif %}
{% endif %}
<!DOCTYPE html>
<html lang="{{ core_e(locale ?? core_config('app.locale', 'tr')) }}" class="humanizer-theme">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {# SEO & Meta: Admin > Sistem Ayarları > SEO & Meta sekmesinden gelir #}
  {% set currentSiteName = site_name|default(core_config('app.name'))|trim %}
  {% set currentPageTitle = pageTitle|default(currentSiteName)|trim %}
  <title>{% if currentPageTitle == currentSiteName %}{{ core_e(currentSiteName) }}{% else %}{{ core_e(currentPageTitle) }} - {{ core_e(currentSiteName) }}{% endif %}</title>
  {% if forum_favicon_url|default('') is not empty %}<link rel="icon" href="{{ core_e(forum_favicon_url) }}" type="image/x-icon"><link rel="shortcut icon" href="{{ core_e(forum_favicon_url) }}">{% endif %}
  {% set _seo_desc = seo_description|default('') %}
  {% if _seo_desc is not empty %}<meta name="description" content="{{ core_e(_seo_desc) }}">{% endif %}
  {% set _seo_kw = seo_keywords|default('') %}
  {% if _seo_kw is not empty %}<meta name="keywords" content="{{ core_e(_seo_kw) }}">{% endif %}
  {% set _canonical = canonical_url|default('') %}
  {% if _canonical is not empty %}<link rel="canonical" href="{{ core_e(_canonical) }}">{% endif %}
  <meta property="og:type" content="{{ core_e(og_type|default('website')) }}">
  <meta property="og:title" content="{{ core_e(og_title|default(site_name|default(core_config('app.name')))) }}">
  {% set _og_desc = og_description|default('') %}
  {% if _og_desc is not empty %}<meta property="og:description" content="{{ core_e(_og_desc) }}">{% endif %}
  {% set _og_img = og_image|default('') %}
  {% if _og_img is not empty %}<meta property="og:image" content="{{ core_e(_og_img) }}">{% endif %}
  {% if _canonical is not empty %}<meta property="og:url" content="{{ core_e(_canonical) }}">{% endif %}
  {% set _schema = schema_json|default('') %}
  {% if _schema is not empty %}
    {% set ld = _schema|schema_ld_json %}
    {% if ld != '' %}<script type="application/ld+json">{{ ld|raw }}</script>{% endif %}
  {% endif %}
  {# PWA: Admin > Ayarlar > PWA Ayarları #}
  {% if pwa_enabled|default(false) %}
  <link rel="manifest" href="{{ core_e(pwa_manifest_url|default(core_url('manifest.json'))) }}">
  <meta name="theme-color" content="{{ pwa_theme_color|default('#2d5580') }}">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  {% if pwa_icon_192_url|default('') is not empty %}<link rel="apple-touch-icon" sizes="192x192" href="{{ core_e(pwa_icon_192_url) }}">{% endif %}
  {% if pwa_icon_512_url|default('') is not empty %}<link rel="apple-touch-icon" sizes="512x512" href="{{ core_e(pwa_icon_512_url) }}">{% endif %}
  {% endif %}
  <link rel="stylesheet" href="{{ theme_asset_url('css/tailwind.css') }}?v={{ 'now'|date('U') }}">
  <link rel="stylesheet" href="{{ theme_asset_url('css/tailwind-custom.css') }}?v={{ 'now'|date('U') }}">
  <link rel="stylesheet" href="{{ core_url('css/main.css') }}?v={{ core_config('app.version', '1.0.0') }}">
  <link rel="stylesheet" href="{{ theme_asset_url('css/theme.css') }}?v={{ 'now'|date('U') }}">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css">
  <link rel="stylesheet" href="{{ theme_asset_url('css/portal.css') }}?v={{ 'now'|date('U') }}">
  <link rel="stylesheet" href="{{ theme_asset_url('css/portal-showcase.css') }}?v={{ 'now'|date('U') }}">
  <link rel="stylesheet" href="{{ theme_asset_url('css/portal-cards.css') }}?v={{ 'now'|date('U') }}">
  <link rel="stylesheet" href="{{ theme_asset_url('css/humanizer-classic.css') }}?v={{ 'now'|date('U') }}">
  {# 3.13.3: x-show+x-transition yarışı → konsol hatası (Alpine 3.14+) #}
  <script defer src="https://unpkg.com/alpinejs@3.14.9/dist/cdn.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  {% if editor_type|default('toast_ui') == 'toast_ui' %}
  <!-- Toast UI Editor: CDN (sadece editör Toast UI seçiliyse) -->
  <link rel="stylesheet" href="https://uicdn.toast.com/editor/latest/toastui-editor.min.css">
  {% endif %}

  <style>
    :root {
      --primary-color: {{ theme_primary_color|default('#105289')|raw }};
      --theme-header-bg: {{ theme_header_bg_color|default('#2d5580')|raw }};
      --theme-header-text: {{ theme_header_text_color|default('#ffffff')|raw }};
      --theme-menu-bg: {{ theme_menu_bg_color|default('#35608c')|raw }};
      --theme-menu-text: {{ theme_menu_text_color|default('#ffffff')|raw }};
      --theme-footer-bg: {{ theme_footer_bg_color|default('#2a3f55')|raw }};
      --theme-footer-text: {{ theme_footer_text_color|default('#d4dce8')|raw }};
      --theme-card-bg: {{ theme_card_bg_color|default('#ffffff')|raw }};
      --theme-card-border: {{ theme_card_border_color|default('#b5c0cb')|raw }};
      --theme-button-radius: {{ theme_button_radius|default('4')|raw }}px;
    }
    #site-header,
    #header-bar {
      background: var(--theme-header-bg, #2d5580) !important;
      color: var(--theme-header-text, #ffffff) !important;
    }
    #site-header a,
    #header-bar a,
    #header-bar .text-gray-600,
    #header-bar .text-gray-700,
    #header-bar .text-gray-800 {
      color: var(--theme-header-text, #ffffff) !important;
    }
    #main-menu-bar,
    #mobile-menu-panel {
      background: var(--theme-menu-bg, #35608c) !important;
      color: var(--theme-menu-text, #ffffff) !important;
      border-color: color-mix(in srgb, var(--theme-menu-bg, #35608c) 70%, #ffffff 30%) !important;
    }
    #main-menu-bar a,
    #main-menu-bar span,
    #mobile-menu-panel a,
    #mobile-menu-panel span {
      color: var(--theme-menu-text, #ffffff) !important;
    }
    footer {
      background: var(--theme-footer-bg, #2a3f55) !important;
      color: var(--theme-footer-text, #d4dce8) !important;
    }
    footer a,
    footer p,
    footer span {
      color: var(--theme-footer-text, #d4dce8) !important;
    }
    .card,
    .son-olaylar-card,
    .portal-card-item,
    .mfbb-showthread-card {
      background-color: var(--theme-card-bg, #ffffff) !important;
      border-color: var(--theme-card-border, #e5e7eb) !important;
    }
    .btn {
      border-radius: var(--theme-button-radius, 10px);
    }
    {% if custom_css is not empty %}
    {{ custom_css|raw }}
    {% endif %}
  </style>
  {% block head_extra %}{% endblock %}
  {% if header_extra is defined and header_extra is not empty %}{{ header_extra|raw }}{% endif %}
</head>
<body class="min-h-screen flex flex-col overflow-x-hidden {% block body_class %}mfbb-layout-forum{% endblock %}">
  <div id="mfbb-top-progress" class="mfbb-top-progress" aria-hidden="true">
    <span id="mfbb-top-progress-bar" class="mfbb-top-progress__bar"></span>
  </div>
  <script>
  (function() {
    var progressEl = document.getElementById('mfbb-top-progress');
    var progressBarEl = document.getElementById('mfbb-top-progress-bar');
    var count = 0;
    var progress = 0;
    var progressTimer = null;
    function setProgress(pct, immediate) {
      if (!progressBarEl) return;
      var clamped = Math.max(0, Math.min(100, pct));
      if (immediate) progressBarEl.style.transition = 'none';
      progressBarEl.style.transform = 'scaleX(' + (clamped / 100) + ')';
      if (immediate) {
        progressBarEl.offsetHeight;
        progressBarEl.style.transition = '';
      }
    }
    function startProgress() {
      if (!progressEl || !progressBarEl) return;
      progress = 12;
      setProgress(progress, true);
      progressEl.classList.add('is-active');
      if (progressTimer) clearInterval(progressTimer);
      progressTimer = setInterval(function() {
        if (progress >= 88) return;
        progress += progress < 50 ? 9 : (progress < 75 ? 5 : 2.2);
        setProgress(progress, false);
      }, 180);
    }
    function finishProgress() {
      if (!progressEl || !progressBarEl) return;
      if (progressTimer) {
        clearInterval(progressTimer);
        progressTimer = null;
      }
      progress = 100;
      setProgress(progress, false);
      setTimeout(function() {
        progressEl.classList.remove('is-active');
        setProgress(0, true);
      }, 260);
    }
    function showLoading() {
      count++;
      if (count !== 1) return;
      startProgress();
      window.dispatchEvent(new CustomEvent('mfbb:loading-start'));
    }
    function hideLoading() {
      count = Math.max(0, count - 1);
      if (count !== 0) return;
      finishProgress();
      window.dispatchEvent(new CustomEvent('mfbb:loading-end'));
    }
    function urlSkipLoading(url) {
      if (typeof url !== 'string') return true;
      var u = url.split('?')[0];
      return u.indexOf('/api/badges') !== -1 || u.indexOf('/api/sse') !== -1 || u.indexOf('/api/notifications/unread') !== -1 || u.indexOf('/api/notifications/dropdown') !== -1 || u.indexOf('/api/hover/user') !== -1 || u.indexOf('/api/hover/post') !== -1;
    }
    window.MegaforBBLoading = {
      show: showLoading,
      hide: hideLoading,
      startProgress: startProgress,
      finishProgress: finishProgress
    };
    var origFetch = window.fetch;
    if (origFetch) {
      window.fetch = function(input, init) {
        var url = typeof input === 'string' ? input : (input && input.url);
        if (urlSkipLoading(url)) return origFetch.apply(this, arguments);
        showLoading();
        return origFetch.apply(this, arguments).then(function(r) { hideLoading(); return r; }, function(e) { hideLoading(); throw e; });
      };
    }
    var OrigXHR = window.XMLHttpRequest;
    if (OrigXHR) {
      window.XMLHttpRequest = function() {
        var xhr = new OrigXHR();
        var origSend = xhr.send;
        xhr.send = function() {
          var url = xhr._mfbbUrl || '';
          if (urlSkipLoading(url)) return origSend.apply(this, arguments);
          showLoading();
          var done = function() { hideLoading(); };
          xhr.addEventListener('load', done, { once: true });
          xhr.addEventListener('error', done, { once: true });
          xhr.addEventListener('abort', done, { once: true });
          return origSend.apply(this, arguments);
        };
        var origOpen = xhr.open;
        xhr.open = function(method, url) { xhr._mfbbUrl = url; return origOpen.apply(this, arguments); };
        return xhr;
      };
    }
  })();
  </script>
  <div id="toast-container" class="mfbb-toast-container" aria-live="polite"></div>
  {% if isStaff %}{% include 'partials/staff_topbar.html.twig' %}{% endif %}
  <div class="flex-1 flex flex-col" x-data="{ mobileMenu: false }">
  <header id="site-header" class="w-full bg-[#105289] text-white shadow-sm">
    <div class="w-full max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="py-4" id="header-bar"
        @mfbb-sse-notification.window="handleSseNotification($event.detail)"
        @mfbb-soft-nav-loaded.window="refreshBadges(); if (openNotifications) loadNotificationDropdown()"
        x-data="{
          openUser: false,
          openNotifications: false,
          notificationList: [],
          badges: { notifications: {{ unreadNotifications ?? 0 }}, messages: {{ unreadMessages ?? 0 }} },
          shownNotifIds: [],
          badgeUrl: '{{ core_e(core_url('api/badges')) }}',
          notifUrl: '{{ core_e(core_url('api/notifications/unread')) }}',
          notifDropdownUrl: '{{ core_e(core_url('api/notifications/dropdown')) }}',
          sseUrl: '{{ currentUser and notificationsEnabled|default(true) ? core_e(core_url('api/sse')) : '' }}',
          readAllUrl: {{ core_url('notifications/read-all')|json_encode|e('html_attr') }},
          readAllCsrf: {{ core_csrf_token('notifications_read_all')|json_encode|e('html_attr') }},
          markAllReadLoading: false,
          toastEnabled: {{ notificationToastEnabled ? 'true' : 'false' }},
          async refreshBadges() {
            try {
              const r = await fetch(this.badgeUrl);
              const d = await r.json();
              if (d.notifications !== undefined) this.badges.notifications = d.notifications;
              if (d.messages !== undefined) this.badges.messages = d.messages;
            } catch (e) {}
          },
          handleSseNotification(detail) {
            const list = (detail && detail.notifications) ? detail.notifications : [];
            list.forEach(n => {
              if (this.shownNotifIds.includes(n.id)) return;
              this.shownNotifIds.push(n.id);
              if (n.type === 'message') {
                this.badges.messages = (this.badges.messages || 0) + 1;
              } else {
                this.badges.notifications = (this.badges.notifications || 0) + 1;
              }
               if (this.toastEnabled && typeof window.MegaforBBPushNotification === 'function') {
                 window.MegaforBBPushNotification(n);
               }
            });
            if (list.length) this.loadNotificationDropdown();
          },
          async loadNotificationDropdown() {
            try {
              const r = await fetch(this.notifDropdownUrl);
              const d = await r.json();
              this.notificationList = d.notifications || [];
            } catch (e) { this.notificationList = []; }
          },
          async markAllNotificationsRead() {
            if (this.badges.notifications === 0 || this.markAllReadLoading) return;
            this.markAllReadLoading = true;
            const fd = new FormData();
            fd.append('_token', this.readAllCsrf);
            try {
              const r = await fetch(this.readAllUrl, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
              const d = await r.json();
              if (d && d.ok) { this.badges.notifications = 0; await this.loadNotificationDropdown(); if (typeof window.mfbbToast === 'function') window.mfbbToast('Tüm bildirimler okundu işaretlendi.', 'success'); }
            } catch (e) { if (typeof window.mfbbToast === 'function') window.mfbbToast('İşlem yapılamadı.', 'error'); }
            this.markAllReadLoading = false;
          }
        }"
        x-init="
          setInterval(async () => {
            try {
              const r = await fetch(badgeUrl);
              const d = await r.json();
              if (d.notifications !== undefined) badges.notifications = d.notifications;
              if (d.messages !== undefined) badges.messages = d.messages;
            } catch (e) {}
          }, 60000);
          if (toastEnabled) {
            setInterval(async () => {
              try {
                const r = await fetch(notifUrl);
                const d = await r.json();
                (d.notifications || []).forEach(n => {
                  if (shownNotifIds.includes(n.id)) return;
                  shownNotifIds.push(n.id);
                  if (typeof window.MegaforBBPushNotification === 'function') {
                    window.MegaforBBPushNotification(n);
                  }
                });
              } catch (e) {}
            }, 45000);
          }
          if (sseUrl && typeof EventSource !== 'undefined') {
            const startSSE = () => {
              const es = new EventSource(sseUrl);
              es.addEventListener('notification', (e) => {
                try {
                  const d = JSON.parse(e.data);
                  window.dispatchEvent(new CustomEvent('mfbb-sse-notification', { detail: d }));
                } catch (err) {}
              });
              es.onerror = () => { es.close(); setTimeout(startSSE, 3000); };
            };
            startSSE();
          }
        ">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            {% if forum_logo_url is not empty %}
            <a href="{{ core_url('') }}" class="flex items-center shrink-0"><img src="{{ core_e(forum_logo_url) }}" alt="" class="h-[50px] w-auto max-w-[240px] object-contain" style="height:50px;max-width:240px;" id="site-logo"></a>
            {% else %}
            <div class="h-10 w-10 rounded-md bg-white text-[#105289] flex items-center justify-center">
              <i class="fa-solid fa-comments"></i>
            </div>
            {% endif %}
            {% if forum_logo_url is empty or show_site_title_next_to_logo %}
            <a href="{{ core_url('') }}" class="text-xl font-semibold">{{ core_e(site_name ?? core__('common.site_name')) }}</a>
            {% endif %}
          </div>
          <div class="flex items-center gap-2 sm:gap-3">
            <button type="button" class="md:hidden flex items-center justify-center h-9 w-9 rounded-md border border-white/50 hover:bg-white hover:text-[#105289] transition-colors" @click.stop="mobileMenu = !mobileMenu" aria-label="Menü">
              <i class="fa-solid" :class="mobileMenu ? 'fa-times' : 'fa-bars'"></i>
            </button>
            <div class="hidden md:block">
              <form class="flex items-center bg-[#355a7d] border border-[#4a6b8a] rounded-md px-3 py-2" action="{{ core_url('search') }}" method="get">
                <input name="q" class="bg-transparent outline-none text-sm text-white placeholder-gray-300 w-48 md:w-64" type="search" placeholder="{{ core_e(core__('common.search')) }}">
                <button type="submit" class="ml-2 text-sm text-[#105289] bg-white hover:bg-gray-100 rounded-md px-3 py-1.5">{{ core_e(core__('common.search_btn')) }}</button>
              </form>
            </div>
            <div class="flex items-center" id="auth-nav-container">
              {% if currentUser %}
                {% include 'partials/user_nav.html.twig' with { currentUser: currentUser, notificationsEnabled: notificationsEnabled|default(true), messagesEnabled: messagesEnabled|default(true) } %}
              {% else %}
                <div class="hidden md:flex items-center gap-2">
                  <a href="{{ core_url('login') }}" class="text-sm text-white border border-white hover:bg-white hover:text-[#105289] rounded-md px-3 py-1.5">{{ core_e(core__('common.login')) }}</a>
                  <a href="{{ core_url('register') }}" class="text-sm text-[#105289] bg-white hover:bg-gray-100 rounded-md px-3 py-1.5">{{ core_e(core__('common.register')) }}</a>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>
  <nav id="main-menu-bar" class="hidden md:block w-full bg-[#234a73] text-white shadow-sm border-b border-[#4a6b8a]">
    <div class="w-full max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between">
      <ul class="flex items-center gap-1 flex-wrap">
        {% for nav in navItems %}
          {% set href = nav.href ?? core_url('') %}
          {% set label = nav.label ?? '' %}
          {% set children = nav.children ?? [] %}
          {% set isExternal = href starts with 'http://' or href starts with 'https://' %}
          {% set linkAttr = isExternal ? ' target="_blank" rel="noopener noreferrer"' : '' %}
          <li class="relative group">
            {% if children is not empty %}
              <span class="block px-4 py-3 hover:bg-[#105289] rounded-md cursor-default flex items-center gap-1">
                {{ core_e(label) }} <i class="fa-solid fa-chevron-down text-xs"></i>
              </span>
              <ul class="absolute left-0 top-full min-w-[160px] bg-[#105289] border border-[#4a6b8a] rounded-md shadow-lg py-1 z-50 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
                <li><a href="{{ core_e(href) }}" class="block px-4 py-2 hover:bg-[#243447] text-sm"{{ linkAttr|raw }}>{{ core_e(label) }}</a></li>
                {% for ch in children %}
                {% set chHref = ch.href ?? core_url('') %}
                {% set chExternal = chHref starts with 'http://' or chHref starts with 'https://' %}
                <li><a href="{{ core_e(chHref) }}" class="block px-4 py-2 hover:bg-[#243447] text-sm"{% if chExternal %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ core_e(ch.label ?? '') }}</a></li>
                {% endfor %}
              </ul>
            {% else %}
              <a href="{{ core_e(href) }}" class="block px-4 py-3 hover:bg-[#105289] rounded-md"{{ linkAttr|raw }}>{{ core_e(label) }}</a>
            {% endif %}
          </li>
        {% endfor %}

      </ul>
      {% if social_show_header and (social_facebook or social_twitter or social_instagram or social_youtube or social_linkedin) %}
      <div class="flex items-center gap-1.5 shrink-0 pl-4 ml-2 border-l border-[#4a6b8a]">
        {% include 'partials/social_links.html.twig' with _context|merge({ social_zone: 'menu' }) %}
      </div>
      {% endif %}
    </div>
  </nav>

  <div class="md:hidden fixed inset-0 bg-black/30 z-40"
    x-show="mobileMenu"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    @click="mobileMenu = false"
    style="display: none;"></div>
  <div id="mobile-menu-panel" class="md:hidden bg-[#105289] border-b border-[#4a6b8a] overflow-hidden relative z-50"
    x-show="mobileMenu"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    style="display: none;">
    <div class="max-w-[1600px] mx-auto px-4 py-4 space-y-4">
      <form class="flex items-center bg-[#355a7d] border border-[#4a6b8a] rounded-lg px-3 py-2.5" action="{{ core_url('search') }}" method="get">
        <i class="fa-solid fa-magnifying-glass text-gray-400 mr-2"></i>
        <input name="q" class="bg-transparent outline-none text-sm text-white placeholder-gray-400 flex-1" type="search" placeholder="{{ core_e(core__('common.search')) }}...">
        <button type="submit" class="ml-2 text-sm text-[#105289] bg-white hover:bg-gray-100 rounded-md px-3 py-1.5 font-medium">{{ core_e(core__('common.search_btn')) }}</button>
      </form>
      <nav class="space-y-0.5">
        {% for nav in navItems %}
          {% set mHref = nav.href ?? core_url('') %}
