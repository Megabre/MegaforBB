  <script src="{{ core_url('ui-vendor/ckeditor5/ckeditor.js') }}"></script>
  <script>
    (function() {
      var uploadUrl = window.MEGAFORBB_UPLOAD_URL || {{ base_url('upload/image')|json_encode|raw }};
      var fullUploadUrl = (typeof uploadUrl === 'string' && uploadUrl.indexOf('http') === 0) ? uploadUrl : (window.location.origin + (uploadUrl.charAt(0) === '/' ? uploadUrl : '/' + uploadUrl));
      window.MEGAFORBB_CKEDITORS = window.MEGAFORBB_CKEDITORS || {};
      function MfbbCkUploadAdapter(loader, url) {
        this.loader = loader;
        this.url = url || fullUploadUrl;
      }
      MfbbCkUploadAdapter.prototype.upload = function() {
        var self = this;
        return this.loader.file.then(function(file) {
          return new Promise(function(resolve, reject) {
            var fd = new FormData();
            fd.append('file', file);
            var xhr = new XMLHttpRequest();
            xhr.open('POST', self.url);
            xhr.withCredentials = true;
            xhr.onload = function() {
              try {
                var d = JSON.parse(xhr.responseText);
                if (d && d.url) resolve({ default: d.url }); else reject(new Error(d && d.error && d.error.message ? d.error.message : 'Upload failed'));
              } catch (e) { reject(e); }
            };
            xhr.onerror = function() { reject(new Error('Upload failed')); };
            xhr.send(fd);
          });
        });
      };
      MfbbCkUploadAdapter.prototype.abort = function() {};
      if (typeof ClassicEditor !== 'undefined') {
        document.querySelectorAll('textarea[data-editor]').forEach(function(ta) {
          if (ta.id && window.MEGAFORBB_CKEDITORS[ta.id]) return;
          var id = ta.id || ('ckeditor-' + Math.random().toString(36).slice(2));
          if (!ta.id) ta.id = id;
          ta.removeAttribute('required');
          ClassicEditor.create(ta, {
            language: {{ (locale|default('tr')) == 'en' ? '"en"' : '"tr"' }},
            placeholder: ta.getAttribute('placeholder') || 'İçerik yazın...',
            toolbar: ['heading', '|', 'bold', 'italic', 'underline', 'strikethrough', '|', 'link', 'imageInsert', 'mediaEmbed', 'blockQuote', 'insertTable', '|', 'bulletedList', 'numberedList', 'alignment', '|', 'undo', 'redo', 'sourceEditing', 'codeBlock'],
            image: { toolbar: ['imageTextAlternative', 'imageStyle:full', 'imageStyle:side', 'linkImage'] },
            table: { contentToolbar: ['tableColumn', 'tableRow', 'mergeTableCells'] }
          }).then(function(editor) {
            var fileRepo = editor.plugins.get('FileRepository');
            if (fileRepo) fileRepo.createUploadAdapter = function(loader) { return new MfbbCkUploadAdapter(loader); };
            window.MEGAFORBB_CKEDITORS[id] = editor;
            var editable = editor.ui.view.editable && editor.ui.view.editable.element;
            if (editable) {
              editable.style.setProperty('min-height', '280px', 'important');
            }
            editor.model.document.on('change:data', function() {
              setTimeout(function() { editor.updateSourceElement(); }, 150);
            });
          }).catch(function(e) { console.error('CKEditor init error', e); });
        });
      }
    })();
  </script>
