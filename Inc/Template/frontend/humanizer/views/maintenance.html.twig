<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ lang('common.maintenance_page_title') }} - {{ appName|e }}</title>
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; margin: 0; padding: 2rem; min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #f5f5f5; }
        .box { background: #fff; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.08); max-width: 420px; text-align: center; }
        h1 { margin: 0 0 1rem; font-size: 1.5rem; color: #333; }
        p { color: #666; margin: 0 0 1rem; }
        a { color: #105289; }
    </style>
</head>
<body>
    <div class="box">
        <h1>{{ lang('common.maintenance_title') }}</h1>
        <p>{{ lang('common.maintenance_message') }}</p>
        {% if loginUrl %}<p><a href="{{ loginUrl|e }}">{{ lang('common.admin_login') }}</a></p>{% endif %}
    </div>
</body>
</html>
