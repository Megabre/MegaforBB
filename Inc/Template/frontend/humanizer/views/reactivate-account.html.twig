{% extends 'base.html.twig' %}

{% block content %}
{% set error = error ?? '' %}

<div class="min-h-[50vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md bg-white ring-1 ring-gray-200 shadow-sm rounded-lg overflow-hidden">
    <div class="p-6 border-b border-gray-200 bg-amber-50">
      <h1 class="text-xl font-semibold text-[#105289]">{{ lang('auth.reactivate_title') }}</h1>
      <p class="text-sm text-gray-600 mt-1">{{ lang('auth.reactivate_description') }}</p>
    </div>
    <div class="p-6">
      {% if error %}
      <div class="mb-4 p-3 rounded-md bg-red-50 border border-red-200 text-red-700 text-sm">{{ core_e(error) }}</div>
      {% endif %}
      <form method="post" action="{{ core_url('reactivate-account') }}">
        {{ core_csrf_field('reactivate')|raw }}
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ core__('auth.username_email') }}</label>
          <input name="login" type="text" class="w-full border border-gray-300 rounded-md px-3 py-2" required>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ core__('auth.password') }}</label>
          <input name="password" type="password" class="w-full border border-gray-300 rounded-md px-3 py-2" required>
        </div>
        <button type="submit" class="w-full text-white bg-[#105289] hover:bg-[#234a73] rounded-md px-4 py-2">{{ lang('auth.reactivate_button') }}</button>
      </form>
    </div>
    <div class="px-6 pb-6 text-center">
      <a href="{{ core_url('login') }}" class="text-sm text-gray-600 hover:underline">{{ lang('auth.back_to_login') }}</a>
    </div>
  </div>
</div>
{% endblock %}
