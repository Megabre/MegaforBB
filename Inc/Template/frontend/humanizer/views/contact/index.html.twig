{% extends 'base.html.twig' %}
{% set contactSuccess = flash('contact_success') %}
{% set contactError = flash('contact_error') %}
{% set contactPageTitle = lang('contact.page_title') %}
{% set siteTitle = site_name|default(core_config('app.name', 'MegaforBB')) %}
{% set siteDesc = seo_description|default(lang('contact.form_intro')) %}
{% set captcha_show = captcha_show ?? false %}
{% block content %}
<div class="container mx-auto px-4 py-8 max-w-4xl">
  <header class="text-center mb-10">
    <h1 class="text-3xl md:text-4xl font-bold text-[#105289] tracking-tight">{{ contactPageTitle }}</h1>
    <p class="mt-3 text-lg text-gray-600 max-w-2xl mx-auto">{{ core_e(siteTitle) }}</p>
    {% if siteDesc %}
    <p class="mt-2 text-gray-500">{{ core_e(siteDesc) }}</p>
    {% endif %}
  </header>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden max-w-2xl mx-auto">
    <div class="p-6 md:p-8">
      {% if contactSuccess %}
      <div class="mb-6 p-4 rounded-lg bg-green-50 border border-green-200 text-green-700 text-sm">{{ core_e(contactSuccess) }}</div>
      {% endif %}
      {% if contactError %}
      <div class="mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">{{ core_e(contactError) }}</div>
      {% endif %}

      <h2 class="text-xl font-semibold text-[#105289] mb-6">{{ core__('contact.form_title') }}</h2>
      <form method="post" action="{{ core_url('iletisim') }}" class="space-y-5">
        {{ core_csrf_field('contact')|raw }}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="contact-name">{{ core__('contact.field_name') }}</label>
            <input name="name" type="text" id="contact-name" required class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-gray-800 placeholder-gray-400 outline-none focus:ring-2 focus:ring-[#105289]/20 focus:border-[#105289]/40" placeholder="{{ core__('contact.field_name') }}">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="contact-email">{{ core__('contact.field_email') }}</label>
            <input name="email" type="email" id="contact-email" required class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-gray-800 placeholder-gray-400 outline-none focus:ring-2 focus:ring-[#105289]/20 focus:border-[#105289]/40" placeholder="{{ core__('contact.field_email') }}">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="contact-subject">{{ core__('contact.field_subject') }}</label>
          <input name="subject" type="text" id="contact-subject" required class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-gray-800 placeholder-gray-400 outline-none focus:ring-2 focus:ring-[#105289]/20 focus:border-[#105289]/40" placeholder="{{ core__('contact.field_subject') }}">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="contact-message">{{ core__('contact.field_message') }}</label>
          <textarea name="message" id="contact-message" rows="5" required class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-gray-800 placeholder-gray-400 outline-none focus:ring-2 focus:ring-[#105289]/20 focus:border-[#105289]/40 resize-y min-h-[140px]" placeholder="{{ core__('contact.field_message') }}"></textarea>
        </div>
        {% if captcha_show %}
        {% include 'partials/captcha.html.twig' %}
        {% endif %}
        <div class="pt-2">
          <button type="submit" class="w-full sm:w-auto min-w-[180px] text-white bg-[#105289] hover:bg-[#234a73] rounded-lg px-6 py-3 font-medium transition-colors shadow-sm">
            <i class="fa-solid fa-paper-plane mr-2"></i>{{ core__('contact.submit') }}
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="mt-8 text-center">
    <p class="text-sm text-gray-500">{{ core__('contact.benefit_general') }} · {{ core__('contact.benefit_support') }} · {{ core__('contact.benefit_feedback') }}</p>
    <p class="mt-4"><a href="{{ core_url('') }}" class="text-sm text-[#105289] hover:underline">{{ core__('common.home') }}</a></p>
  </div>
</div>
{% endblock %}
