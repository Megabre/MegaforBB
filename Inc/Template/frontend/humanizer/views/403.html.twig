{% extends 'base.html.twig' %}

{% block content %}
<div class="min-h-[40vh] flex items-center justify-center px-4">
  <div class="text-center">
    <h1 class="text-2xl font-bold text-[#105289]">{{ core__('error.403_title') }}</h1>
    <p class="text-gray-600 mt-2">{{ (message|default(core__('error.403_message')))|e('html') }}</p>
    <a href="{{ core_url('') }}" class="inline-block mt-4 px-4 py-2 bg-[#105289] text-white rounded-md hover:bg-[#234a73]">{{ core__('error.404_home') }}</a>
  </div>
</div>
{% endblock %}
