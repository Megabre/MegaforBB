{% extends 'base.html.twig' %}

{% block content %}
{% set error = error ?? '' %}
{% set success = success ?? '' %}

<div class="min-h-[60vh] flex items-center justify-center">
  <div class="w-full max-w-md bg-white ring-1 ring-gray-200 shadow-sm rounded-lg overflow-hidden p-6">
    <div class="text-lg font-semibold text-[#105289] mb-2">{{ lang('auth.login_verify_title') }}</div>
    {% if success %}
    <div class="p-3 rounded-md bg-green-50 border border-green-200 text-green-700 text-sm mb-4">{{ core_e(success) }}</div>
    {% endif %}
    {% if error %}
    <div class="p-3 rounded-md bg-red-50 border border-red-200 text-red-700 text-sm mb-4">{{ core_e(error) }}</div>
    {% endif %}
    <form method="post" action="{{ core_url('login/verify') }}">
      {{ core_csrf_field('login_verify')|raw }}
      <div class="mb-4">
        <label class="block text-sm font-medium text-[#105289] mb-1">{{ lang('auth.login_verify_placeholder') }}</label>
        <input name="code" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="6" autocomplete="one-time-code" class="w-full border border-gray-300 rounded-md px-3 py-2 outline-none focus:ring-2 focus:ring-blue-200 font-mono text-lg tracking-widest" placeholder="000000">
      </div>
      <button type="submit" class="w-full text-white bg-[#105289] hover:bg-[#234a73] rounded-md px-4 py-2">{{ lang('auth.login_verify_title') }}</button>
    </form>
    <p class="mt-4 text-sm text-gray-600 text-center">{{ lang('auth.login_verify_again') }} <a href="{{ core_url('login') }}" class="text-[#105289] font-medium hover:underline">{{ core__('auth.login_title') }}</a></p>
    <div class="text-center mt-2"><a href="{{ core_url('') }}" class="text-sm text-gray-600 hover:underline">{{ core__('common.home') }}</a></div>
  </div>
</div>
{% endblock %}
