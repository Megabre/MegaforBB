{% extends 'base.html.twig' %}

{% block content %}
{% set profileUser = profileUser ?? null %}
{% if not profileUser %}
  <p class="p-4 text-gray-500">Kullanıcı bulunamadı.</p>
{% else %}
{% set baseUrl = core_url('member/' ~ (profileUser.username|e('url'))) %}
{% set items = items ?? [] %}

<div class="mt-4 text-sm text-gray-600">
  <nav aria-label="Breadcrumb" class="bg-white border border-gray-200 rounded-md shadow-sm px-4 py-2">
    <ol class="flex items-center gap-2">
      <li><a href="{{ core_url('') }}" class="text-[#105289] hover:text-blue-500 hover:underline">Ana Sayfa</a></li>
      <li>›</li>
      <li><a href="{{ baseUrl }}" class="text-[#105289] hover:text-blue-500 hover:underline">{{ core_e(profileUser.username) }}</a></li>
      <li>›</li>
      <li class="text-gray-700">{{ core__('topic.topics') }}</li>
    </ol>
  </nav>
</div>
<div class="mt-6 bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
    <h1 class="text-xl font-semibold text-[#105289]">{{ core_e(profileUser.username) }} — Açılan konular</h1>
  </div>
  {% if items is empty %}
  <div class="p-8 text-center text-gray-500">Henüz konu açılmamış.</div>
  {% else %}
  <ul class="divide-y divide-gray-200">
    {% for t in items %}
    <li class="px-6 py-3 hover:bg-gray-50 flex flex-wrap items-center gap-2">
      <a href="{{ core_url('forum/' ~ (t.forum_slug ?? '')|e('url')) }}" class="text-xs text-gray-500">{{ core_e(t.forum_name ?? '') }}</a>
      <span class="text-gray-300">›</span>
      <a href="{{ core_url('topic/' ~ topic_url_path(t)) }}" class="font-medium text-[#105289] hover:underline flex-1 min-w-0">{{ core_e(t.title ?? '') }}</a>
      <span class="text-xs text-gray-400">{{ core_e(t.created_at ?? '') }}</span>
      <span class="text-xs text-gray-500">{{ t.reply_count ?? 0 }} cevap</span>
    </li>
    {% endfor %}
  </ul>
  {% endif %}
</div>
{% endif %}
{% endblock %}
