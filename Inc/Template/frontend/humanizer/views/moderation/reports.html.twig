{% extends 'base.html.twig' %}

{% block content %}
{% set reports = reports ?? [] %}
{% set modError = flash('mod_error') %}
{% set modOk = flash('mod_ok') %}

<div class="mt-4 text-sm text-gray-600">
  <nav aria-label="Breadcrumb" class="bg-white border border-gray-200 rounded-md shadow-sm px-4 py-2">
    <ol class="flex items-center gap-2">
      <li><a href="{{ core_url('') }}" class="text-[#105289] hover:text-blue-500 hover:underline">{{ core__('common.home') }}</a></li>
      <li>›</li>
      <li class="text-gray-700">{{ core__('mod.page_title_reports') }}</li>
    </ol>
  </nav>
</div>

{% if modError %}
<div class="mt-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-md text-sm">{{ core_e(modError) }}</div>
{% endif %}
{% if modOk %}
<div class="mt-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-md text-sm">{{ core_e(modOk) }}</div>
{% endif %}

{% if reports is not empty %}
<div class="mt-4 flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-600 shadow-sm">
  <p class="m-0">{{ core__('mod.bulk_bar_hint') }}</p>
  <div class="flex flex-wrap items-center gap-2">
    <form method="post" action="{{ core_url('moderation/reports/bulk-reviewed') }}" class="inline" onsubmit="return confirm('{{ core__('mod.bulk_confirm_review_all')|e('js') }}');">
      {{ core_csrf_field('mod_report')|raw }}
      <input type="hidden" name="apply_all" value="1">
      <button type="submit" class="rounded border border-green-200 bg-green-50 px-3 py-1.5 text-xs font-medium text-green-800 hover:bg-green-100">{{ core__('mod.bulk_review_all') }}</button>
    </form>
    <form method="post" action="{{ core_url('moderation/reports/bulk-dismiss') }}" class="inline" onsubmit="return confirm('{{ core__('mod.bulk_confirm_dismiss_all')|e('js') }}');">
      {{ core_csrf_field('mod_report')|raw }}
      <input type="hidden" name="apply_all" value="1">
      <button type="submit" class="rounded border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-medium text-red-800 hover:bg-red-100">{{ core__('mod.bulk_dismiss_all') }}</button>
    </form>
    <form method="post" id="mod-report-bulk-selected-form" action="{{ core_url('moderation/reports/bulk-reviewed') }}" class="hidden" aria-hidden="true">
      {{ core_csrf_field('mod_report')|raw }}
      <div id="mod-report-bulk-selected-slot"></div>
    </form>
    <button type="button" class="rounded border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-gray-50" id="mod-report-btn-select-all">{{ core__('mod.bulk_select_all_pending_reports') }}</button>
    <button type="button" class="rounded border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-800 hover:bg-gray-50" id="mod-report-btn-review-selected">{{ core__('mod.bulk_review_selected') }}</button>
    <button type="button" class="rounded border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-red-700 hover:bg-red-50" id="mod-report-btn-dismiss-selected">{{ core__('mod.bulk_dismiss_selected') }}</button>
  </div>
</div>
{% endif %}

<div class="mt-6 bg-white ring-1 ring-gray-200 shadow-sm rounded-lg overflow-hidden">
  <div class="px-4 py-3 border-b border-gray-200 bg-slate-50 font-semibold text-[#105289] flex items-center gap-2">
    <i class="fa-solid fa-flag"></i> {{ core__('mod.reported_posts') }}
  </div>
  {% if reports is empty %}
  <div class="p-8 text-center text-gray-500">{{ core__('mod.no_reports_yet') }}</div>
  {% else %}
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
        <tr>
          <th class="w-10 px-4 py-3"><span class="sr-only">{{ core__('mod.col_select') }}</span></th>
          <th class="px-4 py-3">{{ core__('mod.table_date') }}</th>
          <th class="px-4 py-3">{{ core__('mod.table_topic_post') }}</th>
          <th class="px-4 py-3">{{ core__('mod.table_reporter') }}</th>
          <th class="px-4 py-3">{{ core__('mod.table_reason') }}</th>
          <th class="px-4 py-3">{{ core__('mod.table_status') }}</th>
          <th class="px-4 py-3">{{ core__('mod.table_actions') }}</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        {% for r in reports %}
        {% set status = r.status ?? 'pending' %}
        <tr class="hover:bg-gray-50/50">
          <td class="px-4 py-3 align-top">
            {% if status == 'pending' %}
            <input type="checkbox" class="mod-report-cb h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" value="{{ r.id ?? 0 }}" aria-label="{{ core__('mod.col_select') }} #{{ r.id ?? 0 }}">
            {% endif %}
          </td>
          <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap">{{ core_e(r.created_at ?? '') }}</td>
          <td class="px-4 py-3 text-sm">
            <a href="{{ core_url('topic/' ~ (r.topic_id ?? 0)) }}" class="text-[#105289] hover:text-blue-600 hover:underline font-medium">{{ core_e(r.topic_title ?? '') }}</a>
            <span class="text-gray-500">({{ core__('mod.post_hash', { id: r.post_id ?? 0 }) }})</span>
            {% if r.post_author_username is defined and r.post_author_username %}
            <br><span class="text-xs text-gray-400">{{ core__('mod.written_by') }} {{ core_e(r.post_author_username) }}</span>
            {% endif %}
          </td>
          <td class="px-4 py-3 text-sm">
            <a href="{{ core_url('member/' ~ (r.reporter_username ?? '')|e('url')) }}" class="text-blue-600 hover:underline">{{ core_e(r.reporter_username ?? '') }}</a>
          </td>
          <td class="px-4 py-3 text-sm text-gray-700 max-w-xs">{{ (r.reason ?? '')|nl2br }}</td>
          <td class="px-4 py-3 text-sm">
            {% if status == 'pending' %}
              <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800">{{ core__('mod.status_pending') }}</span>
            {% elseif status == 'reviewed' %}
              <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">{{ core__('mod.status_reviewed') }}</span>
            {% else %}
              <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">{{ core__('mod.status_rejected') }}</span>
            {% endif %}
          </td>
          <td class="px-4 py-3 text-sm whitespace-nowrap">
            <a href="{{ core_url('topic/' ~ (r.topic_id ?? 0)) }}" class="text-blue-600 hover:underline mr-2">{{ core__('mod.action_review') }}</a>
            {% if status == 'pending' %}
            <form action="{{ core_url('moderation/reports/' ~ (r.id ?? 0) ~ '/reviewed') }}" method="post" class="inline">
              {{ core_csrf_field('mod_report')|raw }}
              <button type="submit" class="text-green-600 hover:underline mr-2">{{ core__('mod.action_marked_reviewed') }}</button>
            </form>
            <form action="{{ core_url('moderation/reports/' ~ (r.id ?? 0) ~ '/dismiss') }}" method="post" class="inline" onsubmit="return confirm('{{ core__('mod.dismiss_confirm') }}');">
              {{ core_csrf_field('mod_report')|raw }}
              <button type="submit" class="text-red-600 hover:underline">{{ core__('mod.action_dismiss') }}</button>
            </form>
            {% endif %}
            {% if canEditPost|default(false) %}
            <a href="{{ core_url('post/' ~ post_url_path_by_id(r.post_id ?? 0) ~ '/edit') }}" class="text-slate-600 hover:underline ml-2">{{ core__('mod.action_edit') }}</a>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
</div>
{% if reports is not empty %}
<script>
(function () {
  var msgNone = {{ core__('mod.bulk_nothing_selected')|json_encode|raw }};
  var msgDismiss = {{ core__('mod.bulk_confirm_dismiss_selected')|json_encode|raw }};
  var urlReview = {{ core_url('moderation/reports/bulk-reviewed')|json_encode|raw }};
  var urlDismiss = {{ core_url('moderation/reports/bulk-dismiss')|json_encode|raw }};
  function selectedIds() {
    return Array.prototype.slice.call(document.querySelectorAll('input.mod-report-cb:checked')).map(function (el) { return el.value; });
  }
  function submitSelected(url) {
    var ids = selectedIds();
    if (!ids.length) { window.alert(msgNone); return; }
    var form = document.getElementById('mod-report-bulk-selected-form');
    var slot = document.getElementById('mod-report-bulk-selected-slot');
    slot.innerHTML = '';
    ids.forEach(function (id) {
      var h = document.createElement('input');
      h.type = 'hidden';
      h.name = 'report_ids[]';
      h.value = id;
      slot.appendChild(h);
    });
    form.action = url;
    form.submit();
  }
  var br = document.getElementById('mod-report-btn-review-selected');
  var bd = document.getElementById('mod-report-btn-dismiss-selected');
  if (br) br.addEventListener('click', function () { submitSelected(urlReview); });
  if (bd) bd.addEventListener('click', function () { if (!window.confirm(msgDismiss)) return; submitSelected(urlDismiss); });
  var selAll = document.getElementById('mod-report-btn-select-all');
  if (selAll) selAll.addEventListener('click', function () {
    Array.prototype.forEach.call(document.querySelectorAll('input.mod-report-cb'), function (el) { el.checked = true; });
  });
})();
</script>
{% endif %}
{% endblock %}
