{% extends 'base.html.twig' %}

{% block content %}
{% set profile = profile ?? null %}
{% if not profile %}
  <div class="mt-6 p-6 bg-white rounded-xl ring-1 ring-gray-200 shadow-md">
    <p class="text-gray-500">{{ core__('profile.not_found') }}</p>
  </div>
{% else %}
{% set error = error ?? '' %}
{% set success = success ?? '' %}
{% set customDefinitions = customDefinitions ?? [] %}
{% set customValues = customValues ?? [] %}
{% set coverUrl = profile.cover_photo_path is not empty ? asset_url(profile.cover_photo_path) : null %}
{% set avatarUrl = profile.avatar_path is not empty ? asset_url(profile.avatar_path) : 'https://ui-avatars.com/api/?name=' ~ (avatar_display_name(profile.username ?? '')|url_encode) ~ '&size=256' %}

<div class="mt-4 text-sm text-gray-600">
  <nav aria-label="Breadcrumb" class="bg-white ring-1 ring-gray-200 rounded-xl shadow-sm px-4 py-2.5">
    <ol class="flex items-center gap-2">
      <li><a href="{{ core_url('') }}" class="text-[#1a252f] hover:text-blue-500 hover:underline">{{ core__('common.home') }}</a></li>
      <li class="text-gray-400">›</li>
      <li><a href="{{ core_url('member/' ~ (profile.username|e('url'))) }}" class="text-[#1a252f] hover:text-blue-500 hover:underline">{{ core_e(profile.username) }}</a></li>
      <li class="text-gray-400">›</li>
      <li class="text-gray-700 font-medium">{{ core__('profile.edit_page_title') }}</li>
    </ol>
  </nav>
</div>

<div class="mt-6 bg-white ring-1 ring-gray-200 shadow-md rounded-xl overflow-hidden">
  {# Kapak: profil sayfası ile aynı yapı #}
  <div class="relative overflow-hidden bg-gradient-to-r from-[#1a252f] to-[#2c3e50]" style="height: 208px;">
    <img id="profile-cover-preview" src="{{ coverUrl ? core_e(coverUrl) : '' }}" alt="" class="absolute inset-0 w-full h-full object-cover" style="width:100%;height:100%;object-fit:cover;display:block;{{ coverUrl ? '' : 'visibility:hidden;' }}">
    <div class="absolute top-3 right-3 flex gap-2">
      <label class="px-3 py-1.5 text-sm font-medium text-white bg-black/50 hover:bg-black/70 rounded-md backdrop-blur cursor-pointer">
        <input type="file" accept="image/*" id="cover-upload" class="hidden" data-upload-url="{{ core_e(core_url('profile/cover-upload')) }}" data-csrf="{{ core_e(core_csrf_token('profile_cover')) }}">
        <i class="fa-solid fa-image mr-1"></i>{{ core__('profile.edit_cover_upload') }}
      </label>
    </div>
  </div>

  {# Avatar: 160x160, yarısı kapakta; üzerinde fotoğraf yükle #}
  <div class="px-4 sm:px-6 lg:px-8 pb-6 relative">
    <div class="flex flex-col sm:flex-row sm:items-end gap-4" style="margin-top: -80px;">
      <div class="relative flex-shrink-0" style="width: 160px; height: 160px;">
        <img id="profile-avatar-preview" src="{{ core_e(avatarUrl) }}" alt="" class="rounded-2xl ring-4 ring-white shadow-xl bg-white" style="width: 160px; height: 160px; object-fit: cover; display: block; max-width: 160px; max-height: 160px;">
        <label class="absolute bottom-2 right-2 bg-[#1a252f] text-white rounded-full p-2 cursor-pointer hover:bg-[#172029] shadow-lg border-2 border-white" title="{{ core__('profile.edit_avatar_label') }}">
          <input type="file" accept="image/*" id="avatar-upload-input" class="hidden" data-url="{{ core_e(core_url('profile/avatar-upload')) }}">
          <i class="fa-solid fa-camera text-sm block w-5 h-5"></i>
        </label>
      </div>
      <div class="flex-1 min-w-0 pb-1">
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">
          <span class="inline-flex items-center px-4 py-2 rounded-xl bg-[#1a252f] text-white font-bold shadow-md">{{ core_e(profile.username) }}</span>
        </h1>
        <p class="text-gray-500 text-sm mt-2">{{ core__('profile.edit_page_title') }}</p>
      </div>
    </div>

    {% if success %}
      <div class="mt-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg text-sm">{{ core_e(success) }}</div>
    {% endif %}
    {% if error %}
      <div class="mt-4 bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg text-sm">{{ core_e(error) }}</div>
    {% endif %}

    <form action="{{ core_url('profile/update') }}" method="post" class="mt-8">
      {{ core_csrf_field('profile_edit')|raw }}

      {# Hesap bilgileri — tablo #}
      <section class="border-t border-gray-100 pt-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2"><i class="fa-regular fa-id-card text-gray-500"></i> {{ core__('profile.edit_section_account') }}</h2>
        <div class="bg-gray-50 rounded-xl overflow-hidden">
          <table class="w-full text-sm">
            <tr class="border-b border-gray-200 hover:bg-gray-50/80">
              <td class="py-3 px-4 text-gray-600 font-medium w-48 sm:w-56">{{ core__('profile.edit_username') }}</td>
              <td class="py-3 px-4 text-gray-900">
                <span class="font-medium">{{ core_e(profile.username) }}</span>
                <p class="text-xs text-gray-500 mt-0.5">{{ core__('profile.edit_username_readonly') }}</p>
              </td>
            </tr>
            <tr class="border-b border-gray-200 hover:bg-gray-50/80">
              <td class="py-3 px-4 text-gray-600 font-medium w-48 sm:w-56">{{ core__('profile.edit_email') }}</td>
              <td class="py-3 px-4">
                <input type="text" value="{{ core_e(profile.email ?? '') }}" class="w-full max-w-md border border-gray-200 rounded-lg bg-gray-100 px-3 py-2 text-gray-600" disabled>
                <p class="text-xs text-gray-500 mt-1">{{ core__('profile.edit_email_readonly') }}</p>
              </td>
            </tr>
          </table>
        </div>
      </section>

      {# Kişisel bilgiler — tablo #}
      <section class="border-t border-gray-100 pt-6 mt-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2"><i class="fa-regular fa-user text-gray-500"></i> {{ core__('profile.edit_section_personal') }}</h2>
        <div class="bg-gray-50 rounded-xl overflow-hidden">
          <table class="w-full text-sm">
            <tr class="border-b border-gray-200 hover:bg-gray-50/80">
              <td class="py-3 px-4 text-gray-600 font-medium w-48 sm:w-56 align-top pt-4">{{ core__('profile.edit_first_name') }}</td>
              <td class="py-3 px-4">
                <input type="text" name="first_name" id="first_name" value="{{ core_e(profile.first_name ?? '') }}" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#1a252f] focus:border-[#1a252f]" maxlength="128" placeholder="{{ core__('profile.edit_optional') }}">
              </td>
            </tr>
            <tr class="border-b border-gray-200 hover:bg-gray-50/80">
              <td class="py-3 px-4 text-gray-600 font-medium w-48 sm:w-56 align-top pt-4">{{ core__('profile.edit_last_name') }}</td>
              <td class="py-3 px-4">
                <input type="text" name="last_name" id="last_name" value="{{ core_e(profile.last_name ?? '') }}" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#1a252f] focus:border-[#1a252f]" maxlength="128" placeholder="{{ core__('profile.edit_optional') }}">
              </td>
            </tr>
            <tr class="border-b border-gray-200 hover:bg-gray-50/80">
              <td class="py-3 px-4 text-gray-600 font-medium w-48 sm:w-56"></td>
              <td class="py-3 px-4">
                <div class="flex items-center gap-2">
                  <input type="hidden" name="show_name" value="0">
                  <input type="checkbox" name="show_name" id="show_name" value="1"{% if profile.show_name %} checked{% endif %} class="rounded border-gray-300 text-[#1a252f] focus:ring-[#1a252f]">
                  <label for="show_name" class="text-gray-700">{{ core__('profile.edit_show_name_label') }}</label>
                </div>
              </td>
            </tr>
            <tr class="border-b border-gray-200 hover:bg-gray-50/80">
              <td class="py-3 px-4 text-gray-600 font-medium w-48 sm:w-56 align-top pt-4">{{ core__('profile.birthday') }}</td>
              <td class="py-3 px-4">
                <input type="date" name="birthday" id="birthday" value="{{ core_e(profile.birthday ?? '') }}" class="border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#1a252f] focus:border-[#1a252f]">
                <p class="text-xs text-gray-500 mt-1">{{ core__('profile.birthday_hint') }}</p>
              </td>
            </tr>
            <tr class="border-b border-gray-200 hover:bg-gray-50/80">
              <td class="py-3 px-4 text-gray-600 font-medium w-48 sm:w-56 align-top pt-4">{{ core__('profile.location') }}</td>
              <td class="py-3 px-4">
                <input type="text" name="location" id="location" value="{{ core_e(profile.location ?? '') }}" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#1a252f] focus:border-[#1a252f]" maxlength="128" placeholder="{{ core__('profile.edit_location_placeholder') }}">
              </td>
            </tr>
            <tr class="border-b border-gray-200 hover:bg-gray-50/80">
              <td class="py-3 px-4 text-gray-600 font-medium w-48 sm:w-56 align-top pt-4">{{ core__('profile.website') }}</td>
              <td class="py-3 px-4">
                <input type="url" name="website" id="website" value="{{ core_e(profile.website ?? '') }}" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#1a252f] focus:border-[#1a252f]" maxlength="255" placeholder="{{ core__('profile.edit_website_placeholder') }}">
              </td>
            </tr>
            <tr class="border-b border-gray-200 hover:bg-gray-50/80">
              <td class="py-3 px-4 text-gray-600 font-medium w-48 sm:w-56 align-top pt-4">{{ core__('profile.about') }}</td>
              <td class="py-3 px-4">
                <textarea name="bio" id="bio" rows="4" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#1a252f] focus:border-[#1a252f]" placeholder="{{ core__('profile.edit_bio_placeholder') }}">{{ core_e(profile.bio ?? '') }}</textarea>
              </td>
            </tr>
          </table>
        </div>
      </section>

      {# İmza — tablo #}
      <section class="border-t border-gray-100 pt-6 mt-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2"><i class="fa-solid fa-signature text-gray-500"></i> {{ core__('profile.edit_section_signature') }}</h2>
        <div class="bg-gray-50 rounded-xl overflow-hidden">
          <table class="w-full text-sm">
            <tr class="hover:bg-gray-50/80">
              <td class="py-3 px-4 text-gray-600 font-medium w-48 sm:w-56 align-top pt-4">{{ core__('profile.edit_signature_label') }}</td>
              <td class="py-3 px-4">
                <textarea name="signature" id="signature" rows="3" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#1a252f] focus:border-[#1a252f]" maxlength="500" placeholder="{{ core__('profile.edit_signature_placeholder') }}">{{ core_e(profile.signature ?? '') }}</textarea>
                <p class="text-xs text-gray-500 mt-1">{{ core__('profile.edit_signature_hint') }}</p>
              </td>
            </tr>
          </table>
        </div>
      </section>

      {# Özel alanlar — tablo #}
      {% for def in customDefinitions %}
      <section class="border-t border-gray-100 pt-6 mt-8">
        <div class="bg-gray-50 rounded-xl overflow-hidden">
          <table class="w-full text-sm">
            <tr class="hover:bg-gray-50/80">
              {% set fieldKey = def.field_key ?? '' %}
              {% set val = customValues[fieldKey] ?? '' %}
              <td class="py-3 px-4 text-gray-600 font-medium w-48 sm:w-56 align-top pt-4">{{ core_e(def.name ?? '') }}{% if def.is_required %} *{% endif %}</td>
              <td class="py-3 px-4">
                {% if (def.field_type ?? 'text') == 'textarea' %}
                  <textarea name="custom_{{ fieldKey|e }}" id="custom_{{ fieldKey|e }}" rows="3" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#1a252f] focus:border-[#1a252f]"{% if def.is_required %} required{% endif %}>{{ core_e(val) }}</textarea>
                {% elseif (def.field_type ?? '') == 'select' %}
                  {% set optsArr = (def.field_options ?? '[]')|json_decode_array %}
                  <select name="custom_{{ fieldKey|e }}" id="custom_{{ fieldKey|e }}" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#1a252f] focus:border-[#1a252f]"{% if def.is_required %} required{% endif %}>
                    <option value="">{{ core__('common.select_option') }}</option>
                    {% for opt in optsArr %}
                      <option value="{{ core_e(opt) }}"{% if val == opt %} selected{% endif %}>{{ core_e(opt) }}</option>
                    {% endfor %}
                  </select>
                {% else %}
                  {% set inputType = (def.field_type ?? '') == 'number' ? 'number' : ((def.field_type ?? '') == 'date' ? 'date' : 'text') %}
                  <input type="{{ inputType }}" name="custom_{{ fieldKey|e }}" id="custom_{{ fieldKey|e }}" value="{{ core_e(val) }}" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#1a252f] focus:border-[#1a252f]"{% if def.is_required %} required{% endif %}>
                {% endif %}
              </td>
            </tr>
          </table>
        </div>
      </section>
      {% endfor %}

      <div class="flex flex-wrap gap-3 pt-6 mt-8 border-t border-gray-100">
        <button type="submit" class="px-5 py-2.5 text-sm font-medium text-white bg-[#1a252f] rounded-lg hover:bg-[#172029] shadow-sm">{{ core__('profile.edit_save') }}</button>
        <a href="{{ core_url('member/' ~ (profile.username|e('url'))) }}" class="px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">{{ core__('common.cancel') }}</a>
        <a href="{{ core_url('profile/password') }}" class="px-5 py-2.5 text-sm font-medium text-gray-600 hover:text-[#1a252f] hover:underline">{{ core__('profile.password_change_link') }}</a>
        <a href="{{ core_url('profile/account') }}" class="px-5 py-2.5 text-sm font-medium text-amber-600 hover:text-amber-700 hover:underline">{{ lang('profile.account_link') }}</a>
      </div>
    </form>
  </div>
</div>

<p id="avatar-upload-status" class="mt-2 text-sm text-gray-500 hidden"></p>
{% endif %}
{% endblock %}
