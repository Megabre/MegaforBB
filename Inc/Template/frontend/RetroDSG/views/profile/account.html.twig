{% extends 'base.html.twig' %}

{% block content %}
{% set error = error ?? '' %}
{% set success = success ?? '' %}
{% set close_confirm_phrase = close_confirm_phrase ?? 'KAPAT' %}

<div class="mt-4 text-sm text-gray-600">
  <nav aria-label="Breadcrumb" class="bg-white border border-gray-200 rounded-md shadow-sm px-4 py-2">
    <ol class="flex items-center gap-2">
      <li><a href="{{ core_url('') }}" class="text-[#1a252f] hover:text-blue-500 hover:underline">{{ core__('common.home') }}</a></li>
      <li>›</li>
      <li><a href="{{ core_url('profile/edit') }}" class="text-[#1a252f] hover:text-blue-500 hover:underline">{{ core__('profile.edit_link') }}</a></li>
      <li>›</li>
      <li class="text-gray-700">{{ lang('profile.account_page_title') }}</li>
    </ol>
  </nav>
</div>

<div class="mt-6 max-w-2xl space-y-6">
  {% if success %}
  <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-md text-sm">{{ core_e(success) }}</div>
  {% endif %}
  {% if error %}
  <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-md text-sm">{{ core_e(error) }}</div>
  {% endif %}

  {# Hesabı askıya al #}
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <div class="border-b border-gray-200 bg-amber-50 px-6 py-4">
      <h2 class="text-lg font-semibold text-[#1a252f] flex items-center gap-2"><i class="fa-solid fa-pause-circle text-amber-600"></i> {{ lang('profile.suspend_title') }}</h2>
      <p class="text-sm text-gray-600 mt-1">{{ lang('profile.suspend_description') }}</p>
    </div>
    <div class="p-6">
      <form action="{{ core_url('profile/suspend-account') }}" method="post" class="space-y-4" id="form-suspend">
        {{ core_csrf_field('profile_account')|raw }}
        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-1">{{ lang('profile.current_password') }}</label>
          <input type="password" name="password" id="password" class="w-full border border-gray-300 rounded-md shadow-sm px-3 py-2" required autocomplete="current-password">
        </div>
        <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-amber-600 hover:bg-amber-700 rounded-md">{{ lang('profile.suspend_button') }}</button>
      </form>
    </div>
  </div>

  {# Hesabı kalıcı kapat #}
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <div class="border-b border-gray-200 bg-red-50 px-6 py-4">
      <h2 class="text-lg font-semibold text-[#1a252f] flex items-center gap-2"><i class="fa-solid fa-times-circle text-red-600"></i> {{ lang('profile.close_title') }}</h2>
      <p class="text-sm text-gray-600 mt-1">{{ lang('profile.close_description') }}</p>
    </div>
    <div class="p-6">
      <form action="{{ core_url('profile/close-account') }}" method="post" class="space-y-4" id="form-close-account">
        {{ core_csrf_field('profile_account')|raw }}
        <div>
          <label for="password_close" class="block text-sm font-medium text-gray-700 mb-1">{{ lang('profile.current_password') }}</label>
          <input type="password" name="password_close" id="password_close" class="w-full border border-gray-300 rounded-md shadow-sm px-3 py-2" required autocomplete="current-password">
        </div>
        <div>
          <label for="close_confirm" class="block text-sm font-medium text-gray-700 mb-1">{{ lang('profile.close_confirm_label', {'phrase': close_confirm_phrase}) }}</label>
          <input type="text" name="close_confirm" id="close_confirm" class="w-full border border-gray-300 rounded-md shadow-sm px-3 py-2" placeholder="{{ core_e(close_confirm_phrase) }}" required autocomplete="off">
        </div>
        <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-md">{{ lang('profile.close_button') }}</button>
      </form>
    </div>
  </div>

  <p class="text-sm text-gray-500"><a href="{{ core_url('profile/edit') }}" class="text-[#1a252f] hover:underline">{{ core__('common.cancel') }}</a></p>
</div>

<script>
document.getElementById('form-suspend')?.addEventListener('submit', function(e) {
  if (!confirm({{ lang('profile.suspend_confirm_question')|json_encode }})) e.preventDefault();
});
document.getElementById('form-close-account')?.addEventListener('submit', function(e) {
  if (!confirm({{ lang('profile.close_confirm_question')|json_encode }})) e.preventDefault();
});
</script>
{% endblock %}
