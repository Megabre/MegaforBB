{% extends 'base.html.twig' %}

{% block content %}
{% set error = error ?? '' %}
{% set success = success ?? '' %}
{% set captcha_show = captcha_show ?? false %}

<div class="min-h-[60vh] flex items-center justify-center">
  <div class="w-full max-w-3xl bg-white ring-1 ring-gray-200 shadow-sm rounded-lg overflow-hidden grid grid-cols-1 md:grid-cols-2">
    <div class="bg-[#1a252f] text-white p-6 flex flex-col justify-between">
      <div>
        <div class="text-lg font-semibold">{{ core__('common.site_name') }}</div>
        <div class="text-sm text-gray-200 mt-1">Topluluğa giriş yap ve güncellemeleri takip et.</div>
        <ul class="mt-4 space-y-2 text-sm">
          <li class="flex items-center gap-2"><i class="fa-solid fa-circle-check text-blue-300"></i>Özel içeriklere erişim</li>
          <li class="flex items-center gap-2"><i class="fa-solid fa-circle-check text-blue-300"></i>Favori konuları takip et</li>
          <li class="flex items-center gap-2"><i class="fa-solid fa-circle-check text-blue-300"></i>Bildirimleri yönet</li>
        </ul>
      </div>
      <div class="text-xs text-gray-300">© {{ "now"|date("Y") }} {{ core__('common.site_name') }}</div>
    </div>
    <div class="p-6 space-y-4">
      <div class="text-lg font-semibold text-[#1a252f]">{{ core__('auth.login_title') }}</div>
      {% if error %}
      <div class="p-3 rounded-md bg-red-50 border border-red-200 text-red-700 text-sm">{{ core_e(error) }}</div>
      {% if flash('auth_show_reactivate') %}
      <p class="mt-2 text-sm text-gray-600">{{ lang('auth.reactivate_login_hint') }} <a href="{{ core_url('reactivate-account') }}" class="text-[#1a252f] font-medium hover:underline">{{ lang('auth.reactivate_link') }}</a></p>
      {% endif %}
      {% endif %}
      {% if success %}
      <div class="p-3 rounded-md bg-green-50 border border-green-200 text-green-700 text-sm">{{ core_e(success) }}</div>
      {% endif %}
      <form method="post" action="{{ core_url('login') }}">
        {{ core_csrf_field('login')|raw }}
        <div class="mb-4">
          <label class="block text-sm font-medium text-[#1a252f] mb-1">{{ core__('auth.username_email') }}</label>
          <input name="login" type="text" class="w-full border border-gray-300 rounded-md px-3 py-2 outline-none focus:ring-2 focus:ring-blue-200" placeholder="kullanici@ornek.com">
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-[#1a252f] mb-1">{{ core__('auth.password') }}</label>
          <input name="password" type="password" class="w-full border border-gray-300 rounded-md px-3 py-2 outline-none focus:ring-2 focus:ring-blue-200" placeholder="••••••••">
        </div>
        {% if captcha_show %}{% include 'partials/captcha.html.twig' %}{% endif %}
        <div class="flex items-center justify-between mb-4">
          <label class="inline-flex items-center text-sm text-gray-700"><input name="remember" type="checkbox" class="mr-2"> {{ core__('auth.remember') }}</label>
          <a href="{{ core_url('forgot-password') }}" class="text-sm text-blue-600 hover:underline">{{ core__('auth.forgot_password') }}</a>
        </div>
        <button type="submit" class="w-full text-white bg-[#1a252f] hover:bg-[#172029] rounded-md px-4 py-2">{{ core__('auth.login_title') }}</button>
      </form>
      <div class="text-sm text-gray-600 text-center">{{ core__('auth.no_account') }} <a href="{{ core_url('register') }}" class="text-blue-600 hover:underline">{{ core__('common.register') }}</a></div>
      <div class="text-center"><a href="{{ core_url('') }}" class="text-sm text-gray-600 hover:underline">{{ core__('common.home') }}</a></div>
    </div>
  </div>
</div>
{% endblock %}
