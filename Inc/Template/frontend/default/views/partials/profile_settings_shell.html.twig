{# Profil düzenleme sayfaları — IPS kabuğu + ayar sekmeleri #}
{% set u = user ?? profile ?? null %}
{% set active = active ?? 'edit' %}
{% set coverUrl = coverUrl ?? null %}
{% set avatarUrl = avatarUrl ?? '' %}
{% if u %}
{% set coverUrl = coverUrl ?? (u.cover_photo_path is not empty ? asset_url(u.cover_photo_path) : null) %}
{% set avatarUrl = avatarUrl != '' ? avatarUrl : (u.avatar_path is not empty ? asset_url(u.avatar_path) : 'https://ui-avatars.com/api/?name=' ~ (avatar_display_name(u.username ?? '')|url_encode) ~ '&size=256') %}

<div class="ips-profile-wrap ips-profile-wrap--settings">
  <div class="ips-profile ips-profile--compact ips-profile--settings">
    <div class="ips-profile__cover">
      {% if coverUrl %}
        <img id="profile-cover-preview" src="{{ core_e(coverUrl) }}" alt="" class="ips-profile__cover-img">
      {% endif %}
      {% if active == 'edit' %}
      <div class="ips-profile__cover-tools">
        <label class="ips-profile__cover-btn cursor-pointer">
          <input type="file" accept="image/*" id="cover-upload" class="hidden" data-upload-url="{{ core_e(core_url('profile/cover-upload')) }}" data-csrf="{{ core_e(core_csrf_token('profile_cover')) }}">
          <i class="fa-solid fa-camera"></i>
        </label>
      </div>
      {% endif %}
    </div>
    <div class="ips-profile__header">
      <div class="ips-profile__header-main">
        <div class="ips-profile__avatar-wrap">
          {% if active == 'edit' %}
          <div class="ips-profile-avatar-edit">
            <img id="profile-avatar-preview" src="{{ core_e(avatarUrl) }}" alt="" class="ips-profile__avatar">
            <label class="ips-profile-avatar-edit__btn" title="{{ core__('profile.edit_avatar_label') }}">
              <input type="file" accept="image/*" id="avatar-upload-input" class="hidden" data-url="{{ core_e(core_url('profile/avatar-upload')) }}">
              <i class="fa-solid fa-camera text-xs"></i>
            </label>
          </div>
          {% else %}
          <img src="{{ core_e(avatarUrl) }}" alt="" class="ips-profile__avatar">
          {% endif %}
        </div>
        <div class="ips-profile__identity">
          <h1 class="ips-profile__username">{{ core_e(u.username) }}</h1>
          <p class="ips-profile__title">{{ core__('profile.edit_settings_title') }}</p>
        </div>
      </div>
      <div class="ips-profile__actions">
        <a href="{{ core_url('member/' ~ (u.username|e('url'))) }}" class="ips-profile__action-btn"><i class="fa-solid fa-arrow-left"></i> {{ core__('common.profile') }}</a>
      </div>
    </div>
  </div>

  <nav class="ips-profile-settings-tabs" aria-label="{{ core__('profile.edit_settings_title') }}">
    <a href="{{ core_url('profile/edit') }}" class="ips-profile-settings-tabs__item{% if active == 'edit' %} is-active{% endif %}"><i class="fa-solid fa-user-pen"></i> {{ core__('profile.edit_page_title') }}</a>
    <a href="{{ core_url('profile/password') }}" class="ips-profile-settings-tabs__item{% if active == 'password' %} is-active{% endif %}"><i class="fa-solid fa-key"></i> {{ core__('profile.password_change_link') }}</a>
    <a href="{{ core_url('profile/preferences') }}" class="ips-profile-settings-tabs__item{% if active == 'preferences' %} is-active{% endif %}"><i class="fa-solid fa-sliders"></i> {{ core__('profile.preferences_title') }}</a>
    <a href="{{ core_url('profile/account') }}" class="ips-profile-settings-tabs__item{% if active == 'account' %} is-active{% endif %}"><i class="fa-solid fa-shield-halved"></i> {{ lang('profile.account_link') }}</a>
  </nav>
</div>
{% endif %}
