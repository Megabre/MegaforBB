{# Mobil konu kartı — durum şeridi + yazar | başlık; altta son yorum özeti #}
{% set is_sticky = topic_row_theme|default('default') == 'sticky' %}
{% set author = t.user %}
{% set authorName = author ? author.username : '?' %}
{% set lastUser = t.lastPostUser ?? author %}
{% set lastName = lastUser ? lastUser.username : authorName %}
{% set ring_av = is_sticky ? 'border-amber-200' : 'border-gray-200' %}
{% set border_b = is_sticky ? 'border-amber-200/50' : 'border-gray-100' %}
{% set authorBanned = author and (author.is_banned|default(false)) %}
{% set authorAvatarUrl = authorBanned ? banned_avatar_url() : (author and (author.avatar_path|default('')) != '' ? asset_url(author.avatar_path) : ('https://ui-avatars.com/api/?name=' ~ avatar_display_name(authorName)|url_encode ~ '&size=64&background=1a252f&color=ffffff')) %}
{% set lastBanned = lastUser and (lastUser.is_banned|default(false)) %}
{% set lastAvatarUrl = lastBanned ? banned_avatar_url() : (lastUser and (lastUser.avatar_path|default('')) != '' ? asset_url(lastUser.avatar_path) : ('https://ui-avatars.com/api/?name=' ~ avatar_display_name(lastName)|url_encode ~ '&size=64&background=1a252f&color=ffffff')) %}
{% set goto_last = (t.last_post_at ?? '') and (t.last_post_id ?? '') %}
{% set topic_href = core_url('topic/' ~ topic_url_path(t)) %}
{% set last_href = topic_href ~ (goto_last ? '#post-' ~ t.last_post_id : '') %}
{% set lastAt = t.last_post_at ?? t.created_at %}
{% set row_unread = user and (t.is_unread ?? false) %}
{% set has_reply = t.viewer_has_replied ?? false %}
<article class="relative pl-1 border-b {{ border_b }} {{ is_sticky ? 'bg-amber-50/40 active:bg-amber-50/60' : 'bg-white active:bg-gray-50' }} {{ row_unread ? 'bg-amber-50/40' : '' }} max-w-full">
  {% if user %}
  <div class="absolute left-0 top-0 bottom-0 w-1 rounded-r {{ row_unread ? 'bg-amber-500' : 'bg-emerald-500' }}" aria-hidden="true"></div>
  {% endif %}
  <div class="px-3 py-3 pl-3.5">
  <div class="flex gap-3 max-w-full min-w-0">
    <a href="{{ topic_href }}" class="shrink-0 pt-0.5 rounded-full focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1" aria-label="{{ core_e(authorName) }}">
      <img class="w-11 h-11 rounded-full object-cover border {{ ring_av }}" src="{{ core_e(authorAvatarUrl) }}" alt="" width="44" height="44" loading="lazy">
    </a>
    <div class="min-w-0 flex-1 overflow-hidden">
      <a href="{{ topic_href }}" class="block no-underline text-inherit max-w-full">
        <p class="m-0 text-[15px] leading-snug text-[#1a252f] break-words hyphens-auto flex items-start gap-2">
          {% if user %}
          <span class="mfbb-topic-read-frame mfbb-topic-read-frame--sm relative shrink-0 mt-0.5 inline-flex items-center justify-center w-7 h-7 rounded-md border {{ row_unread ? 'bg-amber-100 text-amber-800 border-amber-400/90' : 'bg-emerald-50 text-emerald-600 border-emerald-400/70' }}" title="{{ row_unread ? core__('forum.topic_read_state_unread') : core__('forum.topic_read_state_read') }}{{ has_reply ? ' · ' ~ core__('forum.topic_viewer_replied_badge') : '' }}">
            <i class="{{ row_unread ? 'fa-regular fa-eye-slash text-[12px]' : 'fa-solid fa-eye text-[11px]' }}" aria-hidden="true"></i>
            {% if has_reply %}<span class="mfbb-topic-replied-mark" title="{{ core__('forum.topic_viewer_replied_badge')|e('html_attr') }}"><i class="fa-solid fa-reply" aria-hidden="true"></i></span>{% endif %}
          </span>
          {% endif %}
          <span class="min-w-0 flex-1">
          {% if (t.is_private ?? 0) == 1 %}<i class="fa-solid fa-lock text-amber-500 text-sm mr-1 align-middle shrink-0" title="{{ core__('topic.private_topic')|e('html_attr') }}"></i>{% endif %}
          {% if t.prefix %}<span class="inline-block align-middle mr-1.5 mb-0.5 max-w-full">{% include 'partials/topic_prefix_badge.html.twig' with { prefix_name: t.prefix.name, prefix_css_class: t.prefix.css_class, prefix_badge_bg: t.prefix.badge_bg|default(''), prefix_badge_text: t.prefix.badge_text|default(''), prefix_icon_class: t.prefix.icon_class|default('') } only %}</span>{% endif %}
          <span class="font-semibold align-middle {{ row_unread ? 'text-[#0f172a]' : '' }}">{{ core_e(t.title ?? '') }}</span>
          {% if (t.status ?? '') == 'scheduled' and (t.scheduled_remaining_text ?? '') != '' %}<span class="inline-block align-middle ml-1 text-xs font-normal text-amber-800 bg-amber-100 px-1.5 py-0.5 rounded whitespace-normal">{{ core__('topic.scheduled_badge') }} {{ t.scheduled_remaining_text }}</span>{% endif %}
          </span>
        </p>
        <p class="text-xs text-gray-500 mt-1.5 m-0 truncate max-w-full">{{ core_e(authorName) }} · {{ core_e(t.created_at ?? '') }}</p>
      </a>
    </div>
  </div>
  <div class="mt-3 flex items-stretch justify-between gap-3 border-t {{ border_b }} pt-2.5 min-w-0">
    {% if goto_last %}
    <a href="{{ core_e(last_href) }}" class="flex items-center gap-2.5 min-w-0 flex-1 no-underline text-inherit rounded-lg -mx-1 px-1 py-0.5 hover:bg-slate-50 active:bg-slate-100">
      <img class="w-9 h-9 rounded-full object-cover border {{ ring_av }} shrink-0" src="{{ core_e(lastAvatarUrl) }}" alt="" width="36" height="36" loading="lazy">
      <div class="min-w-0 text-left">
        <div class="text-[10px] font-semibold uppercase tracking-wide text-slate-500">{{ core__('forum.topic_list_th_last_reply') }}</div>
        <div class="text-[11px] text-slate-600 tabular-nums">{{ lastAt ? lastAt|date('d-m-Y H:i:s') : '—' }}</div>
        <div class="text-sm font-semibold text-[#1a252f] truncate">{{ core_e(lastName) }}</div>
      </div>
    </a>
    {% else %}
    <div class="flex items-center gap-2.5 opacity-60 min-w-0 flex-1">
      <img class="w-9 h-9 rounded-full object-cover border border-dashed {{ ring_av }} grayscale shrink-0" src="{{ core_e(lastAvatarUrl) }}" alt="" width="36" height="36" loading="lazy">
      <div class="min-w-0 text-left">
        <div class="text-[10px] text-slate-400 uppercase">{{ core__('forum.topic_list_th_last_reply') }}</div>
        <div class="text-xs text-slate-500">{{ core__('forum.no_messages_yet') }}</div>
      </div>
    </div>
    {% endif %}
    <div class="flex shrink-0 gap-5 sm:gap-8 self-center">
      <div class="text-center min-w-[3.25rem]">
        <div class="text-[10px] font-semibold uppercase tracking-wide text-gray-500 leading-tight">{{ core__('forum.topic_list_th_replies') }}</div>
        <div class="text-sm font-bold tabular-nums text-[#1a252f]">{{ (t.reply_count ?? 0)|number_format(0, ',', '.') }}</div>
      </div>
      <div class="text-center min-w-[3.5rem]">
        <div class="text-[10px] font-semibold uppercase tracking-wide text-gray-500 leading-tight">{{ core__('forum.topic_list_th_views') }}</div>
        <div class="text-sm font-bold tabular-nums text-[#1a252f]">{{ (t.view_count ?? 0)|number_format(0, ',', '.') }}</div>
      </div>
    </div>
  </div>
  </div>
</article>
