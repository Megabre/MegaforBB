{% if currentUser %}
<div class="flex items-center gap-2 sm:gap-3" id="ajax-user-nav-loaded">
{% if notificationsEnabled %}
<div class="hidden md:block relative">
    <button type="button" class="inline-flex relative items-center justify-center h-9 w-9 rounded-md border border-white hover:bg-white hover:text-[#1a252f]"
    @click.stop="openNotifications = !openNotifications; if (openNotifications) loadNotificationDropdown()"
    aria-haspopup="true" :aria-expanded="openNotifications">
    <i class="fa-regular fa-bell"></i>
    <span x-show="badges.notifications > 0" x-text="badges.notifications > 99 ? '99+' : badges.notifications" class="absolute -top-0.5 -right-0.5 min-w-[18px] h-[18px] flex items-center justify-center bg-red-500 text-white text-xs font-bold rounded-full" style="display: none;"></span>
    </button>
    <div class="absolute right-0 mt-2 w-80 bg-white text-[#1a252f] border border-gray-200 rounded-lg shadow-lg z-50 overflow-hidden"
    x-show="openNotifications"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 scale-95"
    x-transition:enter-end="opacity-100 scale-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 scale-100"
    x-transition:leave-end="opacity-0 scale-95"
    @click.outside="openNotifications = false">
    <div class="px-4 py-3 border-b border-gray-200 font-semibold text-gray-800 flex items-center justify-between">
        <span>{{ core__('common.notifications') }}</span>
        <span x-show="badges.notifications > 0" x-text="badges.notifications + ' yeni'" class="text-xs font-normal text-red-600"></span>
    </div>
    <div class="max-h-72 overflow-y-auto">
        <template x-if="notificationList.length === 0">
        <div class="px-4 py-6 text-center text-gray-500 text-sm">Bildirim yok</div>
        </template>
        <template x-if="notificationList.length > 0">
        <ul class="divide-y divide-gray-100">
            <template x-for="n in notificationList" :key="n.id">
            <li>
                <a :href="n.read_url" class="flex items-start gap-3 px-4 py-3 hover:bg-gray-50 block text-left">
                <span class="mt-1.5 w-2 h-2 rounded-full flex-shrink-0" :class="n.unread ? 'bg-blue-500' : 'bg-transparent'" aria-hidden="true"></span>
                <div class="min-w-0 flex-1">
                    <span class="text-sm font-medium text-gray-800" x-text="n.from_username ? n.from_username + ' — ' + n.label : n.label"></span>
                    <div class="text-xs text-gray-500 mt-0.5" x-text="n.created_at"></div>
                </div>
                </a>
            </li>
            </template>
        </ul>
        </template>
    </div>
    <div class="border-t border-gray-200 bg-gray-50 px-4 py-2 space-y-2">
        <button type="button"
        x-show="badges.notifications > 0"
        @click="markAllNotificationsRead()"
        :disabled="markAllReadLoading"
        class="w-full text-center text-sm font-medium text-[#1a252f] hover:text-[#172029] py-2 disabled:opacity-50">
        <span x-text="markAllReadLoading ? '...' : '{{ core__('notification.mark_all_read')|e('js') }}'"></span>
        </button>
        <a href="{{ core_url('notifications') }}" class="block text-center text-sm font-medium text-[#1a252f] hover:text-[#172029] py-2">{{ core__('notification.view_all') }}</a>
    </div>
    </div>
</div>
{% endif %}
{% if messagesEnabled %}
<a href="{{ core_url('conversations') }}" class="hidden md:inline-flex relative items-center justify-center h-9 w-9 rounded-md border border-white hover:bg-white hover:text-[#1a252f]" id="header-messages">
    <i class="fa-regular fa-envelope"></i>
    <span x-show="badges.messages > 0" x-text="badges.messages > 99 ? '99+' : badges.messages" class="absolute -top-0.5 -right-0.5 min-w-[18px] h-[18px] flex items-center justify-center bg-red-500 text-white text-xs font-bold rounded-full" style="display: none;"></span>
</a>
{% endif %}
<div class="relative">
    <button class="flex items-center gap-2 px-2 md:px-3 py-1.5 text-sm border border-white rounded-md hover:bg-white hover:text-[#1a252f]" @click.stop="openUser=!openUser" title="{{ core_e(currentUser.username) }}">
    <img src="{{ currentUser.avatar_path is not empty ? core_e(asset_url(currentUser.avatar_path)) : 'https://ui-avatars.com/api/?name=' ~ avatar_display_name(currentUser.username)|url_encode }}" class="h-8 w-8 md:h-6 md:w-6 rounded-full border border-white object-cover" alt="">
    <span class="hidden md:inline">{{ core_e(currentUser.username) }}</span>
    </button>
    <div class="absolute right-0 mt-2 w-56 bg-white text-[#1a252f] border border-gray-200 rounded-md shadow-lg z-50"
    x-show="openUser"
    x-cloak
    @click.outside="openUser=false">
    <a href="{{ core_url('notifications') }}" class="block px-4 py-2 hover:bg-gray-100">{{ core_e(core__('common.notifications')) }}</a>
    <a href="{{ core_url('conversations') }}" class="block px-4 py-2 hover:bg-gray-100">{{ core_e(core__('common.messages')) }}</a>
    <a href="{{ core_url('member/' ~ currentUser.username|e('url')) }}" class="block px-4 py-2 hover:bg-gray-100">{{ core_e(core__('common.profile')) }}</a>
    <a href="{{ core_url('profile/preferences') }}" class="block px-4 py-2 hover:bg-gray-100">{{ core_e(core__('common.preferences')) }}</a>
    <div class="border-t border-gray-200"></div>
    <form action="{{ core_url('logout') }}" method="post" class="block">
        {{ core_csrf_field()|raw }}
        <button type="submit" class="w-full text-left px-4 py-2 hover:bg-gray-100 text-[#1a252f]">{{ core_e(core__('common.logout')) }}</button>
    </form>
    </div>
</div>
</div>
{% endif %}
