{% extends 'base.html.twig' %}

{% block content %}
<div class="min-h-[40vh] flex items-center justify-center px-4">
  <div class="text-center">
    <img src="{{ theme_asset_url('images/lost.gif') }}" alt="" class="mx-auto w-48 h-48 object-contain rounded-lg mb-4" width="192" height="192" loading="eager">
    <h1 class="text-2xl font-bold text-[#1a252f]">{{ core__('error.404_title') }}</h1>
    <p class="text-gray-600 mt-2">{{ core__('error.404_message') }}</p>
    <a href="{{ core_url('') }}" class="inline-block mt-4 px-4 py-2 bg-[#1a252f] text-white rounded-md hover:bg-[#172029]">{{ core__('error.404_home') }}</a>
  </div>
</div>
{% endblock %}
