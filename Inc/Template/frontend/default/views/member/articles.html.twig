{% extends 'base.html.twig' %}
{% block content %}
{% set profileUser = profileUser ?? null %}
{% if not profileUser %}<div class="ips-profile-page"><div class="ips-profile-empty"><p>{{ core_e(lang('error.not_found')) }}</p></div></div>
{% else %}
{% set baseUrl = core_url('member/' ~ member_url_path(profileUser)) %}
{% set items = items ?? [] %}
{% set userStats = userStats ?? {} %}
{% set isOwnProfile = user and profileUser and user.id is defined and profileUser.id is defined and user.id == profileUser.id %}
{% set avatarUrl = profileUser.avatar_path is not empty ? asset_url(profileUser.avatar_path) : 'https://ui-avatars.com/api/?name=' ~ avatar_display_name(profileUser.username ?? null)|url_encode %}
<div class="ips-profile-page">
{% include 'partials/profile_breadcrumb.html.twig' with { crumbs: [{ label: profileUser.username, href: baseUrl }, { label: core__('article.articles') }] } %}
<div class="ips-profile-wrap">
  {% include 'partials/profile_shell.html.twig' with { profileUser: profileUser, isOwnProfile: isOwnProfile, coverUrl: null, avatarUrl: avatarUrl, rewardLevel: null, userStats: userStats, activeTab: 'activity', compact: true, reputationEnabled: reputationEnabled ?? true, idelistEnabled: idelistEnabled ?? false } %}
  <div class="ips-profile-layout">
    <div class="ips-profile-layout__main">
      {% include 'partials/profile_activity_subnav.html.twig' with { profileUser: profileUser, activityFilter: 'articles', idelistEnabled: idelistEnabled ?? false } %}
      <div class="ips-profile-panel__body">
        {% if items is empty %}<p class="ips-profile-empty-text">{{ core__('member.contributions_articles_empty') }}</p>
        {% else %}<ul class="ips-profile-feed">{% for a in items %}<li class="ips-profile-feed__item"><div class="ips-profile-feed__meta"><span>{{ core_e(a.created_at ?? '') }}</span>{% if a.view_count %}<span>{{ a.view_count }} görüntülenme</span>{% endif %}</div><a href="{{ a.url ?? core_url('articles/' ~ article_url_path_by_id(a.id ?? 0)) }}" class="ips-profile-feed__title">{{ core_e(a.title ?? '') }}</a></li>{% endfor %}</ul>{% endif %}
      </div>
    </div>
    <aside class="ips-profile-layout__side">
      {% include 'partials/profile_sidebar_card.html.twig' with { profileUser: profileUser, userStats: userStats, rewardLevel: rewardLevel ?? null, isOwnProfile: isOwnProfile ?? false, reputationEnabled: reputationEnabled ?? true } %}
    </aside>
  </div>
</div></div>
{% endif %}
{% endblock %}
