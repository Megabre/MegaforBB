{% set stats = stats ?? { total_topics: 0, total_posts: 0, total_members: 0, last_member_username: null } %}
{% set siteName = site_name ?? core_config('app.name', 'MegaforBB') %}
{% set logoUrl = forum_logo_url ?? '' %}
{% set currentUser = user ?? null %}
{% set showSiteName = show_site_title_next_to_logo ?? true %}
  <footer class="mt-auto w-full border-t border-gray-200 shrink-0">
    <div class="w-full bg-[#1a252f] text-gray-300">
      <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
            <div>
              <div class="flex items-center gap-3 mb-3">
                {% if logoUrl is not empty %}
                <img src="{{ core_e(logoUrl) }}" alt="" class="h-8 w-auto max-w-[120px] object-contain opacity-90">
                {% else %}
                <div class="h-9 w-9 rounded-lg bg-white/10 flex items-center justify-center">
                  <i class="fa-solid fa-comments text-white text-lg"></i>
                </div>
                {% endif %}
                {% if logoUrl is empty or showSiteName %}
                <span class="text-white font-bold text-lg">{{ core_e(siteName) }}</span>
                {% endif %}
              </div>
              <p class="text-sm text-gray-400 leading-relaxed">
                {{ (seo_description is defined and seo_description is not empty) ? core_e(seo_description) : core__('footer.default_description') }}
              </p>
              {% if social_show_footer and (social_facebook or social_twitter or social_instagram or social_youtube or social_linkedin) %}
              <div class="flex items-center gap-3 mt-4">
                {% if social_facebook %}<a href="{{ core_e(social_facebook) }}" target="_blank" rel="noopener" class="h-9 w-9 rounded-lg bg-white/10 hover:bg-[#1877F2] flex items-center justify-center transition-colors" title="Facebook"><i class="fa-brands fa-facebook-f text-white text-sm"></i></a>{% endif %}
                {% if social_twitter %}<a href="{{ core_e(social_twitter) }}" target="_blank" rel="noopener" class="h-9 w-9 rounded-lg bg-white/10 hover:bg-[#1DA1F2] flex items-center justify-center transition-colors" title="Twitter"><i class="fa-brands fa-twitter text-white text-sm"></i></a>{% endif %}
                {% if social_instagram %}<a href="{{ core_e(social_instagram) }}" target="_blank" rel="noopener" class="h-9 w-9 rounded-lg bg-white/10 hover:bg-[#E4405F] flex items-center justify-center transition-colors" title="Instagram"><i class="fa-brands fa-instagram text-white text-sm"></i></a>{% endif %}
                {% if social_youtube %}<a href="{{ core_e(social_youtube) }}" target="_blank" rel="noopener" class="h-9 w-9 rounded-lg bg-white/10 hover:bg-[#FF0000] flex items-center justify-center transition-colors" title="YouTube"><i class="fa-brands fa-youtube text-white text-sm"></i></a>{% endif %}
                {% if social_linkedin %}<a href="{{ core_e(social_linkedin) }}" target="_blank" rel="noopener" class="h-9 w-9 rounded-lg bg-white/10 hover:bg-[#0A66C2] flex items-center justify-center transition-colors" title="LinkedIn"><i class="fa-brands fa-linkedin-in text-white text-sm"></i></a>{% endif %}
              </div>
              {% endif %}
              <div class="flex flex-col sm:flex-row sm:items-center gap-3 mt-4">
                <img src="{{ core_url('img/turkey.png') }}" alt="{{ core__('footer.made_in_turkey_alt') }}" class="h-10 w-auto max-w-[132px] object-contain shrink-0 opacity-95" loading="lazy" width="132" height="44">
                <div class="text-[11px] sm:text-xs text-gray-400 leading-snug space-y-1">
                  <p class="font-semibold text-gray-200 tracking-wide">{{ core__('footer.made_in_turkey_badge') }}</p>
                  <p>{{ core__('footer.made_in_turkey_description') }}</p>
                </div>
              </div>
            </div>
            <div>
              <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">{{ core__('footer.quick_links') }}</h4>
              <ul class="space-y-2.5 text-sm">
                {% for item in (footer_quick_links_items ?? []) %}
                {% if item.url != 'profile/edit' or currentUser %}
                <li>
                  <a href="{{ core_e(item.href ?? '#') }}" class="text-gray-400 hover:text-white transition-colors flex items-center gap-2">
                    {% if item.icon is not empty %}<i class="{{ core_e(item.icon) }} w-4 text-center text-xs"></i>{% endif %}
                    {{ core_e(item.label ?? '') }}
                  </a>
                </li>
                {% endif %}
                {% endfor %}
              </ul>
            </div>
            
            {# ── İstatistik (3. Kolon) ── #}
            <div class="bg-white/[0.04] border border-white/10 rounded-xl px-5 py-4 flex flex-col h-full">
              <div class="flex items-center gap-2 mb-3">
                <div class="h-7 w-7 rounded-lg bg-blue-500/15 flex items-center justify-center">
                  <i class="fa-solid fa-chart-line text-blue-400 text-xs"></i>
                </div>
                <h4 class="text-white font-semibold text-xs uppercase tracking-wider">{{ core__('footer.statistics') }}</h4>
              </div>
              <div class="flex-grow">
                <table class="w-full text-sm">
                  <tbody>
                    <tr>
                      <td class="text-gray-400 py-1.5"><i class="fa-solid fa-folder-open w-4 text-center text-xs text-gray-500 mr-1.5"></i>{{ core__('footer.topics') }}</td>
                      <td class="text-white font-semibold text-right py-1.5">{{ (stats.total_topics ?? 0)|number_format(0) }}</td>
                    </tr>
                    <tr>
                      <td class="text-gray-400 py-1.5"><i class="fa-solid fa-message w-4 text-center text-xs text-gray-500 mr-1.5"></i>{{ core__('footer.posts') }}</td>
                      <td class="text-white font-semibold text-right py-1.5">{{ (stats.total_posts ?? 0)|number_format(0) }}</td>
                    </tr>
                    <tr>
                      <td class="text-gray-400 py-1.5"><i class="fa-solid fa-users w-4 text-center text-xs text-gray-500 mr-1.5"></i>{{ core__('common.members') }}</td>
                      <td class="text-white font-semibold text-right py-1.5">{{ (stats.total_members ?? 0)|number_format(0) }}</td>
                    </tr>
                  </tbody>
                </table>
              </div>
              {% if stats.last_member_username is defined and stats.last_member_username is not empty %}
              <div class="mt-3 pt-3 border-t border-white/5 text-xs flex items-center gap-1">
                <span class="text-gray-500">{{ core__('footer.last_registered') }}</span>
                <a href="{{ core_url('member/' ~ stats.last_member_username|e('url')) }}" class="text-blue-400 hover:text-blue-300 font-medium whitespace-nowrap truncate max-w-full inline-block" title="{{ core_e(stats.last_member_username) }}">{{ core_e(stats.last_member_username) }}</a>
              </div>
              {% endif %}
            </div>

            {# ── Çevrimiçi (4. Kolon) ── #}
            {% set onlineStats = onlineStats ?? { members_count: 0, guests_count: 0, bots_count: 0, total_online: 0 } %}
            <div class="bg-white/[0.04] border border-white/10 rounded-xl px-5 py-4 flex flex-col h-full">
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2">
                  <div class="h-7 w-7 rounded-lg bg-emerald-500/15 flex items-center justify-center relative">
                    <i class="fa-solid fa-globe text-emerald-400 text-xs"></i>
                    <span class="absolute top-1 right-1 flex h-2 w-2">
                       <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                       <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                    </span>
                  </div>
                  <h4 class="text-white font-semibold text-xs uppercase tracking-wider">{{ core__('footer.online') }}</h4>
                </div>
                <span class="text-emerald-400 font-bold text-lg leading-tight">{{ onlineStats.total_online ?? 0 }}</span>
              </div>
              <div class="flex-grow">
                <table class="w-full text-sm">
                  <tbody>
                    <tr>
                      <td class="text-gray-400 py-1.5"><i class="fa-solid fa-user-check w-4 text-center text-xs text-emerald-400/70 mr-1.5"></i>{{ core__('footer.online_members') }}</td>
                      <td class="text-white font-medium text-right py-1.5">{{ onlineStats.members_count ?? 0 }}</td>
                    </tr>
                    <tr>
                      <td class="text-gray-400 py-1.5"><i class="fa-solid fa-eye w-4 text-center text-xs text-gray-500 mr-1.5"></i>{{ core__('footer.online_guests') }}</td>
                      <td class="text-white font-medium text-right py-1.5">{{ onlineStats.guests_count ?? 0 }}</td>
                    </tr>
                    <tr>
                      <td class="text-gray-400 py-1.5"><i class="fa-solid fa-robot w-4 text-center text-xs text-gray-500 mr-1.5"></i>{{ core__('footer.online_bots') }}</td>
                      <td class="text-white font-medium text-right py-1.5">{{ onlineStats.bots_count ?? 0 }}</td>
                    </tr>
                  </tbody>
                </table>
              </div>
              <div class="mt-3 pt-3 border-t border-white/5 space-y-1.5">
                {% if (onlineStats.record_online_users ?? 0) > 0 %}
                <p class="text-[11px] text-gray-500">{{ core__('footer.record_online', { count: onlineStats.record_online_users, date: onlineStats.record_online_date is defined and onlineStats.record_online_date ? (onlineStats.record_online_date|date('d.m.Y H:i')) : '' }) }}</p>
                {% endif %}
                <a href="{{ core_url('online') }}" class="inline-flex items-center gap-1.5 text-emerald-400 hover:text-emerald-300 text-xs font-medium transition-colors">
                  {{ core__('footer.online_view_page') }}
                  <i class="fa-solid fa-arrow-right text-[10px]"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    <div class="w-full bg-[#141c24]">
      <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <div class="flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
            <span class="text-gray-500 shrink-0">{{ core__('footer.powered_by_prefix') }} <a href="https://www.megaforbb.com.tr" target="_blank" rel="noopener" class="text-gray-400 hover:text-white transition-colors">MegaforBB</a> — {{ core__('footer.copyright', { year: 'now'|date('Y'), name: 'MegaforBB' }) }}</span>
            <div class="flex items-center gap-4 flex-wrap justify-center sm:justify-end">
              <span class="text-gray-500">{{ core__('footer.language') }}</span>
              <a href="{{ core_url('set-locale') }}?locale=tr" class="hover:text-white transition-colors{{ (locale ?? '') == 'tr' ? ' text-white font-medium' : '' }}">{{ core__('common.lang_tr') }}</a>
              <span class="text-gray-600">|</span>
              <a href="{{ core_url('set-locale') }}?locale=en" class="hover:text-white transition-colors{{ (locale ?? '') == 'en' ? ' text-white font-medium' : '' }}">{{ core__('common.lang_en') }}</a>
              {% for item in (footer_menu_items ?? []) %}
              <span class="hidden sm:inline text-gray-600">·</span>
              {% if (item.href ?? '') == '#' %}
              <button type="button" onclick="window.scrollTo({top:0,behavior:'smooth'})" class="hover:text-gray-300 transition-colors flex items-center gap-1">
                <i class="fa-solid fa-arrow-up"></i> {{ core_e(item.label ?? '') }}
              </button>
              {% else %}
              <a href="{{ core_e(item.href ?? '#') }}" class="hover:text-gray-300 transition-colors">{{ core_e(item.label ?? '') }}</a>
              {% endif %}
              {% endfor %}
            </div>
          </div>
      </div>
    </div>
  </footer>
