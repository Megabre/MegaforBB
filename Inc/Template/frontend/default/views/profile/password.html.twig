{% extends 'base.html.twig' %}
{% block content %}
{% set error = error ?? '' %}
{% set success = success ?? '' %}
<div class="ips-profile-page">
{% include 'partials/profile_breadcrumb.html.twig' with { crumbs: [{ label: core__('profile.edit_link'), href: core_url('profile/edit') }, { label: core__('profile.password_change_link') }] } %}
{% include 'partials/profile_settings_shell.html.twig' with { user: user, active: 'password' } %}
<div class="ips-profile-settings-body">
  <div class="ips-profile-content-card">
    <div class="ips-profile-content-card__body" style="max-width:28rem;">
      {% if success %}<div class="ips-profile-alert ips-profile-alert--success">{{ core_e(success) }}</div>{% endif %}
      {% if error %}<div class="ips-profile-alert ips-profile-alert--error">{{ core_e(error) }}</div>{% endif %}
      <form action="{{ core_url('profile/password') }}" method="post">
        {{ core_csrf_field('profile_password')|raw }}
        <div class="ips-form-field"><label for="current_password">{{ core__('profile.current_password') }}</label><input type="password" name="current_password" id="current_password" required autocomplete="current-password"></div>
        <div class="ips-form-field"><label for="new_password">{{ core__('profile.password_title') }}</label><input type="password" name="new_password" id="new_password" required minlength="6" autocomplete="new-password"></div>
        <div class="ips-form-field"><label for="new_password_confirm">{{ core__('profile.password_confirm_label') }}</label><input type="password" name="new_password_confirm" id="new_password_confirm" required minlength="6" autocomplete="new-password"></div>
        <div class="ips-form-actions"><button type="submit" class="ips-profile__action-btn ips-profile__action-btn--primary">{{ core__('profile.password_update_btn') }}</button><a href="{{ core_url('profile/edit') }}" class="ips-profile__action-btn">{{ core__('common.cancel') }}</a></div>
      </form>
    </div>
  </div>
</div>
</div>
{% endblock %}
