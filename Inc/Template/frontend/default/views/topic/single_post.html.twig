{% extends 'base.html.twig' %}

{% block content %}
{% set topic = topic ?? null %}
{% set post = post ?? null %}
{% set cu = cu ?? null %}
{% if not topic or not post %}
  <p class="p-4 text-gray-500">{{ core__('post.single_post_not_found') }}</p>
{% else %}
{% set topicUrl = (topic.type ?? '') == 'article' ? core_url(article_url_path_by_id(topic.id ?? 0)) : topic_url(topic) %}
{% set avatarUrl = (post.is_banned|default(false)) ? banned_avatar_url() : ((post.avatar_path ?? '') is not empty ? asset_url(post.avatar_path) : ('https://ui-avatars.com/api/?name=' ~ avatar_display_name(post.username)|url_encode ~ '&size=100')) %}

<div class="max-w-5xl mx-auto px-4 py-8">
  <div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-[#1a252f] break-words">
        <a href="{{ topicUrl }}" class="hover:underline">{{ core_e(topic.title) }}</a>
        <span class="text-gray-500 font-normal text-lg ml-2">{{ core__('post.single_post_subtitle') }}</span>
      </h1>
      <nav class="flex text-sm text-gray-500 mt-2" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
          <li><a href="{{ core_url('') }}" class="hover:text-amber-600"><i class="fa-solid fa-home mr-2"></i>{{ core__('common.home') }}</a></li>
          <li><i class="fa-solid fa-chevron-right text-[10px] mx-2"></i><a href="{{ core_url('forum/' ~ (topic.forum_slug ?? '')|e('url')) }}" class="hover:text-amber-600">{{ core_e(topic.forum_name ?? '') }}</a></li>
          <li><i class="fa-solid fa-chevron-right text-[10px] mx-2"></i><span class="text-gray-400">{{ core__('post.single_post_breadcrumb') }}</span></li>
        </ol>
      </nav>
    </div>
    <a href="{{ topicUrl }}" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50">
      <i class="fa-solid fa-arrow-left"></i> {{ core__('post.back_to_topic_btn') }}
    </a>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <div class="flex flex-col md:flex-row">
      <div class="w-full md:w-56 bg-slate-50 p-4 border-b md:border-b-0 md:border-r border-gray-200 flex-shrink-0 flex flex-col items-center">
        <a href="{{ core_url('member/' ~ (post.username ?? '')|e('url')) }}" class="block mb-3 relative">
          <img src="{{ core_e(avatarUrl) }}" alt="" class="w-20 h-20 md:w-24 md:h-24 rounded-full object-cover border-4 border-white shadow-md">
        </a>
        {% if post.is_banned|default(false) %}<p class="text-[10px] font-bold uppercase text-red-600 mb-0.5">{{ core__('member.banned_badge') }}</p>{% endif %}
        <a href="{{ core_url('member/' ~ (post.username ?? '')|e('url')) }}" class="font-bold text-[#1a252f] text-base md:text-lg hover:text-amber-600 text-center">{{ core_e(post.username ?? '') }}</a>
        {% if post.role_name ?? '' %}
        <span class="inline-block mt-2 px-2.5 py-1 text-[11px] font-bold uppercase rounded text-white" style="background-color: {{ post.role_color ?? '#718096' }}">{{ core_e(post.role_name) }}</span>
        {% endif %}
        <div class="mt-4 w-full px-2 text-xs text-slate-500 border-t border-gray-200 pt-3 text-center">
          <div><strong class="text-slate-700">{{ core__('post.post_count_label') }}</strong> {{ (post.post_count ?? 0)|number_format(0, '', '') }}</div>
        </div>
      </div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center justify-between px-4 md:px-6 py-3 border-b border-gray-100 bg-white">
          <span class="text-xs text-gray-500"><i class="fa-regular fa-clock mr-1"></i> {{ core_e(post.created_at ?? '') }}</span>
          <a href="{{ topic_url(topic) ~ '#post-' ~ (post.id ?? 0) }}" class="text-xs text-[#206bc4] hover:underline">#{{ post.id ?? 0 }}</a>
        </div>
        <div class="p-4 md:p-6 prose max-w-none">
          {{ core_sanitize_html(core_display_post_html(post.body ?? '', post.body_html ?? ''))|smileys|raw }}
        </div>
      </div>
    </div>
  </div>
</div>
{% endif %}
{% endblock %}
