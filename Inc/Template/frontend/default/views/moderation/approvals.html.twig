{% extends 'base.html.twig' %}

{% block content %}
{% set list = list ?? [] %}
{% set modError = flash('mod_error') %}
{% set modOk = flash('mod_ok') %}

<div class="mt-4 text-sm text-gray-600">
  <nav aria-label="Breadcrumb" class="bg-white border border-gray-200 rounded-md shadow-sm px-4 py-2">
    <ol class="flex items-center gap-2">
      <li><a href="{{ core_url('') }}" class="text-[#1a252f] hover:text-blue-500 hover:underline">{{ core__('common.home') }}</a></li>
      <li>›</li>
      <li class="text-gray-700">{{ core__('mod.page_title_approvals') }}</li>
    </ol>
  </nav>
</div>

{% if modError %}
<div class="mt-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-md text-sm">{{ core_e(modError) }}</div>
{% endif %}
{% if modOk %}
<div class="mt-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-md text-sm">{{ core_e(modOk) }}</div>
{% endif %}

{% if list is not empty %}
<div class="mt-4 flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-600 shadow-sm">
  <p class="m-0">{{ core__('mod.bulk_users_hint') }}</p>
  <div class="flex flex-wrap items-center gap-2">
    <form method="post" action="{{ core_url('moderation/approvals/bulk-approve') }}" class="inline" onsubmit="return confirm('{{ core__('mod.bulk_confirm_approve_all')|e('js') }}');">
      {{ core_csrf_field('mod_approve')|raw }}
      <input type="hidden" name="apply_all" value="1">
      <button type="submit" class="rounded border border-green-200 bg-green-50 px-3 py-1.5 text-xs font-medium text-green-800 hover:bg-green-100">{{ core__('mod.bulk_approve_all') }}</button>
    </form>
    <form method="post" action="{{ core_url('moderation/approvals/bulk-reject') }}" class="inline" onsubmit="return confirm('{{ core__('mod.bulk_confirm_reject_all')|e('js') }}');">
      {{ core_csrf_field('mod_approve')|raw }}
      <input type="hidden" name="apply_all" value="1">
      <button type="submit" class="rounded border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-medium text-red-800 hover:bg-red-100">{{ core__('mod.bulk_reject_all') }}</button>
    </form>
    <form method="post" id="mod-users-bulk-selected-form" action="{{ core_url('moderation/approvals/bulk-approve') }}" class="hidden" aria-hidden="true">
      {{ core_csrf_field('mod_approve')|raw }}
      <div id="mod-users-bulk-selected-slot"></div>
    </form>
    <button type="button" class="rounded border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-gray-50" id="mod-users-btn-select-all">{{ core__('mod.bulk_select_all_pending_users') }}</button>
    <button type="button" class="rounded border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-800 hover:bg-gray-50" id="mod-users-btn-approve-selected">{{ core__('mod.bulk_approve_selected') }}</button>
    <button type="button" class="rounded border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-red-700 hover:bg-red-50" id="mod-users-btn-reject-selected">{{ core__('mod.bulk_reject_selected') }}</button>
  </div>
</div>
{% endif %}

<div class="mt-6 bg-white ring-1 ring-gray-200 shadow-sm rounded-lg overflow-hidden">
  <div class="px-4 py-3 border-b border-gray-200 bg-slate-50 font-semibold text-[#1a252f] flex items-center gap-2">
    <i class="fa-solid fa-user-check"></i> {{ core__('mod.pending_users_title') }}
  </div>
  {% if list is empty %}
  <div class="p-8 text-center text-gray-500">{{ core__('mod.no_pending_yet') }}</div>
  {% else %}
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
        <tr>
          <th class="w-10 px-4 py-3"><span class="sr-only">{{ core__('mod.col_select') }}</span></th>
          <th class="px-4 py-3">{{ core__('mod.col_user') }}</th>
          <th class="px-4 py-3">{{ core__('mod.col_email') }}</th>
          <th class="px-4 py-3">{{ core__('mod.col_reg_date') }}</th>
          <th class="px-4 py-3">{{ core__('mod.col_action') }}</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        {% for u in list %}
        <tr class="hover:bg-gray-50/50">
          <td class="px-4 py-3 align-top">
            <input type="checkbox" class="mod-user-cb h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" value="{{ u.id ?? 0 }}" aria-label="{{ core__('mod.col_select') }} {{ core_e(u.username ?? '') }}">
          </td>
          <td class="px-4 py-3">
            <a href="{{ core_url('member/' ~ (u.username ?? '')|e('url')) }}" class="text-[#1a252f] hover:text-blue-600 font-medium">{{ core_e(u.username ?? '') }}</a>
          </td>
          <td class="px-4 py-3 text-sm text-gray-600">{{ core_e(u.email ?? '') }}</td>
          <td class="px-4 py-3 text-sm text-gray-600">{{ core_e(u.created_at ?? '') }}</td>
          <td class="px-4 py-3">
            <form action="{{ core_url('moderation/approvals/' ~ (u.id ?? 0) ~ '/approve') }}" method="post" class="inline">
              {{ core_csrf_field('mod_approve')|raw }}
              <button type="submit" class="text-sm text-white bg-green-600 hover:bg-green-700 rounded px-3 py-1.5">{{ core__('mod.approve_btn') }}</button>
            </form>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
</div>
{% if list is not empty %}
<script>
(function () {
  var msgNone = {{ core__('mod.bulk_nothing_selected_users')|json_encode|raw }};
  var msgReject = {{ core__('mod.bulk_confirm_reject_selected')|json_encode|raw }};
  var urlApprove = {{ core_url('moderation/approvals/bulk-approve')|json_encode|raw }};
  var urlReject = {{ core_url('moderation/approvals/bulk-reject')|json_encode|raw }};
  function selectedIds() {
    return Array.prototype.slice.call(document.querySelectorAll('input.mod-user-cb:checked')).map(function (el) { return el.value; });
  }
  function submitSelected(url) {
    var ids = selectedIds();
    if (!ids.length) { window.alert(msgNone); return; }
    var form = document.getElementById('mod-users-bulk-selected-form');
    var slot = document.getElementById('mod-users-bulk-selected-slot');
    slot.innerHTML = '';
    ids.forEach(function (id) {
      var h = document.createElement('input');
      h.type = 'hidden';
      h.name = 'user_ids[]';
      h.value = id;
      slot.appendChild(h);
    });
    form.action = url;
    form.submit();
  }
  var ba = document.getElementById('mod-users-btn-approve-selected');
  var br = document.getElementById('mod-users-btn-reject-selected');
  if (ba) ba.addEventListener('click', function () { submitSelected(urlApprove); });
  if (br) br.addEventListener('click', function () { if (!window.confirm(msgReject)) return; submitSelected(urlReject); });
  var selAll = document.getElementById('mod-users-btn-select-all');
  if (selAll) selAll.addEventListener('click', function () {
    Array.prototype.forEach.call(document.querySelectorAll('input.mod-user-cb'), function (el) { el.checked = true; });
  });
})();
</script>
{% endif %}
{% endblock %}
