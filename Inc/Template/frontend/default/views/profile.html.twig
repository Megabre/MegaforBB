{% extends 'base.html.twig' %}

{% block content %}
{% set u = profileUser ?? null %}
{% set userStats = userStats ?? { post_count: 0, topic_count: 0, like_count: 0, reputation_positive: 0, reputation_negative: 0, subscription_count: 0 } %}
{% set activityStream = activityStream ?? [] %}
{% set activityFilter = activityFilter ?? 'all' %}
{% set activityHasMore = activityHasMore ?? false %}
{% set isOwnProfile = isOwnProfile ?? false %}
{% set reputationEnabled = reputationEnabled ?? true %}
{% set idelistEnabled = idelistEnabled ?? (idelist_enabled ?? false) %}
{% set iBlockedThem = iBlockedThem ?? false %}
{% set theyBlockedMe = theyBlockedMe ?? false %}
{% set rewardLevel = rewardLevel ?? null %}
{% set profileOk = flash('profile_ok') %}
{% set repError = flash('rep_error') %}
{% set profileCommentError = flash('profile_comment_error') %}
{% set profileComments = profileComments ?? [] %}
{% set profileCommentsEnabled = profileCommentsEnabled ?? false %}
{% set allowProfileComments = allowProfileComments ?? true %}
{% set showFullProfile = showFullProfile ?? true %}
{% set profileViewStats = profileViewStats ?? { unique_viewers: 0, total_views: 0 } %}

<div class="ips-profile-page">
{% if not u %}
  <div class="ips-profile-wrap"><div class="ips-profile-empty"><i class="fa-solid fa-user-slash"></i><p>{{ core_e(lang('error.not_found')) }}</p></div></div>
{% else %}
{% set baseUrl = core_url('member/' ~ member_url_path(u)) %}
{% set showFullProfile = not theyBlockedMe and not iBlockedThem %}
{% set coverUrl = u.cover_photo_path is not empty ? asset_url(u.cover_photo_path) : null %}
{% set avatarUrl = (u.is_banned|default(false)) ? banned_avatar_url() : (u.avatar_path is not empty ? asset_url(u.avatar_path) : 'https://ui-avatars.com/api/?name=' ~ avatar_display_name(u.username ?? null)|url_encode) %}

{% include 'partials/profile_breadcrumb.html.twig' with { crumbs: [
  { label: core__('common.members'), href: core_url('members') },
  { label: u.username }
] } %}

{% if profileOk %}<div class="ips-profile-alert ips-profile-alert--success">{{ core_e(profileOk) }}</div>{% endif %}

{% if theyBlockedMe %}
  <div class="ips-profile-wrap"><div class="ips-profile-empty"><i class="fa-solid fa-user-lock"></i><p class="font-semibold">{{ core__('member.profile_blocked_you') }}</p><p class="text-sm text-gray-500">{{ core__('member.profile_blocked_you_desc') }}</p></div></div>

{% elseif iBlockedThem %}
  <div class="ips-profile-wrap">
    {% include 'partials/profile_shell.html.twig' with {
      profileUser: u, isOwnProfile: false, coverUrl: null, avatarUrl: avatarUrl, rewardLevel: null,
      userStats: userStats, activeTab: 'activity', showActions: false, showFullProfile: false, compact: true, idelistEnabled: idelistEnabled
    } %}
    <div class="ips-profile-layout"><div class="ips-profile-layout__main"><div class="ips-profile-empty"><p>{{ core__('member.you_blocked') }}</p>
      <form method="post" action="{{ core_url('member/' ~ member_url_path(u) ~ '/unblock') }}" class="mt-3"><input type="hidden" name="_token" value="{{ core_e(core_csrf_token('member_unblock')) }}"><button type="submit" class="ips-profile__action-btn ips-profile__action-btn--primary">{{ core__('member.unblock_btn') }}</button></form>
    </div></div></div>
  </div>

{% else %}
  <div class="ips-profile-wrap">
    {% include 'partials/profile_shell.html.twig' with {
      profileUser: u, isOwnProfile: isOwnProfile, coverUrl: coverUrl, avatarUrl: avatarUrl, rewardLevel: rewardLevel,
      userStats: userStats, activeTab: 'activity', showCoverUpload: isOwnProfile, showFullProfile: showFullProfile,
      reputationEnabled: reputationEnabled, idelistEnabled: idelistEnabled,
      profileViewStats: profileViewStats, showWatcher: true
    } %}

    {% if repError %}<div class="ips-profile-alert ips-profile-alert--error">{{ core_e(repError) }}</div>{% endif %}
    {% if profileCommentError %}<div class="ips-profile-alert ips-profile-alert--error">{{ core_e(profileCommentError) }}</div>{% endif %}

    <div class="ips-profile-layout ips-profile-layout--activity">
      <div class="ips-profile-layout__main">
        {% include 'partials/profile_activity_box.html.twig' with { profileUser: u, activityStream: activityStream, activityFilter: activityFilter, activityHasMore: activityHasMore, idelistEnabled: idelistEnabled } %}

        {% if showFullProfile and profileCommentsEnabled and allowProfileComments %}
        <section class="ips-profile-panel">
          <header class="ips-profile-panel__head">
            <h2 class="ips-profile-panel__title"><i class="fa-regular fa-comments"></i> {{ core__('member.profile_comments') }}</h2>
            {% if isOwnProfile %}<a href="{{ core_url('profile/preferences') }}" class="ips-profile-panel__link">{{ core__('member.profile_comments_settings_hint') }}</a>{% endif %}
          </header>
          <div class="ips-profile-panel__body">
            {% if user and not isOwnProfile %}
            <form method="post" action="{{ core_url('member/' ~ member_url_path(u) ~ '/profile-comments') }}" class="ips-profile-comment-form">
              <input type="hidden" name="_token" value="{{ core_e(core_csrf_token('profile_comment')) }}">
              <textarea name="body" rows="3" placeholder="{{ core__('member.profile_comment_placeholder') }}" required></textarea>
              <button type="submit" class="ips-profile__action-btn ips-profile__action-btn--primary">{{ core__('member.profile_comment_add') }}</button>
            </form>
            {% endif %}
            {% for c in profileComments %}
            <div class="ips-profile-comment">
              <a href="{{ core_url('member/' ~ (c.author_username|e('url'))) }}"><img src="{{ core_e(c.author_avatar_url) }}" alt="" class="ips-profile-comment__avatar"></a>
              <div class="ips-profile-comment__body">
                <div class="ips-profile-comment__header"><a href="{{ core_url('member/' ~ (c.author_username|e('url'))) }}" class="ips-profile-comment__author">{{ core_e(c.author_username) }}</a><span class="ips-profile-comment__date">{{ c.created_at|date('d.m.Y H:i') }}</span></div>
                <div class="ips-profile-comment__text">{{ c.body_html|raw }}</div>
                {% if user and (isOwnProfile or (user.id is defined and user.id == c.author_id)) %}
                <form method="post" action="{{ core_url('member/' ~ member_url_path(u) ~ '/profile-comments/' ~ c.id ~ '/delete') }}" class="ips-profile-comment__delete" onsubmit="return confirm('{{ core__('member.profile_comment_delete_confirm') }}');">
                  <input type="hidden" name="_token" value="{{ core_e(core_csrf_token('profile_comment_delete')) }}"><button type="submit">{{ core__('member.profile_comment_delete_btn') }}</button>
                </form>
                {% endif %}
              </div>
            </div>
            {% else %}<p class="ips-profile-empty-text">{{ core__('member.profile_comments_empty') }}</p>{% endfor %}
          </div>
        </section>
        {% endif %}
      </div>

      {% if showFullProfile %}
      <aside class="ips-profile-layout__side ips-profile-layout__side--sticky">
        <div class="ips-profile-side-inner">
          {% include 'partials/profile_sidebar_card.html.twig' with { profileUser: u, userStats: userStats, rewardLevel: rewardLevel, reputationEnabled: reputationEnabled, isOwnProfile: isOwnProfile } %}
        </div>
      </aside>
      {% endif %}
    </div>
  </div>
{% endif %}

{% if reputationEnabled and not isOwnProfile and user and showFullProfile %}
<div id="rep-modal" class="fixed inset-0 z-50 hidden" aria-hidden="true">
  <div class="fixed inset-0 bg-black/50" id="rep-modal-backdrop"></div>
  <div class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-white rounded-lg shadow-xl p-6 z-10">
    <h3 class="text-lg font-semibold mb-4">{{ core__('member.give_rep_title') }}</h3>
    <form id="rep-form" method="post" action="">
      <input type="hidden" name="_token" value="{{ core_e(core_csrf_token('give_rep')) }}">
      <input type="hidden" name="value" id="rep-value" value="1">
      <div class="mb-4"><label class="block text-sm font-medium mb-1">{{ core__('member.give_rep_comment') }}</label><textarea name="comment" id="rep-comment" rows="3" class="w-full border rounded-md px-3 py-2" required></textarea></div>
      <div class="flex justify-end gap-2"><button type="button" id="rep-modal-cancel" class="ips-profile__action-btn">{{ core__('common.cancel') }}</button><button type="submit" class="ips-profile__action-btn ips-profile__action-btn--primary">{{ core__('member.give_rep_submit') }}</button></div>
    </form>
  </div>
</div>
{% endif %}

{% include 'partials/profile_viewers_modal.html.twig' with { profileUser: u } %}
{% endif %}
</div>
{% endblock %}
